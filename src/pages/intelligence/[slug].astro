---
import "../../styles/global.css";
import { commodityIntelData, getCommodityBySlug } from "../../data/commodity-intelligence";
import type { CommodityIntel } from "../../data/commodity-intelligence";

export function getStaticPaths() {
  return commodityIntelData.map((c) => ({
    params: { slug: c.slug },
  }));
}

const { slug } = Astro.params;
const commodity = getCommodityBySlug(slug as string)!;

const siteUrl = "https://origindirectgroup.com";
const canonicalUrl = new URL(`/intelligence/${commodity.slug}`, siteUrl).href;
const pageTitle = `${commodity.name} Intelligence - Supply, Pricing & Origin Analysis | Origin Direct`;
const pageDescription = `Deep-dive ${commodity.name.toLowerCase()} market intelligence. Growing regions, seasonal calendar, origin comparison, price drivers and supply outlook. Updated March 2026.`;

const products = [
  { name: "Shea Butter", slug: "shea-butter" },
  { name: "Cocoa", slug: "cocoa" },
  { name: "Cashew Nuts", slug: "cashew-nuts" },
  { name: "Hookah Charcoal", slug: "hookah-charcoal" },
  { name: "Hibiscus", slug: "hibiscus" },
  { name: "Sesame Seeds", slug: "sesame-seeds" },
  { name: "Moringa", slug: "moringa" },
  { name: "Ginger", slug: "ginger" },
];

const navLinks = [
  { name: "Prices", href: "/prices" },
  { name: "Markets", href: "/markets" },
  { name: "Guides", href: "/guides" },
  { name: "About", href: "/about" },
  { name: "Blog", href: "/blog" },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Intelligence", "item": `${siteUrl}/intelligence` },
    { "@type": "ListItem", "position": 3, "name": commodity.name, "item": canonicalUrl },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": commodity.faqs.map((f) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer },
  })),
};

const productSchema = commodity.ours ? {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": commodity.name,
  "description": pageDescription,
  "brand": { "@type": "Brand", "name": "Origin Direct Group" },
  "category": commodity.category,
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "USD",
    "lowPrice": commodity.currentPrice * 0.9,
    "highPrice": commodity.currentPrice * 1.1,
    "availability": "https://schema.org/InStock",
  },
} : null;

const riskColors = {
  high: { bg: "bg-red-500/10", text: "text-red-400", border: "border-red-500/20", label: "HIGH RISK" },
  elevated: { bg: "bg-amber-500/10", text: "text-amber-400", border: "border-amber-500/20", label: "ELEVATED" },
  watch: { bg: "bg-yellow-500/10", text: "text-yellow-400", border: "border-yellow-500/20", label: "WATCH" },
  normal: { bg: "bg-emerald-500/10", text: "text-emerald-400", border: "border-emerald-500/20", label: "NORMAL" },
};
const risk = riskColors[commodity.riskLevel] || riskColors.normal;

const changePositive = commodity.change30d >= 0;
const priceFormatted = commodity.currentPrice.toLocaleString("en-US");

// Calculate map bounds from regions
const lats = commodity.regions.map((r) => r.lat);
const lons = commodity.regions.map((r) => r.lon);
const centerLat = (Math.min(...lats) + Math.max(...lats)) / 2;
const centerLon = (Math.min(...lons) + Math.max(...lons)) / 2;

const regionRiskColors = {
  high: "#ef4444",
  medium: "#f59e0b",
  low: "#10b981",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Origin Direct Group" />
    <meta name="theme-color" content="#0a0f1a" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Origin Direct Group" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    {productSchema && <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />}
  </head>

  <body class="bg-[#0a0f1a] text-white font-sans min-h-screen">

    <!-- Dark Header -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-[#0a0f1a]/90 backdrop-blur-xl border-b border-white/5">
      <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2 group">
            <svg class="w-7 h-7 text-emerald-400 group-hover:text-emerald-300 transition-colors" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M16 2C16 2 8 8 8 16c0 5.5 3.6 10 8 10s8-4.5 8-10c0-8-8-14-8-14z" fill="currentColor" opacity="0.2"/>
              <path d="M16 4c0 0-6 5-6 12 0 4.4 2.7 8 6 8s6-3.6 6-8c0-7-6-12-6-12z" fill="currentColor" opacity="0.4"/>
              <path d="M16 8c0 0-4 3.5-4 8 0 3 1.8 5.5 4 5.5s4-2.5 4-5.5c0-4.5-4-8-4-8z" fill="currentColor"/>
            </svg>
            <span class="text-lg font-bold tracking-tight text-white">
              ORIGIN <span class="font-medium text-emerald-400">DIRECT</span>
            </span>
          </a>

          <nav class="hidden lg:flex items-center gap-6">
            <div class="relative" id="ci-products-dropdown">
              <button id="ci-products-btn" class="flex items-center gap-1 text-sm font-medium text-gray-300 hover:text-white transition-colors py-2">
                Products
                <svg class="w-4 h-4 transition-transform" id="ci-products-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div id="ci-products-menu" class="absolute top-full left-0 pt-2 opacity-0 invisible pointer-events-none transition-all duration-200">
                <div class="bg-[#141a2a] rounded-xl shadow-2xl border border-white/10 py-3 w-56">
                  {products.map((product) => (
                    <a href={`/products/${product.slug}`} class="block px-5 py-2.5 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                      {product.name}
                    </a>
                  ))}
                  <hr class="my-2 border-white/10" />
                  <a href="/products" class="block px-5 py-2.5 text-sm font-medium text-emerald-400 hover:bg-white/5 transition-colors">
                    View All Products
                  </a>
                </div>
              </div>
            </div>

            {navLinks.map((link) => (
              <a href={link.href} class="text-sm font-medium text-gray-300 hover:text-white transition-colors">
                {link.name}
              </a>
            ))}

            <a href="/quote" class="inline-flex items-center px-4 py-2 bg-emerald-600 text-white text-sm font-semibold rounded-lg hover:bg-emerald-500 transition-colors">
              Request Quote
            </a>
          </nav>

          <button id="ci-mobile-btn" class="lg:hidden p-2 text-gray-300 hover:text-white transition-colors" aria-label="Toggle menu">
            <svg id="ci-menu-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="ci-menu-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <div id="ci-mobile-menu" class="lg:hidden hidden bg-[#0a0f1a] border-t border-white/5">
        <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
          <a href="/products" class="block px-3 py-3 text-sm font-medium text-gray-300 hover:bg-white/5 rounded-lg">Products</a>
          {navLinks.map((link) => (
            <a href={link.href} class="block px-3 py-3 text-sm font-medium text-gray-300 hover:bg-white/5 rounded-lg">
              {link.name}
            </a>
          ))}
          <div class="pt-3">
            <a href="/quote" class="block w-full text-center px-5 py-3 bg-emerald-600 text-white text-sm font-semibold rounded-lg hover:bg-emerald-500 transition-colors">
              Request Quote
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Spacer -->
    <div class="h-16"></div>

    <main>
      <!-- Breadcrumb -->
      <div class="bg-[#0a0f1a] border-b border-white/5">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-3">
          <nav class="flex items-center gap-2 text-sm text-gray-500">
            <a href="/" class="hover:text-gray-300 transition-colors">Home</a>
            <span>/</span>
            <a href="/intelligence" class="hover:text-gray-300 transition-colors">Intelligence</a>
            <span>/</span>
            <span class="text-gray-300">{commodity.name}</span>
          </nav>
        </div>
      </div>

      <!-- Hero -->
      <section class="bg-gradient-to-r from-[#0a0f1a] via-[#0f1a2e] to-[#0a0f1a] border-b border-white/5 py-8 sm:py-12">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6">
            <div>
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-bold tracking-widest uppercase text-gray-500">{commodity.category}</span>
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold ${risk.bg} ${risk.text} border ${risk.border}`}>
                  {risk.label}
                </span>
                {commodity.ours && (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                    WE SUPPLY THIS
                  </span>
                )}
              </div>
              <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white tracking-tight mb-3">
                {commodity.name}
              </h1>
              <p class="text-gray-400 max-w-2xl">
                {commodity.ensoImpact}
              </p>
            </div>
            <div class="shrink-0 bg-[#141a2a] rounded-xl border border-white/10 p-6 min-w-[220px]">
              <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Current Price</div>
              <div class="text-3xl font-bold text-white font-mono">${priceFormatted}</div>
              <div class="text-xs text-gray-500 mt-0.5">per {commodity.unit}</div>
              <div class={`flex items-center gap-1 mt-3 text-sm font-semibold ${changePositive ? "text-emerald-400" : "text-red-400"}`}>
                <svg class={`w-4 h-4 ${changePositive ? "" : "rotate-180"}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                </svg>
                {changePositive ? "+" : ""}{commodity.change30d}% (30d)
              </div>
              {commodity.projectedPrice && (
                <div class="mt-3 pt-3 border-t border-white/10">
                  <div class="text-xs text-gray-500">Projected</div>
                  <div class="text-sm font-medium text-amber-400">{commodity.projectedPrice}</div>
                </div>
              )}
            </div>
          </div>
        </div>
      </section>

      <!-- Growing Regions Map -->
      <section class="border-b border-white/5">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <h2 class="text-xl font-bold text-white mb-1">Growing Regions</h2>
          <p class="text-sm text-gray-500 mb-4">Click a region for details. Circles colored by risk level, sized by production significance.</p>
        </div>
        <div id="regions-map" style="height: 450px; width: 100%; background: #0a0f1a;"></div>
      </section>

      <!-- Origin Comparison Table -->
      <section class="border-b border-white/5 py-10">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-xl font-bold text-white mb-6">Origin Comparison</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-white/10">
                  <th class="text-left py-3 px-4 text-xs font-bold tracking-wider uppercase text-gray-500">Origin</th>
                  <th class="text-left py-3 px-4 text-xs font-bold tracking-wider uppercase text-gray-500">Production</th>
                  <th class="text-left py-3 px-4 text-xs font-bold tracking-wider uppercase text-gray-500">Quality Notes</th>
                  <th class="text-left py-3 px-4 text-xs font-bold tracking-wider uppercase text-gray-500">Price Range</th>
                  <th class="text-left py-3 px-4 text-xs font-bold tracking-wider uppercase text-gray-500">Key Advantage</th>
                </tr>
              </thead>
              <tbody>
                {commodity.origins.map((o, i) => {
                  const isOurs = commodity.ours && i === 0;
                  return (
                    <tr class={`border-b border-white/5 ${isOurs ? "bg-emerald-500/5" : "hover:bg-white/[0.02]"}`}>
                      <td class="py-3 px-4 font-medium text-white">
                        {o.origin}
                        {isOurs && <span class="ml-2 text-xs text-emerald-400 font-bold">OUR ORIGIN</span>}
                      </td>
                      <td class="py-3 px-4 text-gray-400">{o.production}</td>
                      <td class="py-3 px-4 text-gray-400 max-w-xs">{o.quality}</td>
                      <td class="py-3 px-4 text-gray-300 font-mono text-xs">{o.price}</td>
                      <td class="py-3 px-4 text-gray-400">{o.advantage}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- Seasonal Calendar -->
      <section class="border-b border-white/5 py-10">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-xl font-bold text-white mb-2">Seasonal Calendar</h2>
          <p class="text-sm text-gray-500 mb-6">
            <span class="inline-block w-3 h-3 rounded-sm bg-emerald-500/30 border border-emerald-500/50 mr-1 align-middle"></span> Good time to buy
            <span class="inline-block w-3 h-3 rounded-sm bg-gray-500/20 border border-gray-500/30 mr-1 ml-4 align-middle"></span> Neutral
            <span class="inline-block w-3 h-3 rounded-sm bg-red-500/20 border border-red-500/40 mr-1 ml-4 align-middle"></span> Peak prices / low supply
          </p>
          <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-12 gap-2">
            {commodity.seasonal.map((s) => {
              const signalClasses: any = {
                buy: "bg-emerald-500/10 border-emerald-500/30",
                neutral: "bg-white/[0.03] border-white/10",
                wait: "bg-red-500/10 border-red-500/30",
              };
              const dotClasses: any = {
                buy: "bg-emerald-400",
                neutral: "bg-gray-500",
                wait: "bg-red-400",
              };
              return (
                <div class={`rounded-lg border p-3 ${signalClasses[s.buySignal]}`}>
                  <div class="text-xs font-bold text-gray-300 mb-1">{s.month}</div>
                  <div class="flex items-center gap-1.5 mb-1">
                    <span class={`w-1.5 h-1.5 rounded-full ${dotClasses[s.buySignal]}`}></span>
                    <span class={`text-[10px] font-semibold uppercase ${s.buySignal === "buy" ? "text-emerald-400" : s.buySignal === "wait" ? "text-red-400" : "text-gray-500"}`}>
                      {s.buySignal}
                    </span>
                  </div>
                  <div class="text-[10px] text-gray-500 leading-tight">{s.activity}</div>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <!-- Price Drivers -->
      <section class="border-b border-white/5 py-10">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-xl font-bold text-white mb-6">Price Drivers</h2>
          <div class="grid md:grid-cols-2 gap-3">
            {commodity.priceDrivers.map((driver) => (
              <div class="flex items-start gap-3 bg-[#141a2a] rounded-lg border border-white/5 p-4">
                <svg class="w-5 h-5 text-amber-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
                <span class="text-sm text-gray-300">{driver}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Supply Outlook -->
      <section class="border-b border-white/5 py-10">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-xl font-bold text-white mb-6">Supply Outlook</h2>
          <div class="prose prose-invert max-w-none">
            {commodity.supplyOutlook.split("\n\n").map((paragraph) => (
              <p class="text-gray-300 text-sm leading-relaxed mb-4">{paragraph}</p>
            ))}
          </div>
        </div>
      </section>

      <!-- Best Time to Buy -->
      <section class="border-b border-white/5 py-10">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
          <div class="bg-amber-500/10 border border-amber-500/20 rounded-xl p-6 sm:p-8">
            <div class="flex items-start gap-4">
              <div class="shrink-0 w-12 h-12 rounded-lg bg-amber-500/20 flex items-center justify-center">
                <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h2 class="text-lg font-bold text-amber-400 mb-2">Best Time to Buy</h2>
                <p class="text-gray-300 text-sm leading-relaxed">{commodity.bestTimeToBuy}</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQs -->
      <section class="border-b border-white/5 py-10">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-xl font-bold text-white mb-6">Frequently Asked Questions</h2>
          <div class="space-y-4">
            {commodity.faqs.map((faq) => (
              <details class="group bg-[#141a2a] border border-white/5 rounded-lg">
                <summary class="flex items-center justify-between cursor-pointer p-5 text-sm font-medium text-white hover:text-emerald-400 transition-colors">
                  {faq.question}
                  <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-5 pb-5 text-sm text-gray-400 leading-relaxed border-t border-white/5 pt-4">
                  {faq.answer}
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="py-12 sm:py-16">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
          {commodity.ours ? (
            <div class="bg-gradient-to-br from-emerald-900/30 to-[#141a2a] border border-emerald-500/20 rounded-2xl p-8 sm:p-12">
              <div class="grid lg:grid-cols-2 gap-8 items-start">
                <div>
                  <div class="inline-flex items-center gap-2 px-3 py-1 bg-emerald-500/10 rounded-full text-xs font-bold text-emerald-400 mb-4">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                    We Supply {commodity.name}
                  </div>
                  <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">
                    Get a Competitive Quote
                  </h2>
                  <p class="text-gray-400 mb-6">
                    Origin Direct sources {commodity.name.toLowerCase()} directly from producers in our network.
                    We handle logistics, quality control, and documentation from origin to your warehouse.
                  </p>
                  <ul class="space-y-2 text-sm text-gray-300">
                    <li class="flex items-center gap-2">
                      <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                      Direct from verified producers
                    </li>
                    <li class="flex items-center gap-2">
                      <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                      Full traceability and documentation
                    </li>
                    <li class="flex items-center gap-2">
                      <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                      Quality inspection before shipment
                    </li>
                    <li class="flex items-center gap-2">
                      <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                      CIF/FOB delivery worldwide
                    </li>
                  </ul>
                </div>
                <div>
                  <form action="https://formspree.io/f/mjgaqaqj" method="POST" class="space-y-4">
                    <input type="hidden" name="product" value={commodity.name} />
                    <input type="hidden" name="source" value={`intelligence/${commodity.slug}`} />
                    <div>
                      <label for="cta-company" class="block text-xs font-medium text-gray-400 mb-1">Company</label>
                      <input type="text" id="cta-company" name="company" required placeholder="Your company name" class="w-full px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-transparent" />
                    </div>
                    <div>
                      <label for="cta-email" class="block text-xs font-medium text-gray-400 mb-1">Email</label>
                      <input type="email" id="cta-email" name="email" required placeholder="you@company.com" class="w-full px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-transparent" />
                    </div>
                    <div>
                      <label for="cta-quantity" class="block text-xs font-medium text-gray-400 mb-1">Quantity needed</label>
                      <input type="text" id="cta-quantity" name="quantity" required placeholder="e.g., 20 MT" class="w-full px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-transparent" />
                    </div>
                    <div>
                      <label for="cta-destination" class="block text-xs font-medium text-gray-400 mb-1">Destination</label>
                      <input type="text" id="cta-destination" name="destination" required placeholder="e.g., Rotterdam, Netherlands" class="w-full px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-transparent" />
                    </div>
                    <button type="submit" class="w-full px-6 py-3 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-500 active:bg-emerald-700 transition-colors text-sm">
                      Request {commodity.name} Quote
                    </button>
                  </form>
                </div>
              </div>
            </div>
          ) : (
            <div class="text-center bg-[#141a2a] border border-white/10 rounded-2xl p-8 sm:p-12">
              <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">
                Need Help Sourcing {commodity.name}?
              </h2>
              <p class="text-gray-400 max-w-lg mx-auto mb-6">
                While {commodity.name.toLowerCase()} is not in our core product range, we can help you source it through our network. Contact us for a custom quote.
              </p>
              <a href="/quote" class="inline-flex items-center px-6 py-3 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-500 transition-colors text-sm">
                Get a Custom Quote
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>
          )}
        </div>
      </section>

      <!-- Other Commodities -->
      <section class="border-t border-white/5 py-10">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-lg font-bold text-white mb-4">Explore Other Commodities</h2>
          <div class="flex flex-wrap gap-2">
            {commodityIntelData.filter((c) => c.slug !== commodity.slug).map((c) => (
              <a href={`/intelligence/${c.slug}`} class="inline-flex items-center px-3 py-1.5 bg-white/5 border border-white/10 rounded-lg text-sm text-gray-400 hover:text-white hover:border-white/20 transition-colors">
                {c.name}
              </a>
            ))}
          </div>
          <div class="mt-4">
            <a href="/intelligence" class="text-sm text-emerald-400 hover:text-emerald-300 transition-colors">
              Back to full intelligence dashboard &rarr;
            </a>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="bg-[#060a12] border-t border-white/5 py-8">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" viewBox="0 0 32 32" fill="none"><path d="M16 8c0 0-4 3.5-4 8 0 3 1.8 5.5 4 5.5s4-2.5 4-5.5c0-4.5-4-8-4-8z" fill="currentColor"/></svg>
            <span class="text-sm font-bold text-white">Origin Direct Group</span>
          </div>
          <div class="flex items-center gap-6 text-xs text-gray-500">
            <a href="/privacy" class="hover:text-gray-300 transition-colors">Privacy</a>
            <a href="/terms" class="hover:text-gray-300 transition-colors">Terms</a>
            <span>&copy; 2026 Origin Direct Group</span>
          </div>
        </div>
      </div>
    </footer>

    <!-- Leaflet JS -->
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <!-- Map + UI scripts -->
    <script is:inline define:vars={{ regions: commodity.regions, centerLat, centerLon, regionRiskColors }}>
      document.addEventListener("DOMContentLoaded", function () {
        // ── Map ──
        var mapEl = document.getElementById("regions-map");
        if (!mapEl || typeof L === "undefined") return;

        var map = L.map(mapEl, {
          center: [centerLat, centerLon],
          zoom: 4,
          zoomControl: true,
          scrollWheelZoom: false,
          attributionControl: false,
        });

        L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png", {
          maxZoom: 19,
        }).addTo(map);

        L.control.attribution({ position: "bottomright", prefix: false }).addTo(map);

        var bounds = [];
        regions.forEach(function (r) {
          var color = regionRiskColors[r.risk] || "#10b981";
          var radius = r.production.includes("000,000") ? 18 :
                       r.production.includes("00,000") ? 14 :
                       r.production.includes("0,000") ? 10 : 8;

          var circle = L.circleMarker([r.lat, r.lon], {
            radius: radius,
            fillColor: color,
            color: color,
            weight: 1,
            opacity: 0.8,
            fillOpacity: 0.3,
          }).addTo(map);

          var riskLabel = r.risk === "high" ? "HIGH" : r.risk === "medium" ? "MEDIUM" : "LOW";
          circle.bindPopup(
            '<div style="font-family:Inter,sans-serif;min-width:200px;">' +
              '<div style="font-weight:700;font-size:14px;margin-bottom:4px;">' + r.name + '</div>' +
              '<div style="font-size:12px;color:#999;margin-bottom:8px;">' + r.country + '</div>' +
              '<div style="display:flex;gap:12px;margin-bottom:8px;">' +
                '<div><div style="font-size:10px;color:#666;text-transform:uppercase;">Production</div><div style="font-size:13px;font-weight:600;">' + r.production + '</div></div>' +
                '<div><div style="font-size:10px;color:#666;text-transform:uppercase;">Risk</div><div style="font-size:13px;font-weight:600;color:' + color + ';">' + riskLabel + '</div></div>' +
              '</div>' +
              '<div style="font-size:10px;color:#666;text-transform:uppercase;">Rainfall</div>' +
              '<div style="font-size:12px;margin-bottom:8px;">' + r.rainfall + '</div>' +
              '<div style="font-size:11px;color:#bbb;line-height:1.4;">' + r.detail + '</div>' +
            '</div>',
            { className: "dark-popup" }
          );

          bounds.push([r.lat, r.lon]);
        });

        if (bounds.length > 1) {
          map.fitBounds(bounds, { padding: [40, 40], maxZoom: 6 });
        }

        // ── Header dropdowns ──
        var prodBtn = document.getElementById("ci-products-btn");
        var prodMenu = document.getElementById("ci-products-menu");
        var prodChevron = document.getElementById("ci-products-chevron");
        if (prodBtn && prodMenu) {
          prodBtn.addEventListener("click", function () {
            var open = !prodMenu.classList.contains("invisible");
            if (open) {
              prodMenu.classList.add("opacity-0", "invisible", "pointer-events-none");
              prodChevron && prodChevron.classList.remove("rotate-180");
            } else {
              prodMenu.classList.remove("opacity-0", "invisible", "pointer-events-none");
              prodChevron && prodChevron.classList.add("rotate-180");
            }
          });
          document.addEventListener("click", function (e) {
            if (!document.getElementById("ci-products-dropdown").contains(e.target)) {
              prodMenu.classList.add("opacity-0", "invisible", "pointer-events-none");
              prodChevron && prodChevron.classList.remove("rotate-180");
            }
          });
        }

        // Mobile menu
        var mobileBtn = document.getElementById("ci-mobile-btn");
        var mobileMenu = document.getElementById("ci-mobile-menu");
        var menuOpen = document.getElementById("ci-menu-open");
        var menuClose = document.getElementById("ci-menu-close");
        if (mobileBtn && mobileMenu) {
          mobileBtn.addEventListener("click", function () {
            var hidden = mobileMenu.classList.contains("hidden");
            mobileMenu.classList.toggle("hidden");
            menuOpen && menuOpen.classList.toggle("hidden");
            menuClose && menuClose.classList.toggle("hidden");
          });
        }
      });
    </script>

    <!-- Popup styling -->
    <style is:inline>
      .dark-popup .leaflet-popup-content-wrapper {
        background: #141a2a;
        color: #e5e7eb;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
      }
      .dark-popup .leaflet-popup-tip {
        background: #141a2a;
        border: 1px solid rgba(255,255,255,0.1);
      }
      .dark-popup .leaflet-popup-close-button {
        color: #9ca3af;
      }
      .dark-popup .leaflet-popup-close-button:hover {
        color: #fff;
      }
      .leaflet-control-zoom a {
        background: #141a2a !important;
        color: #e5e7eb !important;
        border-color: rgba(255,255,255,0.1) !important;
      }
      .leaflet-control-zoom a:hover {
        background: #1e2740 !important;
      }
    </style>
  </body>
</html>
