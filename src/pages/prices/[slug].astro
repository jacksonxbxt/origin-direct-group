---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { commodityPrices, type CommodityPricing } from '../../data/prices';

export function getStaticPaths() {
  return commodityPrices.map((commodity) => ({
    params: { slug: commodity.slug },
    props: { commodity },
  }));
}

interface Props {
  commodity: CommodityPricing;
}

const { commodity } = Astro.props;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Prices", item: "https://origindirectgroup.com/prices" },
    { "@type": "ListItem", position: 3, name: commodity.name, item: `https://origindirectgroup.com/prices/${commodity.slug}` },
  ],
};

const pageTitle = `${commodity.name} Price Per Ton (2026) | Origin Direct Group`;
const pageDescription = `Indicative ${commodity.name.toLowerCase()} prices FOB ${commodity.originPort}. ${commodity.grades[0].priceRange} ${commodity.grades[0].unit} for ${commodity.grades[0].grade}. Updated ${commodity.lastUpdated}.`;

const priceDriverParagraphs = commodity.priceDrivers.split('\n\n');
---

<Layout
  title={pageTitle}
  description={pageDescription}
  structuredData={[breadcrumbSchema]}
>
  <!-- Hero -->
  <section class="relative py-16 sm:py-20 bg-gradient-to-br from-green-950 via-green-900 to-earth-900">
    <div class="absolute inset-0 bg-black/30"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-amber-400 text-sm font-semibold uppercase tracking-wider mb-3">Indicative Pricing</p>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white tracking-tight">
        {commodity.name} Prices
      </h1>
      <div class="w-16 h-1 bg-amber-500 mx-auto mt-5 mb-5"></div>
      <p class="text-base md:text-lg text-gray-200/90 max-w-2xl mx-auto">
        FOB {commodity.originPort} &middot; Updated {commodity.lastUpdated}
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <!-- Breadcrumbs -->
    <Breadcrumbs items={[
      { label: "Prices", href: "/prices" },
      { label: commodity.name },
    ]} />

    <div class="lg:grid lg:grid-cols-3 lg:gap-16">
      <!-- Main Content -->
      <div class="lg:col-span-2">

        <!-- Price Table -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-brand-900 mb-6">
            {commodity.name} Price Table ({commodity.currency} FOB)
          </h2>
          <div class="overflow-x-auto rounded-xl border border-gray-200">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-50 border-b border-gray-200">
                  <th class="text-left px-5 py-3.5 font-semibold text-gray-700">Grade</th>
                  <th class="text-left px-5 py-3.5 font-semibold text-gray-700">Price Range (FOB)</th>
                  <th class="text-left px-5 py-3.5 font-semibold text-gray-700">Unit</th>
                  <th class="text-left px-5 py-3.5 font-semibold text-gray-700 hidden sm:table-cell">Notes</th>
                </tr>
              </thead>
              <tbody>
                {commodity.grades.map((grade, i) => (
                  <tr class={`border-b border-gray-100 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}>
                    <td class="px-5 py-4 font-medium text-gray-900">{grade.grade}</td>
                    <td class="px-5 py-4 text-brand-700 font-semibold whitespace-nowrap">{grade.priceRange}</td>
                    <td class="px-5 py-4 text-gray-600">{grade.unit}</td>
                    <td class="px-5 py-4 text-gray-500 hidden sm:table-cell">{grade.notes || '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="mt-3 text-xs text-gray-400">
            All prices in {commodity.currency}, FOB {commodity.originPort}. Updated {commodity.lastUpdated}.
          </p>
        </section>

        <!-- Disclaimer -->
        <div class="mb-12 p-5 bg-amber-50 border border-amber-200 rounded-xl">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-amber-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-sm text-amber-800">
              <strong>Disclaimer:</strong> Prices are indicative and vary by volume, grade, season, and Incoterms. Contact us for a firm quote tailored to your specific requirements.
            </p>
          </div>
        </div>

        <!-- Price Comparison (if applicable) -->
        {commodity.comparisonNote && (
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-brand-900 mb-4">Price Comparison</h2>
            <div class="p-6 bg-brand-50 rounded-xl border border-brand-200">
              <p class="text-gray-700 leading-relaxed">{commodity.comparisonNote}</p>
            </div>
          </section>
        )}

        <!-- What Drives Prices -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-brand-900 mb-4">
            What Drives {commodity.name} Prices
          </h2>
          <div class="prose prose-gray max-w-none">
            {priceDriverParagraphs.map((paragraph) => (
              <p class="text-gray-600 leading-relaxed mb-4">{paragraph}</p>
            ))}
          </div>
        </section>

        <!-- Seasonal Pattern -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-brand-900 mb-4">
            Seasonal Pricing Pattern
          </h2>
          <div class="p-6 bg-gray-50 rounded-xl border border-gray-200">
            <p class="text-gray-600 leading-relaxed">{commodity.seasonalPattern}</p>
          </div>
        </section>

        <!-- Recent Trend -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-brand-900 mb-4">
            Recent Price Trend
          </h2>
          <p class="text-gray-600 leading-relaxed">{commodity.recentTrend}</p>
        </section>

        <!-- Link to product page -->
        <div class="mb-12">
          <a
            href={`/products/${commodity.productSlug}`}
            class="inline-flex items-center gap-2 text-brand-700 font-medium hover:text-brand-600 transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
            </svg>
            View {commodity.name} product details
          </a>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="sticky top-24">
          <!-- Quick Facts -->
          <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
            <h3 class="text-lg font-bold text-brand-900 mb-4">Quick Facts</h3>
            <dl class="space-y-3 text-sm">
              <div>
                <dt class="text-gray-500">Currency</dt>
                <dd class="font-medium text-gray-900">{commodity.currency}</dd>
              </div>
              <div>
                <dt class="text-gray-500">Origin Port</dt>
                <dd class="font-medium text-gray-900">{commodity.originPort}</dd>
              </div>
              <div>
                <dt class="text-gray-500">Grades Available</dt>
                <dd class="font-medium text-gray-900">{commodity.grades.length} grades</dd>
              </div>
              <div>
                <dt class="text-gray-500">Last Updated</dt>
                <dd class="font-medium text-gray-900">{commodity.lastUpdated}</dd>
              </div>
            </dl>
          </div>

          <!-- Quote Form -->
          <QuoteForm productName={commodity.name} />
        </div>
      </div>
    </div>
  </div>

  <!-- All Prices CTA -->
  <section class="py-12 bg-gray-50 border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gray-600 mb-4">Looking for prices on other commodities?</p>
      <a
        href="/prices"
        class="inline-flex items-center gap-2 px-6 py-3 bg-brand-700 text-white font-semibold rounded-lg hover:bg-brand-600 transition-colors shadow-sm"
      >
        View All Commodity Prices
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
