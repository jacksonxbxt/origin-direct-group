---
import Layout from '../../layouts/Layout.astro';

const resources = [
  {
    title: "HS Codes for African Commodities",
    description: "Complete reference table with HS codes, EU duty rates, and US duty rates for cocoa, shea butter, cashew nuts, sesame seeds, moringa, ginger, hibiscus, and charcoal.",
    href: "/resources/hs-codes",
    icon: "table",
    available: true,
  },
  {
    title: "Shipping & Incoterms Guide",
    description: "FOB, CIF, DDP explained. How ocean freight works from West Africa to Europe, the US, and Asia. Container sizes, transit times, and cost factors.",
    href: "#",
    icon: "ship",
    available: false,
  },
  {
    title: "Certification & Compliance",
    description: "Overview of phytosanitary certificates, EUR.1 certificates, certificates of origin, organic certifications, and food safety compliance for African imports.",
    href: "#",
    icon: "certificate",
    available: false,
  },
  {
    title: "Commodity Pricing Guide",
    description: "How commodity pricing works for West African exports. Seasonal trends, pricing benchmarks, and what drives price fluctuations for cocoa, shea, cashews, and more.",
    href: "#",
    icon: "chart",
    available: false,
  },
];
---

<Layout
  title="Resources for Commodity Buyers | Origin Direct"
  description="Guides, references, and tools for commodity importers. HS codes, shipping guides, certification overviews, and pricing information for West African commodities."
>

  <!-- Hero -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-950 via-green-900 to-amber-950"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6">
        Resources for Commodity Buyers
      </h1>
      <p class="text-lg md:text-xl text-green-100/90 max-w-2xl mx-auto leading-relaxed">
        Practical guides, reference tables, and tools to help you navigate commodity imports from West Africa and India.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Breadcrumb -->
  <nav class="max-w-7xl mx-auto px-6 py-4" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li><a href="/" class="hover:text-green-700 transition-colors">Home</a></li>
      <li><span class="mx-1">/</span></li>
      <li class="text-gray-900 font-medium">Resources</li>
    </ol>
  </nav>

  <!-- Resource Cards -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 lg:gap-10">
        {resources.map((resource) => (
          <div class={`relative rounded-2xl p-8 lg:p-10 border transition-all ${resource.available ? 'bg-white border-gray-200 shadow-sm hover:shadow-md hover:border-green-200' : 'bg-gray-50 border-gray-100'}`}>
            {!resource.available && (
              <span class="absolute top-6 right-6 px-3 py-1 bg-amber-100 text-amber-800 text-xs font-semibold rounded-full uppercase tracking-wider">
                Coming Soon
              </span>
            )}

            <!-- Icon -->
            <div class={`inline-flex items-center justify-center w-14 h-14 rounded-xl mb-6 ${resource.available ? 'bg-green-100 text-green-700' : 'bg-gray-200 text-gray-400'}`}>
              {resource.icon === "table" && (
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m-9.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 3.75h-7.5A1.125 1.125 0 0112 18.375m9.75-12.75c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125m19.5 0v1.5c0 .621-.504 1.125-1.125 1.125M2.25 5.625v1.5c0 .621.504 1.125 1.125 1.125m0 0h17.25m-17.25 0h7.5c.621 0 1.125.504 1.125 1.125M3.375 8.25c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125m17.25-3.75h-7.5c-.621 0-1.125.504-1.125 1.125m8.625-1.125c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125M12 10.875v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 10.875c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125M12 12v-1.5c0 .621-.504 1.125-1.125 1.125M12 12c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125m0 1.5v-1.5m0 0c0-.621.504-1.125 1.125-1.125m0 0h1.5c.621 0 1.125.504 1.125 1.125" />
                </svg>
              )}
              {resource.icon === "ship" && (
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.125-.504 1.125-1.125V14.25M2.25 14.25h19.5M2.25 14.25V8.625c0-.621.504-1.125 1.125-1.125h3.375M21.75 14.25V8.625c0-.621-.504-1.125-1.125-1.125h-3.375m-10.5 0V4.875c0-.621.504-1.125 1.125-1.125h8.25c.621 0 1.125.504 1.125 1.125V7.5m-10.5 0h10.5" />
                </svg>
              )}
              {resource.icon === "certificate" && (
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              )}
              {resource.icon === "chart" && (
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                </svg>
              )}
            </div>

            <h2 class={`text-xl font-bold mb-3 ${resource.available ? 'text-gray-900' : 'text-gray-500'}`}>
              {resource.title}
            </h2>
            <p class={`leading-relaxed mb-6 ${resource.available ? 'text-gray-600' : 'text-gray-400'}`}>
              {resource.description}
            </p>

            {resource.available ? (
              <a
                href={resource.href}
                class="inline-flex items-center gap-2 text-green-700 font-semibold hover:text-green-900 transition-colors"
              >
                View Resource
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            ) : (
              <span class="inline-flex items-center gap-2 text-gray-400 font-medium text-sm">
                Available soon
              </span>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28 bg-green-950">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Have a Question About Importing?</h2>
      <p class="text-lg text-green-200/80 max-w-xl mx-auto mb-8">
        Our team handles commodity imports from West Africa every day. Ask us anything about HS codes, documentation, shipping, or pricing.
      </p>
      <a
        href="/quote"
        class="inline-flex items-center gap-2 px-8 py-4 bg-amber-500 text-white font-semibold rounded-lg hover:bg-amber-600 transition-colors shadow-lg text-lg"
      >
        Get in Touch
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

</Layout>
