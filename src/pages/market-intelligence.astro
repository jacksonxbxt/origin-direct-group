---
import Layout from '../layouts/Layout.astro';
import QuoteForm from '../components/QuoteForm.astro';

const monitoringPoints = [
  { commodity: "Cocoa", regions: "Ghana (Western, Ashanti), Nigeria (Ondo, Cross River)", riskFactors: "Rainfall deficit, NDVI drop, black pod disease conditions" },
  { commodity: "Shea", regions: "Ghana (Upper East, Upper West, Northern), Nigeria (Niger, Kwara)", riskFactors: "Dry season severity, late rains, NDVI anomalies" },
  { commodity: "Cashew", regions: "Ghana (Brong-Ahafo, Northern), Nigeria (Kogi, Enugu)", riskFactors: "Flowering-period rainfall, humidity spikes, NDVI decline" },
  { commodity: "Sesame", regions: "Nigeria (Jigawa, Nasarawa, Benue)", riskFactors: "Planting-season rainfall, mid-season drought, soil moisture" },
  { commodity: "Hibiscus", regions: "Nigeria (Jigawa, Bauchi, Kano)", riskFactors: "Rainfall timing, post-harvest drying conditions" },
  { commodity: "Ginger", regions: "Nigeria (Kaduna, Nasarawa)", riskFactors: "Waterlogging, drought stress, NDVI trends" },
  { commodity: "Turmeric", regions: "India (Telangana, Tamil Nadu, Maharashtra)", riskFactors: "Monsoon patterns, ENSO phase, soil moisture" },
  { commodity: "Castor", regions: "India (Gujarat, Rajasthan)", riskFactors: "Monsoon rainfall, ENSO correlation, pest pressure indicators" },
];

const riskLevels = [
  { commodity: "Cocoa", region: "Ghana / Nigeria", status: "Elevated", statusColor: "bg-amber-100 text-amber-800", note: "Below-average rainfall in Western Region Q1 2026" },
  { commodity: "Shea Butter", region: "Ghana", status: "Normal", statusColor: "bg-green-100 text-green-800", note: "Vegetation indices within seasonal norms" },
  { commodity: "Cashew Nuts", region: "Ghana / Nigeria", status: "Normal", statusColor: "bg-green-100 text-green-800", note: "Good flowering-period conditions observed" },
  { commodity: "Sesame Seeds", region: "Nigeria", status: "Normal", statusColor: "bg-green-100 text-green-800", note: "Pre-season moisture levels adequate" },
  { commodity: "Ginger", region: "Nigeria", status: "Watch", statusColor: "bg-yellow-100 text-yellow-800", note: "Monitoring soil moisture in Kaduna region" },
  { commodity: "Turmeric", region: "India", status: "Normal", statusColor: "bg-green-100 text-green-800", note: "Post-monsoon yields tracking well" },
];
---

<Layout
  title="Market Intelligence - Supply Shortage Early Warning | Origin Direct"
  description="Satellite-powered crop monitoring and supply shortage early warning for cocoa, shea, cashew, sesame, and more. NASA data across 14 growing regions in Ghana, Nigeria, and India."
>

  <!-- Hero -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-950 via-green-900 to-amber-950"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(180,130,50,0.15),transparent_60%)]"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full mb-8">
        <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" />
        </svg>
        <span class="text-sm font-semibold text-amber-200 tracking-wide">Satellite-Powered Intelligence</span>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6">
        Never Get Caught by a<br />Supply Shortage Again
      </h1>
      <p class="text-lg md:text-xl text-green-100/90 max-w-2xl mx-auto leading-relaxed">
        Our proprietary monitoring system uses NASA satellite data to detect crop anomalies months before they impact prices. Get early warnings, not late surprises.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- How It Works -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">How It Works</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">From satellite to actionable intelligence in four layers</p>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full mt-4"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
        <!-- NASA POWER Data -->
        <div class="bg-brand-50 rounded-2xl p-8 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-green-100 text-green-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.92 17.92 0 01-8.716-2.247m0 0A8.966 8.966 0 013 12c0-1.528.38-2.968 1.05-4.228" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">NASA POWER Satellite Data</h3>
          <p class="text-gray-600 leading-relaxed">
            We pull daily precipitation, temperature, humidity, and solar radiation data from NASA's POWER (Prediction of Worldwide Energy Resources) API. This covers every growing region we monitor with granular, location-specific weather data going back decades.
          </p>
        </div>

        <!-- NDVI Monitoring -->
        <div class="bg-brand-50 rounded-2xl p-8 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-green-100 text-green-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">NDVI Vegetation Tracking</h3>
          <p class="text-gray-600 leading-relaxed">
            Normalized Difference Vegetation Index (NDVI) measures crop health from space. When vegetation in a cocoa-growing region drops below historical norms, it signals trouble for next season's harvest. We track NDVI across all 14 monitoring points.
          </p>
        </div>

        <!-- ENSO Tracking -->
        <div class="bg-brand-50 rounded-2xl p-8 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-amber-100 text-amber-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">ENSO Climate Pattern Tracking</h3>
          <p class="text-gray-600 leading-relaxed">
            El Nino and La Nina events have outsized impacts on West African and Indian agriculture. We monitor ENSO indices and correlate them with regional weather patterns to identify systemic risks before they manifest as supply disruptions.
          </p>
        </div>

        <!-- 14 Monitoring Points -->
        <div class="bg-brand-50 rounded-2xl p-8 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-amber-100 text-amber-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">14 Monitoring Points</h3>
          <p class="text-gray-600 leading-relaxed">
            Each monitoring point corresponds to a specific growing region for a specific commodity. From cocoa in Ghana's Western Region to castor in Gujarat, we cover the regions that matter to our clients' supply chains.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Monitor -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">What We Monitor</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Commodities, regions, and the risk factors we watch for each</p>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full mt-4"></div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <thead>
            <tr class="bg-brand-900 text-white">
              <th class="px-6 py-4 text-left text-sm font-semibold">Commodity</th>
              <th class="px-6 py-4 text-left text-sm font-semibold">Monitored Regions</th>
              <th class="px-6 py-4 text-left text-sm font-semibold">Key Risk Factors</th>
            </tr>
          </thead>
          <tbody>
            {monitoringPoints.map((point, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                <td class="px-6 py-4 text-sm font-semibold text-gray-900 whitespace-nowrap">{point.commodity}</td>
                <td class="px-6 py-4 text-sm text-gray-600">{point.regions}</td>
                <td class="px-6 py-4 text-sm text-gray-600">{point.riskFactors}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Historical Validation -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Historical Validation</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-8 lg:p-12">
        <div class="flex items-start gap-4 mb-6">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-amber-100 text-amber-700 rounded-xl flex-shrink-0">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">The 2023-24 Cocoa Crisis</h3>
            <p class="text-gray-700 leading-relaxed mb-4">
              During the 2023-24 cocoa crisis, rainfall anomalies in Ghana's Western Region were visible in our data 4 months before prices tripled. Buyers who acted on early signals saved 40-60% vs peak pricing.
            </p>
            <p class="text-gray-700 leading-relaxed mb-4">
              Cocoa futures went from $2,500/MT to over $10,000/MT. The warning signs were clear in satellite data: below-average rainfall during the critical pod development phase, declining NDVI across the cocoa belt, and a strong El Nino pattern disrupting normal West African weather.
            </p>
            <p class="text-gray-700 leading-relaxed">
              Buyers who secured contracts at $3,000-4,000/MT on early warning signals avoided the worst of the price spike. Those who waited paid 2-3x more for the same product.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Price Impact Methodology -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Price Impact Methodology</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">How we translate weather anomalies into actionable price forecasts</p>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full mt-4"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-20 h-20 bg-green-50 border-2 border-green-200 rounded-full mb-6">
            <span class="text-2xl font-bold text-green-700">01</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Detect Anomalies</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Compare current weather and NDVI data against 10+ year historical baselines for each region. Flag significant deviations from normal patterns.
          </p>
        </div>

        <div class="text-center">
          <div class="inline-flex items-center justify-center w-20 h-20 bg-green-50 border-2 border-green-200 rounded-full mb-6">
            <span class="text-2xl font-bold text-green-700">02</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Assess Yield Impact</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Cross-reference anomalies with crop calendars, growth stages, and historical yield data. A drought during flowering has very different effects than one during harvest.
          </p>
        </div>

        <div class="text-center">
          <div class="inline-flex items-center justify-center w-20 h-20 bg-green-50 border-2 border-green-200 rounded-full mb-6">
            <span class="text-2xl font-bold text-green-700">03</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Project Price Impact</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Model supply reduction scenarios against current global demand and inventory levels. Generate price range forecasts with confidence intervals.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Current Status -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Current Risk Overview</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Latest risk assessments across monitored commodities</p>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full mt-4"></div>
      </div>

      <div class="grid gap-4">
        {riskLevels.map((item) => (
          <div class="bg-white rounded-xl border border-gray-100 p-6 flex flex-col sm:flex-row sm:items-center gap-4 hover:shadow-sm transition-shadow">
            <div class="sm:w-40 flex-shrink-0">
              <h3 class="font-semibold text-gray-900">{item.commodity}</h3>
              <p class="text-sm text-gray-500">{item.region}</p>
            </div>
            <div class="flex-shrink-0">
              <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold ${item.statusColor}`}>
                {item.status}
              </span>
            </div>
            <p class="text-sm text-gray-600 flex-1">{item.note}</p>
          </div>
        ))}
      </div>

      <p class="mt-6 text-center text-sm text-gray-500">
        Last updated: March 2026. Detailed reports with full data available to active clients.
      </p>
    </div>
  </section>

  <!-- How to Access -->
  <section class="py-20 md:py-28 bg-brand-50">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">How to Access</h2>
      <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full mb-8"></div>

      <div class="bg-white rounded-2xl p-8 lg:p-12 border border-green-100 shadow-sm text-left">
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">Included for Active Clients</h3>
            <p class="text-gray-600 leading-relaxed mb-4">
              Market intelligence reports are available to all active Origin Direct Group clients at no additional cost. When you source through us, you automatically get access to:
            </p>
            <ul class="space-y-3 text-gray-600">
              <li class="flex items-start gap-2">
                <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
                <span>Monthly commodity risk summaries</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
                <span>Anomaly alerts for your sourced commodities</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
                <span>Price impact forecasts with buy/wait recommendations</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
                <span>Priority notification of emerging supply risks</span>
              </li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">Available on Request</h3>
            <p class="text-gray-600 leading-relaxed mb-4">
              Not yet a client? You can request a sample market intelligence report as part of your initial quote. We will include a current risk overview for your commodities of interest so you can see the value firsthand.
            </p>
            <p class="text-gray-600 leading-relaxed">
              Simply mention "market intelligence" in your quote request, and we will include a snapshot with your proposal.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA / Quote Section -->
  <section id="quote" class="py-20 md:py-28 bg-green-950">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Request a Market Intelligence Report</h2>
        <p class="text-lg text-green-200/80 max-w-xl mx-auto">
          Tell us what you source. We will send you a risk assessment and pricing outlook.
        </p>
      </div>
      <QuoteForm />
    </div>
  </section>

</Layout>
