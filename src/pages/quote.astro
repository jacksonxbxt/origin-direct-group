---
import Layout from '../layouts/Layout.astro';
import QuoteForm from '../components/QuoteForm.astro';

const whatsappNumber = "31612345678";
const whatsappMessage = encodeURIComponent("Hi, I'm interested in your commodities. Please send me more information.");
---

<Layout
  title="Request a Quote | Origin Direct Group"
  description="Get a competitive commodity quote within 2 hours. Shea butter, cocoa, cashew nuts, hookah charcoal, hibiscus, sesame, moringa, ginger - direct from West Africa & India."
>

  <!-- Hero -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-950 via-green-900 to-amber-950"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6">
        Request a Quote
      </h1>
      <p class="text-lg md:text-xl text-green-100/90 max-w-2xl mx-auto leading-relaxed">
        Tell us what you need and we'll get back to you within 2 hours with a competitive offer.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-gray-50 to-transparent"></div>
  </section>

  <!-- Quote Form Section -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-2xl mx-auto px-6">
      <QuoteForm />
    </div>

    <!-- Info Blocks -->
    <div class="max-w-4xl mx-auto px-6 mt-16">
      <div class="grid sm:grid-cols-3 gap-6">
        <!-- Response Time -->
        <div class="bg-white rounded-xl border border-gray-100 p-6 text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-green-100 text-green-700 rounded-xl mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Response Time</h3>
          <p class="text-sm text-gray-600">Under 2 hours</p>
        </div>

        <!-- Sample Orders -->
        <div class="bg-white rounded-xl border border-gray-100 p-6 text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-amber-100 text-amber-700 rounded-xl mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Sample Orders</h3>
          <p class="text-sm text-gray-600">Available for all products</p>
        </div>

        <!-- Payment Terms -->
        <div class="bg-white rounded-xl border border-gray-100 p-6 text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-green-100 text-green-700 rounded-xl mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Payment</h3>
          <p class="text-sm text-gray-600">LC, TT, CAD terms available</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Info -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">Prefer to Reach Out Directly?</h2>
        <div class="w-12 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid sm:grid-cols-3 gap-8 text-center">
        <!-- Email -->
        <div>
          <div class="inline-flex items-center justify-center w-12 h-12 bg-gray-100 text-gray-700 rounded-xl mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Email</h3>
          <a href="mailto:info@origindirectgroup.com" class="text-green-700 hover:text-green-600 text-sm transition-colors">
            info@origindirectgroup.com
          </a>
        </div>

        <!-- Phone -->
        <div>
          <div class="inline-flex items-center justify-center w-12 h-12 bg-gray-100 text-gray-700 rounded-xl mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Phone</h3>
          <a href="tel:+31612345678" class="text-green-700 hover:text-green-600 text-sm transition-colors">
            +31 6 1234 5678
          </a>
        </div>

        <!-- WhatsApp -->
        <div>
          <div class="inline-flex items-center justify-center w-12 h-12 bg-green-100 text-green-700 rounded-xl mb-4">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">WhatsApp</h3>
          <a
            href={`https://wa.me/${whatsappNumber}?text=${whatsappMessage}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-green-700 hover:text-green-600 text-sm transition-colors"
          >
            Chat with us instantly
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
