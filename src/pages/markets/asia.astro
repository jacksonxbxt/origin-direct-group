---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const products = [
  {
    name: "Raw Cashew Nuts (RCN)",
    description: "High-quality raw cashew nuts for India and Vietnam's massive processing industries. Consistent kernel outturn ratio (KOR), competitive pricing direct from Ghana and Nigeria.",
    markets: "India, Vietnam",
    highlight: "Bulk volumes",
  },
  {
    name: "Cocoa Beans",
    description: "Premium fermented cocoa beans for Japan's high-end chocolate makers and confectionery industry. Full traceability from farm to port.",
    markets: "Japan, South Korea, China",
    highlight: "Premium grade",
  },
  {
    name: "Sesame Seeds",
    description: "Natural and hulled sesame seeds for oil pressing, food manufacturing, and traditional Asian cuisine. High oil content, consistent quality.",
    markets: "China, Japan, South Korea",
    highlight: "High oil content",
  },
  {
    name: "Shea Butter",
    description: "Refined and unrefined shea butter for cosmetics manufacturing and food applications. Supplied to Asian beauty and personal care brands.",
    markets: "Japan, South Korea, China",
    highlight: "Cosmetic grade",
  },
];

const countries = [
  "China", "Japan", "South Korea", "India", "Vietnam", "Indonesia", "Thailand", "Malaysia",
  "Singapore", "Philippines", "Taiwan", "Hong Kong", "Australia", "New Zealand", "Bangladesh",
  "Sri Lanka", "Pakistan", "Myanmar", "Cambodia",
];

const ports = [
  { name: "Nhava Sheva", country: "India", transit: "20-24 days" },
  { name: "Ho Chi Minh City", country: "Vietnam", transit: "28-32 days" },
  { name: "Shanghai", country: "China", transit: "30-35 days" },
  { name: "Yokohama", country: "Japan", transit: "32-36 days" },
];
---

<Layout
  title="Commodities for Asian Buyers | Origin Direct"
  description="Raw cashew nuts for India and Vietnam, cocoa beans for Japan, sesame seeds for China. Letter of Credit terms, direct exports from West Africa."
>

  <!-- Hero -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-950 via-green-900 to-rose-950"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <p class="text-amber-400 font-semibold text-sm uppercase tracking-wider mb-4">Asia & Pacific Market</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6">
        Commodities for Asian & Pacific Buyers
      </h1>
      <p class="text-lg md:text-xl text-green-100/90 max-w-2xl mx-auto leading-relaxed">
        Serving {countries.length} countries across Asia and the Pacific region.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Countries We Serve -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">Countries We Serve in Asia & Pacific</h2>
        <p class="text-gray-600">Letter of Credit terms accepted. Bulk volumes for processing industries across the region.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-2">
        {countries.map((country) => (
          <span class="inline-flex items-center px-3 py-1.5 bg-white text-gray-700 text-sm font-medium rounded-full border border-gray-200">
            {country}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Supplying Asia's Processing Industries -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Supplying Asia's Processing Industries</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <p class="text-gray-700 leading-relaxed text-center max-w-3xl mx-auto mb-12">
        Asia's massive food processing and manufacturing industries require consistent, high-volume supplies of raw
        materials. We supply raw cashew nuts to India and Vietnam's processing plants, premium cocoa beans to
        Japanese chocolate makers, and sesame seeds to oil pressers across the region.
      </p>

      <div class="grid sm:grid-cols-3 gap-6">
        <div class="bg-green-50/50 rounded-xl border border-green-100 p-6 text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-green-100 text-green-700 rounded-xl mb-3">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Letter of Credit</h3>
          <p class="text-sm text-gray-600">We work with LC at sight and deferred LC &mdash; the standard payment terms for Asian trade</p>
        </div>

        <div class="bg-green-50/50 rounded-xl border border-green-100 p-6 text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-green-100 text-green-700 rounded-xl mb-3">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Bulk Volumes</h3>
          <p class="text-sm text-gray-600">Full container loads (FCL) and bulk shipments for processing plants</p>
        </div>

        <div class="bg-green-50/50 rounded-xl border border-green-100 p-6 text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-green-100 text-green-700 rounded-xl mb-3">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Quality Specs</h3>
          <p class="text-sm text-gray-600">We match your exact quality specifications &mdash; KOR, moisture, FFA, and more</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Products -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Key Products for Asia</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {products.map((product) => (
          <div class="bg-white rounded-2xl border border-gray-100 p-8 hover:shadow-lg transition-shadow">
            <div class="flex items-center gap-3 mb-3">
              <h3 class="text-xl font-bold text-gray-900">{product.name}</h3>
              <span class="inline-flex items-center px-2.5 py-0.5 bg-green-100 text-green-800 text-xs font-semibold rounded-full">
                {product.highlight}
              </span>
            </div>
            <p class="text-gray-600 leading-relaxed mb-4">{product.description}</p>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">
              Key Markets: <span class="text-gray-700 normal-case font-medium">{product.markets}</span>
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Transit Times -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Transit Times</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {ports.map((port) => (
          <div class="bg-gray-50 rounded-xl border border-gray-100 p-6 text-center">
            <h3 class="text-lg font-bold text-gray-900 mb-1">{port.name}</h3>
            <p class="text-sm text-gray-500 mb-3">{port.country}</p>
            <p class="text-2xl font-bold text-green-700">{port.transit}</p>
            <p class="text-xs text-gray-400 mt-1">from West Africa</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA / Quote -->
  <section class="py-20 md:py-28 bg-green-950">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Get a Quote for Asia</h2>
        <p class="text-lg text-green-200/80 max-w-xl mx-auto">
          Bulk raw materials, LC terms accepted, shipped direct from source.
        </p>
      </div>
      <QuoteForm />
    </div>
  </section>

</Layout>
