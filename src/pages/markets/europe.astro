---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const products = [
  {
    product: "Cocoa Beans",
    hsCode: "1801.00",
    regulations: "EUDR, Cadmium limits (EU 488/2014)",
    status: "EUDR compliant, cadmium tested",
  },
  {
    product: "Shea Butter",
    hsCode: "1515.90",
    regulations: "Novel Food (cosmetic exempt), REACH",
    status: "Full REACH compliance",
  },
  {
    product: "Cashew Nuts",
    hsCode: "0801.31 / 0801.32",
    regulations: "Phytosanitary, aflatoxin limits",
    status: "Lab tested, phyto certified",
  },
  {
    product: "Sesame Seeds",
    hsCode: "1207.40",
    regulations: "ETO limits, Salmonella testing",
    status: "ETO-free certified",
  },
  {
    product: "Moringa Powder",
    hsCode: "0712.90",
    regulations: "Novel Food Regulation (EU 2015/2283)",
    status: "Novel Food compliant",
  },
  {
    product: "Dried Hibiscus",
    hsCode: "0902.20",
    regulations: "Pesticide MRLs, phytosanitary",
    status: "Residue tested, certified",
  },
  {
    product: "Dried Ginger",
    hsCode: "0910.11",
    regulations: "Aflatoxin limits, pesticide MRLs",
    status: "Lab tested, compliant",
  },
  {
    product: "Hookah Charcoal",
    hsCode: "4402.90",
    regulations: "REACH, product safety",
    status: "REACH registered",
  },
];

const ports = [
  { name: "Rotterdam", country: "Netherlands", transitTema: "12-14 days", transitLagos: "14-16 days" },
  { name: "Hamburg", country: "Germany", transitTema: "14-16 days", transitLagos: "16-18 days" },
  { name: "Antwerp", country: "Belgium", transitTema: "12-14 days", transitLagos: "14-16 days" },
  { name: "Felixstowe", country: "UK", transitTema: "14-16 days", transitLagos: "16-18 days" },
];
---

<Layout
  title="Commodities for European Buyers | Origin Direct"
  description="EU-compliant commodity exports from West Africa and India. EUDR ready, cadmium tested, EUR.1 certificates. Cocoa, shea butter, sesame, cashews, moringa for European buyers."
>

  <!-- Hero -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-950 via-green-900 to-blue-950"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <p class="text-amber-400 font-semibold text-sm uppercase tracking-wider mb-4">Europe Market</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6">
        Commodities for European Buyers
      </h1>
      <p class="text-lg md:text-xl text-green-100/90 max-w-2xl mx-auto leading-relaxed">
        🇳🇱 🇩🇪 🇬🇧 🇫🇷 🇧🇪 🇮🇹 🇪🇸 🇵🇱
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Why European Buyers Choose Us -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Why European Buyers Choose Us</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-8 rounded-2xl bg-green-50/50 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-green-100 text-green-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3">EU Compliance Expertise</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            We understand the full landscape of EU import regulations &mdash; from EUDR to Novel Food to REACH. Your shipment arrives ready for customs.
          </p>
        </div>

        <div class="text-center p-8 rounded-2xl bg-green-50/50 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-green-100 text-green-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3">EUDR Ready</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Full geolocation data for cocoa and other EUDR-regulated commodities. We provide the due diligence data your compliance team needs.
          </p>
        </div>

        <div class="text-center p-8 rounded-2xl bg-green-50/50 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-amber-100 text-amber-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3">EUR.1 Certificates</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            We provide EUR.1 movement certificates for preferential tariff rates under EU trade agreements with originating countries.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Compliance & Documentation -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Compliance &amp; Documentation</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="bg-white rounded-2xl border border-gray-100 p-8 lg:p-10">
        <p class="text-gray-700 leading-relaxed mb-8">
          We provide all EU-required documentation with every shipment. Your customs broker will have everything they need for smooth clearance.
        </p>

        <div class="grid sm:grid-cols-2 gap-4">
          {[
            "EUDR geolocation data for regulated commodities",
            "Cadmium testing below EU limits (Reg. 488/2014)",
            "Phytosanitary certificates (NPPO issued)",
            "EUR.1 movement certificates for preferential tariffs",
            "Certificate of Analysis from accredited labs",
            "Certificate of Origin",
            "Bill of Lading / shipping documents",
            "Fumigation certificates where required",
          ].map((doc) => (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span class="text-gray-700 text-sm">{doc}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Key Products for Europe -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Key Products for Europe</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b-2 border-gray-200">
              <th class="text-left py-4 px-4 font-semibold text-gray-900">Product</th>
              <th class="text-left py-4 px-4 font-semibold text-gray-900">HS Code</th>
              <th class="text-left py-4 px-4 font-semibold text-gray-900">Applicable Regulations</th>
              <th class="text-left py-4 px-4 font-semibold text-gray-900">Our Compliance</th>
            </tr>
          </thead>
          <tbody>
            {products.map((row, i) => (
              <tr class={`border-b border-gray-100 ${i % 2 === 0 ? 'bg-gray-50/50' : ''}`}>
                <td class="py-3.5 px-4 font-medium text-gray-900">{row.product}</td>
                <td class="py-3.5 px-4 text-gray-600 font-mono text-xs">{row.hsCode}</td>
                <td class="py-3.5 px-4 text-gray-600">{row.regulations}</td>
                <td class="py-3.5 px-4">
                  <span class="inline-flex items-center gap-1.5 text-green-700 font-medium">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    {row.status}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Key Ports -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Key European Ports</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {ports.map((port) => (
          <div class="bg-white rounded-xl border border-gray-100 p-6 text-center">
            <h3 class="text-lg font-bold text-gray-900 mb-1">{port.name}</h3>
            <p class="text-sm text-gray-500 mb-4">{port.country}</p>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500">From Tema:</span>
                <span class="font-medium text-gray-900">{port.transitTema}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">From Lagos:</span>
                <span class="font-medium text-gray-900">{port.transitLagos}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA / Quote -->
  <section class="py-20 md:py-28 bg-green-950">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Get a Quote for Europe</h2>
        <p class="text-lg text-green-200/80 max-w-xl mx-auto">
          EU-compliant commodities, competitive pricing, delivered to your port.
        </p>
      </div>
      <QuoteForm />
    </div>
  </section>

</Layout>
