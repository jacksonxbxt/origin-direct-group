---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const markets = [
  {
    region: "Europe",
    slug: "europe",
    featured: ["Netherlands", "Germany", "UK", "France", "Belgium", "Italy", "Spain", "Portugal", "Poland", "Czech Republic", "Austria", "Switzerland", "Sweden", "Denmark"],
    moreCountries: ["Norway", "Finland", "Ireland", "Greece", "Romania", "Hungary", "Slovenia", "Croatia", "Slovakia", "Bulgaria", "Lithuania", "Latvia", "Estonia"],
    commodities: ["Cocoa", "Shea butter", "Sesame", "Cashews", "Moringa"],
    description: "Europe accounts for 40% of our exports. We understand EU compliance - EUDR, cadmium limits, Novel Food regulations, and phytosanitary requirements.",
  },
  {
    region: "Americas",
    slug: "americas",
    featured: ["USA", "Canada", "Mexico", "Brazil", "Argentina", "Colombia", "Chile", "Peru", "Ecuador", "Dominican Republic", "Jamaica", "Trinidad & Tobago"],
    moreCountries: ["Barbados", "Suriname", "Guyana", "Costa Rica", "Panama", "Guatemala", "Honduras", "Uruguay", "Paraguay", "Bolivia"],
    commodities: ["Hibiscus", "Cocoa", "Cashews", "Ginger", "Moringa"],
    description: "From hibiscus for Mexico's agua de jamaica to ginger for the Caribbean, we serve the Americas with competitive direct pricing.",
  },
  {
    region: "Middle East & Africa",
    slug: "middle-east",
    featured: ["UAE", "Saudi Arabia", "Qatar", "Kuwait", "Bahrain", "Oman", "Jordan", "Lebanon", "Turkey", "Israel", "Egypt", "South Africa"],
    moreCountries: ["Kenya", "Tanzania", "Morocco", "Tunisia", "Senegal", "Ivory Coast"],
    commodities: ["Hookah charcoal", "Sesame seeds", "Hibiscus (karkade)", "Shea butter"],
    description: "The Middle East & Africa is our fastest-growing market. We supply premium hookah charcoal, tahini-grade sesame, and cosmetic shea butter.",
  },
  {
    region: "Asia & Pacific",
    slug: "asia",
    featured: ["China", "Japan", "South Korea", "India", "Vietnam", "Indonesia", "Thailand", "Malaysia", "Singapore", "Philippines", "Taiwan", "Hong Kong"],
    moreCountries: ["Australia", "New Zealand", "Bangladesh", "Sri Lanka", "Pakistan", "Myanmar", "Cambodia"],
    commodities: ["Raw cashew nuts", "Cocoa beans", "Sesame seeds"],
    description: "We supply raw materials to Asia's massive processing industries - cashew kernels for Vietnam, cocoa for Japanese chocolate makers.",
  },
];
---

<Layout
  title="Markets We Serve | Origin Direct Group"
  description="Origin Direct Group ships commodities worldwide - Europe, Americas, Middle East, and Asia. Direct sourcing from West Africa and India with full compliance documentation."
>

  <!-- Hero -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-950 via-green-900 to-amber-950"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6">
        We Ship to 150+ Countries
      </h1>
      <p class="text-lg md:text-xl text-green-100/90 max-w-2xl mx-auto leading-relaxed">
        From West Africa and India to buyers on every continent. Wherever your business is, we deliver with full compliance documentation.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Market Cards -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="space-y-8">
        {markets.map((market) => (
          <a
            href={`/markets/${market.slug}`}
            class="group block bg-white rounded-2xl border border-gray-100 hover:border-green-200 hover:shadow-xl transition-all duration-300 overflow-hidden"
          >
            <div class="p-8 lg:p-10">
              <div class="flex flex-col gap-6">
                <!-- Region header -->
                <div>
                  <h2 class="text-2xl md:text-3xl font-bold text-gray-900 group-hover:text-green-700 transition-colors mb-3">
                    {market.region}
                  </h2>
                  <p class="text-gray-600 leading-relaxed max-w-3xl">
                    {market.description}
                  </p>
                </div>

                <!-- Countries as badges -->
                <div>
                  <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Countries We Serve</h4>
                  <div class="flex flex-wrap gap-2 mb-2">
                    {market.featured.map((country: string) => (
                      <span class="inline-flex items-center px-3 py-1.5 bg-gray-50 text-gray-700 text-sm font-medium rounded-full border border-gray-200">
                        {country}
                      </span>
                    ))}
                    <span class="inline-flex items-center px-3 py-1.5 bg-green-50 text-green-700 text-sm font-semibold rounded-full border border-green-200">
                      + {market.moreCountries.length} more
                    </span>
                  </div>
                </div>

                <!-- Commodities + CTA -->
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pt-2 border-t border-gray-100">
                  <div class="flex flex-wrap gap-2">
                    {market.commodities.map((commodity: string) => (
                      <span class="inline-flex items-center px-3 py-1 bg-green-50 text-green-800 text-sm font-medium rounded-full border border-green-100">
                        {commodity}
                      </span>
                    ))}
                  </div>
                  <div class="flex items-center gap-2 text-green-700 font-semibold text-sm group-hover:gap-3 transition-all flex-shrink-0">
                    View Details
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28 bg-green-950">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Shipping to Your Market?</h2>
        <p class="text-lg text-green-200/80 max-w-xl mx-auto">
          Tell us your destination and product requirements. We'll handle the rest.
        </p>
      </div>
      <QuoteForm />
    </div>
  </section>

</Layout>
