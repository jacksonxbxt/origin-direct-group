          .width(width)
          .height(height)
          .backgroundColor("rgba(0,0,0,0)")
          .globeImageUrl("https://unpkg.com/three-globe/example/img/earth-night.jpg")
          .atmosphereColor("#1a6b3c")
          .atmosphereAltitude(0.2)
          .pointsData(commodities.map(c => ({ lat: c.lat, lng: c.lng, size: c.ours ? 0.4 : 0.2, color: categoryColors[c.category].color, name: c.name, ours: c.ours })))
          .pointLat("lat")
          .pointLng("lng")
          .pointAltitude(d => d.ours ? 0.06 : 0.02)
          .pointRadius(d => d.size)
          .pointColor(d => d.color)
          .pointLabel(d => `<div style="background:rgba(0,0,0,0.8);padding:6px 10px;border-radius:6px;font-size:12px;color:white;border:1px solid rgba(255,255,255,0.1);">${d.name}${d.ours ? ' <span style="color:#fbbf24;font-weight:bold;">[We Supply]</span>' : ''}</div>`)
          .arcsData(tradeRoutes.map(r => ({
            startLat: r.from[0], startLng: r.from[1],
            endLat: r.to[0], endLng: r.to[1],
            color: categoryColors[r.category].color,
            label: r.label,
            category: r.category
          })))
          .arcStartLat("startLat")
          .arcStartLng("startLng")
          .arcEndLat("endLat")
          .arcEndLng("endLng")
          .arcColor(d => d.color)
          .arcAltitude(0.15)
          .arcStroke(0.4)
          .arcDashLength(0.5)
          .arcDashGap(0.3)
          .arcDashAnimateTime(3000)
          .arcLabel(d => `<div style="background:rgba(0,0,0,0.8);padding:6px 10px;border-radius:6px;font-size:11px;color:white;border:1px solid rgba(255,255,255,0.1);">${d.label}</div>`)
          (container);

        // Auto-rotate
        globe.controls().autoRotate = true;
        globe.controls().autoRotateSpeed = 0.4;
        globe.controls().enableZoom = true;

        // Set initial view to show Africa
        globe.pointOfView({ lat: 10, lng: 20, altitude: 2.5 }, 0);

        document.getElementById("globe-route-count").textContent = tradeRoutes.length + " active routes";

        // Resize observer
        const ro = new ResizeObserver(entries => {
          for (const entry of entries) {
            const w = entry.contentRect.width;
            globe.width(w);
          }
        });
        ro.observe(container);

        // Store globe reference for filtering
        window._globe = globe;
      }

      // ========================================
      // UPDATE GLOBE ARCS ON FILTER
      // ========================================
      function updateGlobeArcs() {
        if (!window._globe) return;
        const filteredRoutes = tradeRoutes.filter(r => {
          if (activeCategory !== "all" && r.category !== activeCategory) return false;
          if (searchTerm) {
            return r.label.toLowerCase().includes(searchTerm);
          }
          return true;
        });

        window._globe.arcsData(filteredRoutes.map(r => ({
          startLat: r.from[0], startLng: r.from[1],
          endLat: r.to[0], endLng: r.to[1],
          color: categoryColors[r.category].color,
          label: r.label,
          category: r.category
        })));

        document.getElementById("globe-route-count").textContent = filteredRoutes.length + " active routes";
      }

      // ========================================
      // EVENT LISTENERS
      // ========================================
      document.addEventListener("DOMContentLoaded", () => {
        renderCards();
        renderTable();

        // Wait a tick for container to have dimensions, then init globe
        setTimeout(initGlobe, 100);

        // Search
        const searchInput = document.getElementById("commodity-search");
        let searchTimeout;
        searchInput.addEventListener("input", (e) => {
          clearTimeout(searchTimeout);
          searchTimeout = setTimeout(() => {
            searchTerm = e.target.value.toLowerCase().trim();
            renderCards();
            renderTable();
            updateGlobeArcs();
          }, 150);
        });

        // Category filters
        document.querySelectorAll(".category-btn").forEach(btn => {
          btn.addEventListener("click", () => {
            document.querySelectorAll(".category-btn").forEach(b => b.classList.remove("active"));
            btn.classList.add("active");
            activeCategory = btn.dataset.category;
            renderCards();
            renderTable();
            updateGlobeArcs();
          });
        });

        // Table sorting
        document.querySelectorAll("#price-table th[data-sort]").forEach(th => {
          th.addEventListener("click", () => {
            const col = th.dataset.sort;
            if (sortCol === col) {
              sortDir = sortDir === "asc" ? "desc" : "asc";
            } else {
              sortCol = col;
              sortDir = "asc";
            }
            renderTable();
          });
        });

        // Header nav dropdown
        const dropdown = document.getElementById("intel-products-dropdown");
        const btn = document.getElementById("intel-products-btn");
        const menu = document.getElementById("intel-products-menu");
        const chevron = document.getElementById("intel-products-chevron");
        let ddTimeout;

        function showMenu() {
          if (ddTimeout) clearTimeout(ddTimeout);
          menu.classList.remove("opacity-0", "invisible", "pointer-events-none");
          menu.classList.add("opacity-100", "visible", "pointer-events-auto");
          chevron.classList.add("rotate-180");
        }
        function hideMenu() {
          ddTimeout = setTimeout(() => {
            menu.classList.add("opacity-0", "invisible", "pointer-events-none");
            menu.classList.remove("opacity-100", "visible", "pointer-events-auto");
            chevron.classList.remove("rotate-180");
          }, 150);
        }

        dropdown?.addEventListener("mouseenter", showMenu);
        dropdown?.addEventListener("mouseleave", hideMenu);

        // Mobile menu
        const mobileBtn = document.getElementById("intel-mobile-btn");
        const mobileMenu = document.getElementById("intel-mobile-menu");
        const openIcon = document.getElementById("intel-menu-open");
        const closeIcon = document.getElementById("intel-menu-close");

        mobileBtn?.addEventListener("click", () => {
          mobileMenu.classList.toggle("hidden");
          openIcon.classList.toggle("hidden");
          closeIcon.classList.toggle("hidden");
        });
      });
    </script>

    <style is:inline>
      /* Category button states */
      .category-btn {
        color: #9ca3af;
        border-color: rgba(255,255,255,0.1);
        background: transparent;
      }
      .category-btn:hover {
        color: #e5e7eb;
        border-color: rgba(255,255,255,0.2);
        background: rgba(255,255,255,0.03);
      }
      .category-btn.active {
        color: #34d399;
        border-color: rgba(52,211,153,0.4);
        background: rgba(52,211,153,0.1);
      }

      /* Scrollbar styling */
      #commodity-cards::-webkit-scrollbar {
        width: 4px;
      }
      #commodity-cards::-webkit-scrollbar-track {
        background: transparent;
      }
      #commodity-cards::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.1);
        border-radius: 4px;
      }
      #commodity-cards::-webkit-scrollbar-thumb:hover {
        background: rgba(255,255,255,0.2);
      }

      /* Hide scrollbar on filter strip */
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }
      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }

      /* Table row hover */
      #price-table-body tr {
        transition: background-color 0.15s;
      }

      /* Font mono for prices */
      .font-mono {
        font-family: "JetBrains Mono", ui-monospace, monospace;
      }

      /* Responsive globe */
      @media (max-width: 1023px) {
        #globe-container {
          height: 400px !important;
        }
      }

      @media (max-width: 639px) {
        #globe-container {
          height: 320px !important;
        }
      }

      /* Details/summary arrow removal */
      details > summary::-webkit-details-marker {
        display: none;
      }
      details > summary {
        list-style: none;
      }
    </style>
  </body>
</html>
