      function productionToRadius(prod) {
        // Parse production string to number
        var num = parseFloat(prod);
        if (prod.includes("M")) num = num * 1000;
        // Map to radius: bigger = bigger circle (min 6, max 22)
        if (num >= 1000) return 22;
        if (num >= 500) return 18;
        if (num >= 200) return 15;
        if (num >= 100) return 12;
        if (num >= 50) return 10;
        return 7;
      }

