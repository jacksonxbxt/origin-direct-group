---
import "../styles/global.css";

const siteUrl = "https://origindirectgroup.com";
const canonicalUrl = new URL("/intelligence", siteUrl).href;
const pageTitle = "LIVE Commodity Intelligence Dashboard - Global Supply Monitor | Origin Direct";
const pageDescription = "Free real-time commodity supply intelligence. Track cocoa, shea butter, cashew, sesame, coffee, palm oil, wheat and 20+ commodities worldwide. Satellite-powered shortage alerts.";

const products = [
  { name: "Shea Butter", slug: "shea-butter" },
  { name: "Cocoa", slug: "cocoa" },
  { name: "Cashew Nuts", slug: "cashew-nuts" },
  { name: "Hookah Charcoal", slug: "hookah-charcoal" },
  { name: "Hibiscus", slug: "hibiscus" },
  { name: "Sesame Seeds", slug: "sesame-seeds" },
  { name: "Moringa", slug: "moringa" },
  { name: "Ginger", slug: "ginger" },
];

const navLinks = [
  { name: "Prices", href: "/prices" },
  { name: "Markets", href: "/markets" },
  { name: "Guides", href: "/guides" },
  { name: "About", href: "/about" },
  { name: "Blog", href: "/blog" },
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Origin Direct Commodity Intelligence Dashboard",
  "url": canonicalUrl,
  "description": pageDescription,
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Origin Direct Group",
    "url": siteUrl
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What commodities are tracked on this dashboard?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We track over 30 commodities worldwide including cocoa, shea butter, cashew nuts, sesame seeds, coffee (Arabica and Robusta), palm oil, wheat, rice, sugar, vanilla, black pepper, cardamom, and many more. Our own products from West Africa and India are highlighted with supply risk indicators."
      }
    },
    {
      "@type": "Question",
      "name": "How is the supply risk calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Supply risk is calculated using NASA POWER satellite data including rainfall, NDVI vegetation indices, temperature anomalies, and ENSO climate patterns. We compare current conditions against 10+ year historical baselines for each growing region and assess the likelihood and severity of supply disruptions."
      }
    },
    {
      "@type": "Question",
      "name": "How often is the data updated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The dashboard data is updated daily at 06:00 UTC. Satellite weather data is refreshed from NASA POWER, and risk levels are recalculated based on the latest conditions in each monitored growing region."
      }
    },
    {
      "@type": "Question",
      "name": "Is this commodity intelligence dashboard free to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, this dashboard is completely free. No login, no paywall. We provide this as a service to the commodity trading community. When you need to source commodities directly from West Africa or India, Origin Direct Group can help."
      }
    }
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Origin Direct Group" />
    <meta name="theme-color" content="#0a0f1a" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={`${siteUrl}/og-intelligence.jpg`} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Origin Direct Group" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`${siteUrl}/og-intelligence.jpg`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </head>

  <body class="bg-[#0a0f1a] text-white font-sans min-h-screen">

    <!-- Dark Header -->
    <header id="intel-header" class="fixed top-0 left-0 right-0 z-50 bg-[#0a0f1a]/90 backdrop-blur-xl border-b border-white/5">
      <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2 group">
            <svg class="w-7 h-7 text-emerald-400 group-hover:text-emerald-300 transition-colors" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M16 2C16 2 8 8 8 16c0 5.5 3.6 10 8 10s8-4.5 8-10c0-8-8-14-8-14z" fill="currentColor" opacity="0.2"/>
              <path d="M16 4c0 0-6 5-6 12 0 4.4 2.7 8 6 8s6-3.6 6-8c0-7-6-12-6-12z" fill="currentColor" opacity="0.4"/>
              <path d="M16 8c0 0-4 3.5-4 8 0 3 1.8 5.5 4 5.5s4-2.5 4-5.5c0-4.5-4-8-4-8z" fill="currentColor"/>
            </svg>
            <span class="text-lg font-bold tracking-tight text-white">
              ORIGIN <span class="font-medium text-emerald-400">DIRECT</span>
            </span>
          </a>

          <nav class="hidden lg:flex items-center gap-6">
            <div class="relative" id="intel-products-dropdown">
              <button id="intel-products-btn" class="flex items-center gap-1 text-sm font-medium text-gray-300 hover:text-white transition-colors py-2">
                Products
                <svg class="w-4 h-4 transition-transform" id="intel-products-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div id="intel-products-menu" class="absolute top-full left-0 pt-2 opacity-0 invisible pointer-events-none transition-all duration-200">
                <div class="bg-[#141a2a] rounded-xl shadow-2xl border border-white/10 py-3 w-56">
                  {products.map((product) => (
                    <a href={`/products/${product.slug}`} class="block px-5 py-2.5 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                      {product.name}
                    </a>
                  ))}
                  <hr class="my-2 border-white/10" />
                  <a href="/products" class="block px-5 py-2.5 text-sm font-medium text-emerald-400 hover:bg-white/5 transition-colors">
                    View All Products
                  </a>
                </div>
              </div>
            </div>

            {navLinks.map((link) => (
              <a href={link.href} class="text-sm font-medium text-gray-300 hover:text-white transition-colors">
                {link.name}
              </a>
            ))}

            <a href="/quote" class="inline-flex items-center px-4 py-2 bg-emerald-600 text-white text-sm font-semibold rounded-lg hover:bg-emerald-500 transition-colors">
              Request Quote
            </a>
          </nav>

          <div class="hidden lg:flex items-center gap-3 ml-4">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="text-[10px] font-bold tracking-widest uppercase text-emerald-400">LIVE</span>
          </div>

          <button id="intel-mobile-btn" class="lg:hidden p-2 text-gray-300 hover:text-white transition-colors" aria-label="Toggle menu">
            <svg id="intel-menu-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="intel-menu-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="intel-mobile-menu" class="lg:hidden hidden bg-[#0a0f1a] border-t border-white/5">
        <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
          <a href="/products" class="block px-3 py-3 text-sm font-medium text-gray-300 hover:bg-white/5 rounded-lg">Products</a>
          {navLinks.map((link) => (
            <a href={link.href} class="block px-3 py-3 text-sm font-medium text-gray-300 hover:bg-white/5 rounded-lg">
              {link.name}
            </a>
          ))}
          <div class="pt-3">
            <a href="/quote" class="block w-full text-center px-5 py-3 bg-emerald-600 text-white text-sm font-semibold rounded-lg hover:bg-emerald-500 transition-colors">
              Request Quote
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Spacer -->
    <div class="h-16"></div>

    <main>
      <!-- Hero Bar -->
      <section class="bg-gradient-to-r from-[#0a0f1a] via-[#0f1a2e] to-[#0a0f1a] border-b border-white/5 py-5 sm:py-6">
        <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <div class="flex items-center gap-3 mb-2">
                <span class="relative flex h-2.5 w-2.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                </span>
                <span class="text-xs font-bold tracking-widest uppercase text-emerald-400">Live Intelligence</span>
                <span class="text-xs text-gray-500">Updated daily at 06:00 UTC</span>
              </div>
              <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-white tracking-tight">
                Global Commodity Intelligence
              </h1>
              <p class="text-sm sm:text-base text-gray-400 mt-1 max-w-2xl">
                Monitor growing regions, track supply risk, and spot disruptions before they hit prices.
              </p>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <div class="flex items-center gap-2 px-3 py-1.5 bg-red-500/10 border border-red-500/20 rounded-lg" id="high-risk-badge">
                <span class="w-2 h-2 rounded-full bg-red-500"></span>
                <span class="text-xs font-bold text-red-400" id="high-risk-count">0 HIGH RISK</span>
              </div>
              <div class="flex items-center gap-2 px-3 py-1.5 bg-amber-500/10 border border-amber-500/20 rounded-lg" id="medium-risk-badge">
                <span class="w-2 h-2 rounded-full bg-amber-500"></span>
                <span class="text-xs font-bold text-amber-400" id="medium-risk-count">0 ELEVATED</span>
              </div>
              <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 bg-blue-500/10 border border-blue-500/20 rounded-lg">
                <span class="text-xs font-bold text-blue-400">ENSO: Neutral</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Filter Bar (sticky) -->
      <section class="sticky top-16 z-40 bg-[#0d1320]/95 backdrop-blur-xl border-b border-white/5">
        <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-3">
          <div class="flex flex-col sm:flex-row gap-3">
            <!-- Search -->
            <div class="relative flex-1 max-w-sm">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <input
                type="text"
                id="commodity-search"
                placeholder="Search commodities or regions..."
                class="w-full pl-10 pr-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-white placeholder-gray-500 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/30 transition-colors"
              />
            </div>

            <!-- Commodity Filters -->
            <div class="flex items-center gap-2 overflow-x-auto pb-1 sm:pb-0 scrollbar-hide">
              <button data-commodity="all" class="commodity-btn active shrink-0 px-3 py-1.5 text-xs font-semibold rounded-full border transition-all duration-200">
                All
              </button>
              <button data-commodity="Cocoa" class="commodity-btn shrink-0 px-3 py-1.5 text-xs font-semibold rounded-full border transition-all duration-200">
                Cocoa
              </button>
              <button data-commodity="Shea Butter" class="commodity-btn shrink-0 px-3 py-1.5 text-xs font-semibold rounded-full border transition-all duration-200">
                Shea
              </button>
              <button data-commodity="Cashew" class="commodity-btn shrink-0 px-3 py-1.5 text-xs font-semibold rounded-full border transition-all duration-200">
                Cashew
              </button>
              <button data-commodity="Sesame" class="commodity-btn shrink-0 px-3 py-1.5 text-xs font-semibold rounded-full border transition-all duration-200">
                Sesame
              </button>
              <button data-commodity="Hibiscus" class="commodity-btn shrink-0 px-3 py-1.5 text-xs font-semibold rounded-full border transition-all duration-200">
                Hibiscus
              </button>
              <button data-commodity="Ginger" class="commodity-btn shrink-0 px-3 py-1.5 text-xs font-semibold rounded-full border transition-all duration-200">
                Ginger
              </button>
              <button data-commodity="Turmeric" class="commodity-btn shrink-0 px-3 py-1.5 text-xs font-semibold rounded-full border transition-all duration-200">
                Turmeric
              </button>
              <button data-commodity="Coffee" class="commodity-btn shrink-0 px-3 py-1.5 text-xs font-semibold rounded-full border transition-all duration-200">
                Coffee
              </button>
              <button data-commodity="Castor Oil" class="commodity-btn shrink-0 px-3 py-1.5 text-xs font-semibold rounded-full border transition-all duration-200">
                Castor
              </button>
              <button data-commodity="Palm Oil" class="commodity-btn shrink-0 px-3 py-1.5 text-xs font-semibold rounded-full border transition-all duration-200">
                Palm Oil
              </button>
              <button data-commodity="Olive Oil" class="commodity-btn shrink-0 px-3 py-1.5 text-xs font-semibold rounded-full border transition-all duration-200">
                Olive Oil
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- Leaflet Map -->
      <section class="border-b border-white/5">
        <div id="map-container" style="width:100%; height:60vh; min-height:500px; background:#060b16; position:relative;">
          <div id="leaflet-map" style="width:100%; height:100%; z-index:1;"></div>
          <!-- Map legend overlay -->
          <div class="absolute bottom-4 left-4 z-[1000] bg-black/70 backdrop-blur-md rounded-lg px-3 py-2.5 border border-white/10">
            <div class="text-[10px] uppercase tracking-widest text-gray-500 mb-1.5">Risk Level</div>
            <div class="flex items-center gap-3">
              <span class="flex items-center gap-1.5 text-[11px] text-gray-300">
                <span class="w-3 h-3 rounded-full bg-red-500 border border-red-400 opacity-70"></span> High
              </span>
              <span class="flex items-center gap-1.5 text-[11px] text-gray-300">
                <span class="w-3 h-3 rounded-full bg-amber-500 border border-amber-400 opacity-70"></span> Medium
              </span>
              <span class="flex items-center gap-1.5 text-[11px] text-gray-300">
                <span class="w-3 h-3 rounded-full bg-emerald-500 border border-emerald-400 opacity-70"></span> Low
              </span>
            </div>
          </div>
          <!-- Region count overlay -->
          <div class="absolute top-4 left-4 z-[1000] bg-black/70 backdrop-blur-md rounded-lg px-3 py-2 border border-white/10">
            <div class="text-[10px] uppercase tracking-widest text-gray-500 mb-0.5">Monitoring</div>
            <div class="text-sm font-semibold text-white" id="region-count">-- regions</div>
          </div>
        </div>
      </section>

      <!-- Commodity Summary Cards -->
      <section class="py-8 sm:py-10">
        <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl sm:text-2xl font-bold text-white">Commodity Overview</h2>
            <span class="text-xs text-gray-500" id="card-count">-- commodities</span>
          </div>
          <div id="commodity-cards" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            <!-- Cards injected by JS -->
          </div>
        </div>
      </section>

      <!-- Worldwide Price Table -->
      <section class="py-8 sm:py-12 border-t border-white/5">
        <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
            <div>
              <h2 class="text-xl sm:text-2xl font-bold text-white">Worldwide Price Table</h2>
              <p class="text-sm text-gray-500 mt-1">Click column headers to sort. Our products are highlighted.</p>
            </div>
            <div class="text-xs text-gray-600">Prices in USD. Indicative market rates, not live quotes.</div>
          </div>

          <div class="overflow-x-auto rounded-xl border border-white/5">
            <table class="w-full text-sm" id="price-table">
              <thead>
                <tr class="bg-[#111827] text-gray-400 text-xs uppercase tracking-wider">
                  <th class="px-4 py-3 text-left cursor-pointer hover:text-white transition-colors select-none" data-sort="name">
                    Commodity <span class="sort-arrow"></span>
                  </th>
                  <th class="px-4 py-3 text-left cursor-pointer hover:text-white transition-colors select-none" data-sort="category">
                    Category <span class="sort-arrow"></span>
                  </th>
                  <th class="px-4 py-3 text-right cursor-pointer hover:text-white transition-colors select-none" data-sort="price">
                    Price/MT <span class="sort-arrow"></span>
                  </th>
                  <th class="px-4 py-3 text-right cursor-pointer hover:text-white transition-colors select-none" data-sort="change">
                    30d Change <span class="sort-arrow"></span>
                  </th>
                  <th class="px-4 py-3 text-center cursor-pointer hover:text-white transition-colors select-none" data-sort="risk">
                    Risk <span class="sort-arrow"></span>
                  </th>
                  <th class="px-4 py-3 text-left cursor-pointer hover:text-white transition-colors select-none" data-sort="origin">
                    Origin <span class="sort-arrow"></span>
                  </th>
                  <th class="px-4 py-3 text-center">
                    <!-- actions -->
                  </th>
                </tr>
              </thead>
              <tbody id="price-table-body" class="divide-y divide-white/5">
                <!-- Rows injected by JS -->
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- Deep Dive Links -->
      <section class="py-8 border-t border-white/5">
        <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-lg font-bold text-white mb-4">Detailed Analysis Available</h2>
          <div class="flex flex-wrap gap-3">
            <a href="/intelligence/cocoa" class="inline-flex items-center gap-2 px-4 py-2 bg-white/[0.03] border border-white/10 rounded-lg text-sm text-gray-300 hover:text-white hover:border-emerald-500/30 hover:bg-emerald-500/5 transition-all">
              <span class="w-2 h-2 rounded-full bg-red-500"></span> Cocoa Deep Dive
            </a>
            <a href="/intelligence/shea-butter" class="inline-flex items-center gap-2 px-4 py-2 bg-white/[0.03] border border-white/10 rounded-lg text-sm text-gray-300 hover:text-white hover:border-emerald-500/30 hover:bg-emerald-500/5 transition-all">
              <span class="w-2 h-2 rounded-full bg-amber-500"></span> Shea Butter Deep Dive
            </a>
            <a href="/intelligence/cashew" class="inline-flex items-center gap-2 px-4 py-2 bg-white/[0.03] border border-white/10 rounded-lg text-sm text-gray-300 hover:text-white hover:border-emerald-500/30 hover:bg-emerald-500/5 transition-all">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span> Cashew Deep Dive
            </a>
            <a href="/intelligence/sesame" class="inline-flex items-center gap-2 px-4 py-2 bg-white/[0.03] border border-white/10 rounded-lg text-sm text-gray-300 hover:text-white hover:border-emerald-500/30 hover:bg-emerald-500/5 transition-all">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span> Sesame Deep Dive
            </a>
            <a href="/intelligence/coffee" class="inline-flex items-center gap-2 px-4 py-2 bg-white/[0.03] border border-white/10 rounded-lg text-sm text-gray-300 hover:text-white hover:border-emerald-500/30 hover:bg-emerald-500/5 transition-all">
              <span class="w-2 h-2 rounded-full bg-amber-500"></span> Coffee Deep Dive
            </a>
            <a href="/intelligence/turmeric" class="inline-flex items-center gap-2 px-4 py-2 bg-white/[0.03] border border-white/10 rounded-lg text-sm text-gray-300 hover:text-white hover:border-emerald-500/30 hover:bg-emerald-500/5 transition-all">
              <span class="w-2 h-2 rounded-full bg-red-500"></span> Turmeric Deep Dive
            </a>
            <a href="/intelligence/olive-oil" class="inline-flex items-center gap-2 px-4 py-2 bg-white/[0.03] border border-white/10 rounded-lg text-sm text-gray-300 hover:text-white hover:border-emerald-500/30 hover:bg-emerald-500/5 transition-all">
              <span class="w-2 h-2 rounded-full bg-red-500"></span> Olive Oil Deep Dive
            </a>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="py-12 sm:py-16 bg-gradient-to-r from-emerald-900/30 via-emerald-800/20 to-emerald-900/30 border-y border-emerald-500/10">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">Need to source these commodities?</h2>
          <p class="text-gray-400 mb-6 max-w-xl mx-auto">
            Origin Direct supplies cocoa, shea butter, cashew, sesame, spices, and more - direct from producers in Ghana, Nigeria, and India. Cut out the middlemen and save 15-40%.
          </p>
