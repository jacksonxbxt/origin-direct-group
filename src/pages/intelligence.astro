      // ========================================
      function getFilteredRegions() {
        return growingRegions.filter(function(r) {
          var matchCommodity = activeCommodity === "all" || r.commodity === activeCommodity;
          var matchSearch = !searchTerm ||
            r.name.toLowerCase().indexOf(searchTerm) !== -1 ||
            r.commodity.toLowerCase().indexOf(searchTerm) !== -1 ||
            r.detail.toLowerCase().indexOf(searchTerm) !== -1;
          return matchCommodity && matchSearch;
        });
      }

      function getFilteredCommodities() {
        return commodities.filter(function(c) {
          var matchCommodity = activeCommodity === "all" || c.commodity === activeCommodity;
          var matchSearch = !searchTerm ||
            c.name.toLowerCase().indexOf(searchTerm) !== -1 ||
            c.origin.toLowerCase().indexOf(searchTerm) !== -1 ||
            c.commodity.toLowerCase().indexOf(searchTerm) !== -1;
          return matchCommodity && matchSearch;
        });
      }

      function getSorted(list) {
        var arr = list.slice();
        arr.sort(function(a, b) {
          var va, vb;
          switch (sortCol) {
            case "name": va = a.name; vb = b.name; break;
            case "category": va = a.category; vb = b.category; break;
            case "price": va = a.price; vb = b.price; break;
            case "change": va = a.change; vb = b.change; break;
            case "risk": va = riskOrder[a.risk]; vb = riskOrder[b.risk]; break;
            case "origin": va = a.origin; vb = b.origin; break;
            default: va = a.name; vb = b.name;
          }
          if (typeof va === "string") {
            return sortDir === "asc" ? va.localeCompare(vb) : vb.localeCompare(va);
          }
          return sortDir === "asc" ? va - vb : vb - va;
        });
        return arr;
      }

      // ========================================
      // RENDER MAP MARKERS
      // ========================================
      function renderMapMarkers() {
        // Clear existing markers
        mapMarkers.forEach(function(m) { map.removeLayer(m); });
        mapMarkers = [];

        var filtered = getFilteredRegions();

        filtered.forEach(function(r) {
          var rc = riskColors[r.risk];
          var radius = productionToRadius(r.production);

          var circle = L.circleMarker([r.lat, r.lon], {
            radius: radius,
            fillColor: rc.fill,
            color: rc.border,
            weight: 2,
            opacity: 0.9,
            fillOpacity: 0.35,
          }).addTo(map);

          var supplyLink = r.ours && r.slug
            ? '<div style="margin-top:8px;"><a href="/products/' + r.slug + '" style="display:inline-block;padding:4px 12px;background:#059669;color:white;border-radius:4px;text-decoration:none;font-size:11px;font-weight:600;">We supply this - Request Quote</a></div>'
            : '';

          var riskBadgeColor = r.risk === "high" ? "#ef4444" : (r.risk === "medium" ? "#f59e0b" : "#10b981");

          circle.bindPopup(
            '<div style="font-family:Inter,sans-serif;min-width:220px;">' +
              '<div style="font-size:14px;font-weight:700;color:#111;margin-bottom:4px;">' + r.name + '</div>' +
              '<div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;">' +
                '<span style="font-size:11px;font-weight:600;color:#666;">' + r.commodity + '</span>' +
                '<span style="display:inline-block;padding:1px 6px;border-radius:9px;font-size:10px;font-weight:700;color:white;background:' + riskBadgeColor + ';">' + r.risk.toUpperCase() + ' RISK</span>' +
              '</div>' +
              '<div style="font-size:12px;color:#444;line-height:1.5;">' +
                '<div><strong>Production:</strong> ' + r.production + '</div>' +
                '<div><strong>Rainfall anomaly:</strong> ' + r.rainfall + '</div>' +
                '<div style="margin-top:4px;">' + r.detail + '</div>' +
              '</div>' +
              supplyLink +
            '</div>',
            { maxWidth: 280, className: "dark-popup" }
          );

          mapMarkers.push(circle);
        });

        // Update region count
        document.getElementById("region-count").textContent = filtered.length + " regions";

        // Update risk badges
        var highCount = growingRegions.filter(function(r) { return r.risk === "high"; }).length;
        var medCount = growingRegions.filter(function(r) { return r.risk === "medium"; }).length;
        document.getElementById("high-risk-count").textContent = highCount + " HIGH RISK";
        document.getElementById("medium-risk-count").textContent = medCount + " ELEVATED";

        // Auto-zoom if filtering to specific commodity
        if (activeCommodity !== "all" && filtered.length > 0) {
          var bounds = L.latLngBounds(filtered.map(function(r) { return [r.lat, r.lon]; }));
          map.fitBounds(bounds, { padding: [50, 50], maxZoom: 6 });
        } else if (activeCommodity === "all") {
          map.setView([15, 30], 3);
        }
      }

      // ========================================
      // SPARKLINE SVG GENERATOR
      // ========================================
      function sparkline(change) {
        var pts = 20;
        var seed = Math.abs(change * 137) % 100;
        var vals = [];
        var v = 50;
        for (var i = 0; i < pts; i++) {
          v += (change / pts) + Math.sin(seed + i * 0.7) * 2 + (Math.cos(seed * i * 0.3) * 1.5);
          v = Math.max(5, Math.min(95, v));
          vals.push(v);
        }
        var minV = Math.min.apply(null, vals);
        var maxV = Math.max.apply(null, vals);
        var range = maxV - minV || 1;
        var normalized = vals.map(function(v) { return 28 - ((v - minV) / range) * 28; });
        var points = normalized.map(function(y, i) { return ((i / (pts - 1)) * 72) + "," + y; }).join(" ");
        var color = change >= 0 ? "#34d399" : "#f87171";
        return '<svg width="72" height="28" viewBox="0 0 72 28" class="inline-block"><polyline fill="none" stroke="' + color + '" stroke-width="1.5" points="' + points + '"/></svg>';
      }

      // ========================================
      // BUILD COMMODITY CARD SUMMARIES
      // ========================================
      function getCommoditySummaries() {
        // Group regions by commodity
        var grouped = {};
        growingRegions.forEach(function(r) {
          if (!grouped[r.commodity]) grouped[r.commodity] = [];
          grouped[r.commodity].push(r);
        });

        // Build summary for each commodity that has regions
        var summaries = [];
        var seen = {};

        // Also pull price data from commodities array
        commodities.forEach(function(c) {
          var key = c.commodity;
          if (seen[key]) return;
          seen[key] = true;

          var regions = grouped[key] || [];
          var stressedRegions = regions.filter(function(r) { return r.risk === "high" || r.risk === "medium"; });

          summaries.push({
            commodity: key,
            name: c.name,
            price: c.price,
            unit: c.unit,
            change: c.change,
            risk: c.risk,
            ours: c.ours,
            slug: c.slug,
            category: c.category,
            totalRegions: regions.length,
            stressedRegions: stressedRegions.length,
            regions: regions,
          });
        });

        return summaries;
      }

      // ========================================
      // RENDER COMMODITY CARDS
      // ========================================
      function renderCards() {
        var container = document.getElementById("commodity-cards");
        var summaries = getCommoditySummaries();

        // Filter
        var filtered = summaries.filter(function(s) {
          var matchCommodity = activeCommodity === "all" || s.commodity === activeCommodity;
          var matchSearch = !searchTerm ||
            s.name.toLowerCase().indexOf(searchTerm) !== -1 ||
            s.commodity.toLowerCase().indexOf(searchTerm) !== -1;
          return matchCommodity && matchSearch;
        });

        // Sort: ours first, then by risk
        filtered.sort(function(a, b) {
          if (a.ours !== b.ours) return a.ours ? -1 : 1;
          return riskOrder[a.risk] - riskOrder[b.risk];
        });

        document.getElementById("card-count").textContent = filtered.length + " commodities";

        container.innerHTML = filtered.map(function(s) {
          var cat = categoryColors[s.category];
          var risk = riskConfig[s.risk];
          var changeSign = s.change >= 0 ? "+" : "";
          var changeColor = s.change >= 0 ? "text-emerald-400" : "text-red-400";
          var arrow = s.change >= 0
            ? '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 15l7-7 7 7"/></svg>'
            : '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>';

          var oursTag = s.ours
            ? '<span class="inline-flex items-center gap-1 px-1.5 py-0.5 bg-amber-500/20 text-amber-400 text-[10px] font-bold rounded border border-amber-500/30">WE SUPPLY</span>'
            : '';

          var goldBorder = s.ours ? "border-l-2 border-l-amber-500/60" : "";

          var regionSummary = s.totalRegions > 0
            ? '<div class="text-[11px] text-gray-500 mt-2">' +
                '<span class="text-gray-300 font-medium">' + s.totalRegions + ' region' + (s.totalRegions !== 1 ? 's' : '') + ' monitored</span>' +
                (s.stressedRegions > 0
                  ? ' &middot; <span class="text-amber-400 font-medium">' + s.stressedRegions + ' showing stress</span>'
                  : ' &middot; <span class="text-emerald-400">All normal</span>') +
              '</div>'
            : '';

          var quoteBtn = s.ours && s.slug
            ? '<a href="/products/' + s.slug + '" class="inline-flex items-center gap-1 px-3 py-1.5 bg-emerald-600/80 text-white text-xs font-semibold rounded hover:bg-emerald-500 transition-colors mt-3">Request Quote</a>'
            : '';

          return '<div class="commodity-card bg-white/[0.03] hover:bg-white/[0.06] rounded-xl p-4 border border-white/5 ' + goldBorder + ' transition-all duration-200">' +
            '<div class="flex items-start justify-between mb-2">' +
              '<div class="flex-1 min-w-0">' +
                '<div class="flex items-center gap-2 mb-1">' +
                  '<span class="text-sm font-semibold text-white">' + s.name + '</span>' +
                  oursTag +
                '</div>' +
                '<div class="flex items-center gap-2">' +
                  '<span class="text-[10px] px-1.5 py-0.5 rounded-full font-medium" style="background:' + cat.bg + ';color:' + cat.color + ';border:1px solid ' + cat.border + '">' + categoryLabels[s.category] + '</span>' +
                '</div>' +
              '</div>' +
              '<span class="px-2 py-0.5 text-[10px] font-bold rounded-full border ' + risk.class + '">' + risk.label + '</span>' +
            '</div>' +
            '<div class="flex items-end justify-between">' +
              '<div>' +
                '<div class="text-lg font-bold text-white font-mono">$' + s.price.toLocaleString() + '<span class="text-xs text-gray-500 font-sans">/' + s.unit + '</span></div>' +
                '<div class="flex items-center gap-1 ' + changeColor + '">' +
                  arrow +
                  '<span class="text-xs font-semibold">' + changeSign + s.change + '%</span>' +
                  '<span class="text-[10px] text-gray-500">30d</span>' +
                '</div>' +
              '</div>' +
              '<div>' + sparkline(s.change) + '</div>' +
            '</div>' +
            regionSummary +
            quoteBtn +
          '</div>';
        }).join("");
      }

      // ========================================
      // RENDER PRICE TABLE
      // ========================================
      function renderTable() {
        var tbody = document.getElementById("price-table-body");
        var filtered = getFilteredCommodities();
        var sorted = getSorted(filtered);

        tbody.innerHTML = sorted.map(function(c) {
          var cat = categoryColors[c.category];
          var risk = riskConfig[c.risk];
          var changeSign = c.change >= 0 ? "+" : "";
          var changeColor = c.change >= 0 ? "text-emerald-400" : "text-red-400";
          var arrow = c.change >= 0 ? "&#9650;" : "&#9660;";
          var rowBorder = c.ours ? "border-l-2 border-l-amber-500/60" : "";
          var oursTag = c.ours
            ? '<span class="inline-flex items-center gap-1 ml-2 px-1.5 py-0.5 bg-amber-500/20 text-amber-400 text-[10px] font-bold rounded border border-amber-500/30">WE SUPPLY</span>'
            : '';
          var quoteBtn = c.ours
            ? '<a href="' + (c.slug ? '/products/' + c.slug : '/quote') + '" class="inline-flex items-center px-3 py-1 bg-emerald-600/80 text-white text-xs font-semibold rounded hover:bg-emerald-500 transition-colors">Quote</a>'
            : '';

          return '<tr class="' + rowBorder + ' hover:bg-white/[0.03] transition-colors">' +
            '<td class="px-4 py-3 font-medium text-white whitespace-nowrap">' + c.name + oursTag + '</td>' +
            '<td class="px-4 py-3"><span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:' + cat.bg + ';color:' + cat.color + ';border:1px solid ' + cat.border + '">' + categoryLabels[c.category] + '</span></td>' +
            '<td class="px-4 py-3 text-right font-mono font-medium text-white">$' + c.price.toLocaleString() + '</td>' +
            '<td class="px-4 py-3 text-right"><span class="' + changeColor + ' font-semibold"><span class="text-xs">' + arrow + '</span> ' + changeSign + c.change + '%</span></td>' +
            '<td class="px-4 py-3 text-center"><span class="px-2 py-0.5 text-[10px] font-bold rounded-full border ' + risk.class + '">' + risk.label + '</span></td>' +
            '<td class="px-4 py-3 text-gray-400 text-xs">' + c.origin + '</td>' +
            '<td class="px-4 py-3 text-center">' + quoteBtn + '</td>' +
          '</tr>';
        }).join("");

        // Update sort arrows
        document.querySelectorAll("#price-table th[data-sort]").forEach(function(th) {
          var arrow = th.querySelector(".sort-arrow");
          if (th.dataset.sort === sortCol) {
            arrow.textContent = sortDir === "asc" ? " \u25B2" : " \u25BC";
            th.classList.add("text-white");
          } else {
            arrow.textContent = "";
            th.classList.remove("text-white");
          }
        });
      }

      // ========================================
      // RENDER ALL
      // ========================================
      function renderAll() {
        renderMapMarkers();
        renderCards();
        renderTable();
      }

      // ========================================
      // EVENT LISTENERS
      // ========================================
      document.addEventListener("DOMContentLoaded", function() {
        initMap();
        renderCards();
        renderTable();

        // Search
        var searchInput = document.getElementById("commodity-search");
        var searchTimeout;
        searchInput.addEventListener("input", function(e) {
          clearTimeout(searchTimeout);
          searchTimeout = setTimeout(function() {
            searchTerm = e.target.value.toLowerCase().trim();
            renderAll();
          }, 150);
        });

        // Commodity filters
        document.querySelectorAll(".commodity-btn").forEach(function(btn) {
          btn.addEventListener("click", function() {
            document.querySelectorAll(".commodity-btn").forEach(function(b) { b.classList.remove("active"); });
            btn.classList.add("active");
            activeCommodity = btn.dataset.commodity;
            renderAll();
          });
        });

        // Table sorting
        document.querySelectorAll("#price-table th[data-sort]").forEach(function(th) {
          th.addEventListener("click", function() {
            var col = th.dataset.sort;
            if (sortCol === col) {
              sortDir = sortDir === "asc" ? "desc" : "asc";
            } else {
              sortCol = col;
              sortDir = "asc";
            }
            renderTable();
          });
        });

        // Header nav dropdown
        var dropdown = document.getElementById("intel-products-dropdown");
        var menu = document.getElementById("intel-products-menu");
        var chevron = document.getElementById("intel-products-chevron");
        var ddTimeout;

        function showMenu() {
          if (ddTimeout) clearTimeout(ddTimeout);
          menu.classList.remove("opacity-0", "invisible", "pointer-events-none");
          menu.classList.add("opacity-100", "visible", "pointer-events-auto");
          chevron.classList.add("rotate-180");
        }
        function hideMenu() {
          ddTimeout = setTimeout(function() {
            menu.classList.add("opacity-0", "invisible", "pointer-events-none");
            menu.classList.remove("opacity-100", "visible", "pointer-events-auto");
            chevron.classList.remove("rotate-180");
          }, 150);
        }

        if (dropdown) {
          dropdown.addEventListener("mouseenter", showMenu);
          dropdown.addEventListener("mouseleave", hideMenu);
        }

        // Mobile menu
        var mobileBtn = document.getElementById("intel-mobile-btn");
        var mobileMenu = document.getElementById("intel-mobile-menu");
        var openIcon = document.getElementById("intel-menu-open");
        var closeIcon = document.getElementById("intel-menu-close");

        if (mobileBtn) {
          mobileBtn.addEventListener("click", function() {
            mobileMenu.classList.toggle("hidden");
            openIcon.classList.toggle("hidden");
            closeIcon.classList.toggle("hidden");
          });
        }
      });
    </script>

    <style is:inline>
      /* Commodity filter button states */
      .commodity-btn {
        color: #9ca3af;
        border-color: rgba(255,255,255,0.1);
        background: transparent;
      }
      .commodity-btn:hover {
        color: #e5e7eb;
        border-color: rgba(255,255,255,0.2);
        background: rgba(255,255,255,0.03);
      }
      .commodity-btn.active {
        color: #34d399;
        border-color: rgba(52,211,153,0.4);
        background: rgba(52,211,153,0.1);
      }

      /* Leaflet overrides for dark theme */
      .leaflet-container {
        background: #060b16 !important;
        font-family: "Inter", sans-serif;
      }
      .leaflet-control-zoom a {
        background: #141a2a !important;
        color: #9ca3af !important;
        border-color: rgba(255,255,255,0.1) !important;
      }
      .leaflet-control-zoom a:hover {
        background: #1f2937 !important;
        color: white !important;
      }
      .leaflet-popup-content-wrapper {
        background: white;
        border-radius: 10px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.4);
      }
      .leaflet-popup-tip {
        background: white;
      }

      /* Scrollbar styling */
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }
      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }

      /* Table row hover */
      #price-table-body tr {
        transition: background-color 0.15s;
      }

      /* Font mono for prices */
      .font-mono {
        font-family: "JetBrains Mono", ui-monospace, monospace;
      }

      /* Details/summary arrow removal */
      details > summary::-webkit-details-marker {
        display: none;
      }
      details > summary {
        list-style: none;
      }
    </style>
  </body>
</html>
