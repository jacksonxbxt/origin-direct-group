---
import Layout from '../../layouts/Layout.astro';
import TrustBar from '../../components/TrustBar.astro';
import ProductCard from '../../components/ProductCard.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const siteUrl = "https://origindirectgroup.com";

const products = [
  {
    name: "Beurre de Karite",
    slug: "fr/produits/beurre-de-karite",
    origin: "Ghana \u{1F1EC}\u{1F1ED}",
    description: "Grades non raffine, raffine et biologique pour les industries cosmetiques et alimentaires",
    grades: "Grade A Non Raffine | Raffine | Certifie Bio",
  },
  {
    name: "Cacao",
    slug: "fr/produits/cacao",
    origin: "Ghana \u{1F1EC}\u{1F1ED} / Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Feves, beurre, poudre et grues de cacao, directement de la premiere region productrice mondiale",
    grades: "Feves Fermentees | Beurre Naturel | Poudre Alcalinisee",
  },
  {
    name: "Noix de Cajou",
    slug: "fr/produits/noix-de-cajou",
    origin: "Ghana \u{1F1EC}\u{1F1ED} / Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Noix de cajou brutes et amandes transformees dans tous les grades standards",
    grades: "RCN | W180 | W240 | W320 | W450",
  },
  {
    name: "Charbon Chicha",
    slug: "fr/produits/charbon-chicha",
    origin: "Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Briquettes de charbon de bois dur et de coque de noix de coco pour le marche du narguilé",
    grades: "Cube 25mm | Plat | Doigt | Formes Sur Mesure",
  },
  {
    name: "Hibiscus Seche",
    slug: "fr/produits/hibiscus",
    origin: "Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Fleurs d'hibiscus sechees (Roselle) pour boissons, melanges de the et colorants alimentaires",
    grades: "Fleurs Entieres | Coupe et Tamisee | Poudre",
  },
  {
    name: "Graines de Sesame",
    slug: "fr/produits/graines-de-sesame",
    origin: "Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Graines de sesame blanches et brunes pour la production de tahini et la transformation alimentaire",
    grades: "Blanc Decortique | Naturel | Noir | Bio",
  },
  {
    name: "Poudre de Moringa",
    slug: "fr/produits/moringa",
    origin: "Ghana \u{1F1EC}\u{1F1ED} / Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Poudre de feuilles de moringa certifiee biologique pour les marches des aliments sante et supplements",
    grades: "Conventionnel | Bio | Grade Pharmaceutique",
  },
  {
    name: "Gingembre Seche",
    slug: "fr/produits/gingembre",
    origin: "Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Gingembre seche fendu et entier avec une teneur elevee en oleoresine et gingerol",
    grades: "Seche Fendu | Seche Entier | Poudre | Bio",
  },
];

const steps = [
  {
    number: "01",
    title: "Dites-nous ce dont vous avez besoin",
    description: "Soumettez une demande de devis avec votre produit, quantite et destination. Nous planifions depuis la source.",
  },
  {
    number: "02",
    title: "Nous sourcons a la ferme",
    description: "Nos equipes sur le terrain visitent les producteurs, inspectent la qualite a l'origine, negocient les prix et securisent le meilleur produit directement de la source.",
  },
  {
    number: "03",
    title: "Nous gerons la paperasse et le fret",
    description: "Tests de laboratoire, certificats phytosanitaires, documents d'exportation, supervision du chargement des conteneurs et reservation du fret maritime - tout est gere par nous.",
  },
  {
    number: "04",
    title: "Livre a votre porte",
    description: "Suivez votre expedition en temps reel. Nous coordonnons la documentation douaniere et la livraison jusqu'a votre entrepot.",
  },
];

const markets = [
  {
    region: "Europe",
    slug: "fr/marches/europe",
    featured: ["France", "Belgique", "Pays-Bas", "Allemagne", "Royaume-Uni", "Italie", "Espagne", "Portugal", "Pologne", "Republique Tcheque"],
    moreCount: 17,
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.92 17.92 0 01-8.716-2.247m0 0A8.966 8.966 0 013 12c0-1.528.38-2.968 1.05-4.228" /></svg>`,
  },
  {
    region: "Ameriques",
    slug: "fr/marches/ameriques",
    featured: ["USA", "Canada", "Mexique", "Bresil", "Argentine", "Colombie", "Chili", "Jamaique", "Trinite-et-Tobago", "Costa Rica"],
    moreCount: 12,
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.92 17.92 0 01-8.716-2.247m0 0A8.966 8.966 0 013 12c0-1.528.38-2.968 1.05-4.228" /></svg>`,
  },
  {
    region: "Afrique et Moyen-Orient",
    slug: "fr/marches/afrique-moyen-orient",
    featured: ["EAU", "Arabie Saoudite", "Qatar", "Koweit", "Turquie", "Afrique du Sud", "Kenya", "Egypte", "Maroc", "Bahrein"],
    moreCount: 8,
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>`,
  },
];
---

<Layout
  title="Origin Direct Group | Matieres Premieres Direct d'Afrique de l'Ouest et d'Inde"
  description="Approvisionnement direct en matieres premieres depuis le Ghana, le Nigeria et l'Inde. Beurre de karite, cacao, noix de cajou, charbon chicha, hibiscus, sesame, moringa et gingembre. Prix competitifs, qualite garantie."
  lang="fr"
  hreflangs={[
    { lang: "en", href: `${siteUrl}/` },
    { lang: "fr", href: `${siteUrl}/fr/` },
  ]}
>

  <!-- Hero Section -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-950 via-green-900 to-amber-950"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(180,130,50,0.15),transparent_60%)]"></div>
    <div class="absolute inset-0 bg-black/30"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white tracking-tight leading-tight mb-6 animate-fade-in">
        Matieres Premieres<br />Direct de la Source
      </h1>
      <p class="text-lg md:text-xl text-gray-200 max-w-2xl mx-auto mb-10 leading-relaxed">
        Nous connectons les acheteurs mondiaux avec des fournisseurs verifies en Afrique de l'Ouest et en Inde.
        Sans intermediaires. Sans surcharge. Tracabilite complete.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <a
          href="#quote"
          class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-green-950 font-semibold rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-amber-500/25 text-lg"
        >
          Demander un Devis
        </a>
        <a
          href="#products"
          class="inline-flex items-center px-8 py-4 border-2 border-white/80 hover:border-white text-white font-semibold rounded-lg transition-all duration-200 hover:bg-white/10 text-lg"
        >
          Voir les Produits
        </a>
      </div>

      <div class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full mb-4">
        <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" />
        </svg>
        <span class="text-sm font-semibold text-amber-200 tracking-wide">De la Terre a Votre Porte - Nous Gerons Tout</span>
      </div>

      <p class="text-sm text-gray-300/80 tracking-wide uppercase">
        Des acheteurs dans plus de 150 pays nous font confiance
      </p>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Trust Bar -->
  <TrustBar />

  <!-- Pourquoi Origin Direct -->
  <section class="py-24 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Pourquoi les Acheteurs Nous Choisissent</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        <div class="text-center p-8 rounded-2xl hover:bg-green-50/50 transition-colors duration-300">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 text-green-700 rounded-2xl mb-6">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Direct de la Source</h3>
          <p class="text-gray-600 leading-relaxed">
            Nos equipes au Ghana, au Nigeria et en Inde travaillent directement avec les producteurs.
            Pas d'intermediaires europeens ou asiatiques qui gonflent vos couts.
          </p>
        </div>

        <div class="text-center p-8 rounded-2xl hover:bg-green-50/50 transition-colors duration-300">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 text-green-700 rounded-2xl mb-6">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Controle Qualite Complet</h3>
          <p class="text-gray-600 leading-relaxed">
            Chaque expedition est inspectee, testee et documentee. Rapports de laboratoire,
            certificats d'analyse et certificats phytosanitaires inclus.
          </p>
        </div>

        <div class="text-center p-8 rounded-2xl hover:bg-green-50/50 transition-colors duration-300">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 text-green-700 rounded-2xl mb-6">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.92 17.92 0 01-8.716-2.247m0 0A8.966 8.966 0 013 12c0-1.528.38-2.968 1.05-4.228" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Service de la Terre a Votre Porte</h3>
          <p class="text-gray-600 leading-relaxed">
            Nous gerons chaque maillon de la chaine : approvisionnement a la ferme, controle qualite a l'origine,
            documents d'exportation, fret maritime et livraison a votre entrepot. FOB, CIF ou DDP.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Grille Produits -->
  <section id="products" class="py-24 md:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Nos Produits</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Approvisionnes directement aupres de producteurs verifies en Afrique de l'Ouest et en Inde
        </p>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full mt-4"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map((product) => (
          <ProductCard
            name={product.name}
            slug={product.slug}
            origin={product.origin}
            description={product.description}
            grades={product.grades}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Comment ca marche -->
  <section class="py-24 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Comment ca Fonctionne</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-2">De la terre a votre porte en quatre etapes simples</p>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="relative">
        <div class="hidden md:block absolute top-12 left-[12.5%] right-[12.5%] h-0.5 border-t-2 border-dashed border-green-200"></div>

        <div class="grid md:grid-cols-4 gap-8 md:gap-6">
          {steps.map((step) => (
            <div class="relative text-center">
              <div class="inline-flex items-center justify-center w-24 h-24 bg-green-50 border-2 border-green-200 rounded-full mb-6 relative z-10 bg-white">
                <span class="text-2xl font-bold text-green-700">{step.number}</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{step.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>

        <div class="md:hidden absolute top-0 bottom-0 left-1/2 -translate-x-1/2 w-0.5 border-l-2 border-dashed border-green-200 -z-10"></div>
      </div>
    </div>
  </section>

  <!-- Marches -->
  <section class="py-24 md:py-28 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Marches que Nous Servons</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>
      <p class="text-center text-lg text-gray-600 mb-12 max-w-2xl mx-auto">
        Nous livrons dans <span class="font-semibold text-green-700">plus de 150 pays</span> a travers le monde. Ou que soit votre entreprise, nous livrons.
      </p>

      <div class="grid sm:grid-cols-2 gap-6">
        {markets.map((market) => (
          <a
            href={`/${market.slug}`}
            class="group bg-white rounded-2xl p-8 border border-gray-100 hover:border-green-200 hover:shadow-lg transition-all duration-300"
          >
            <div class="flex items-center gap-3 mb-4">
              <div class="text-green-700" set:html={market.icon} />
              <h3 class="text-xl font-bold text-gray-900 group-hover:text-green-700 transition-colors">
                {market.region}
              </h3>
            </div>
            <div class="flex flex-wrap gap-2 mb-3">
              {market.featured.map((country: string) => (
                <span class="inline-flex items-center px-2.5 py-1 bg-gray-50 text-gray-700 text-xs font-medium rounded-full border border-gray-200">
                  {country}
                </span>
              ))}
            </div>
            <p class="text-sm text-green-700 font-medium">
              + {market.moreCount} autres pays &rarr;
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA / Devis -->
  <section id="quote" class="py-24 md:py-28 bg-green-950">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Pret a Sourcer Directement ?</h2>
        <p class="text-lg text-green-200/80 max-w-xl mx-auto">
          Recevez un devis competitif en moins de 2 heures. Notre equipe est prete a vous aider.
        </p>
      </div>

      <QuoteForm />
    </div>
  </section>

</Layout>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.8s ease-out both;
  }
</style>
