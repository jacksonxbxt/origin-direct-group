---
import Layout from '../../../layouts/Layout.astro';
import QuoteForm from '../../../components/QuoteForm.astro';

const siteUrl = "https://origindirectgroup.com";

const countries = [
  "France", "Belgique", "Pays-Bas", "Allemagne", "Royaume-Uni", "Italie", "Espagne", "Portugal",
  "Pologne", "Republique Tcheque", "Autriche", "Suisse", "Suede", "Danemark", "Norvege", "Finlande",
  "Irlande", "Grece", "Roumanie", "Hongrie", "Slovenie", "Croatie", "Slovaquie", "Bulgarie",
  "Lituanie", "Lettonie", "Estonie",
];

const products = [
  { product: "Feves de Cacao", hsCode: "1801.00", regulations: "EUDR, Limites de cadmium (UE 488/2014)", status: "Conforme EUDR, cadmium teste" },
  { product: "Beurre de Karite", hsCode: "1515.90", regulations: "Novel Food (exempt cosmetique), REACH", status: "Pleine conformite REACH" },
  { product: "Noix de Cajou", hsCode: "0801.31 / 0801.32", regulations: "Phytosanitaire, limites aflatoxines", status: "Teste en labo, certifie phyto" },
  { product: "Graines de Sesame", hsCode: "1207.40", regulations: "Limites OEt, test Salmonella", status: "Certifie sans OEt" },
  { product: "Poudre de Moringa", hsCode: "0712.90", regulations: "Reglement Novel Food (UE 2015/2283)", status: "Conforme Novel Food" },
  { product: "Hibiscus Seche", hsCode: "0902.20", regulations: "LMR pesticides, phytosanitaire", status: "Teste residus, certifie" },
  { product: "Gingembre Seche", hsCode: "0910.11", regulations: "Limites aflatoxines, LMR pesticides", status: "Teste en labo, conforme" },
  { product: "Charbon Chicha", hsCode: "4402.90", regulations: "REACH, securite produit", status: "Enregistre REACH" },
];

const ports = [
  { name: "Rotterdam", country: "Pays-Bas", transitTema: "12-14 jours", transitLagos: "14-16 jours" },
  { name: "Hambourg", country: "Allemagne", transitTema: "14-16 jours", transitLagos: "16-18 jours" },
  { name: "Anvers", country: "Belgique", transitTema: "12-14 jours", transitLagos: "14-16 jours" },
  { name: "Le Havre", country: "France", transitTema: "13-15 jours", transitLagos: "15-17 jours" },
];
---

<Layout
  title="Matieres Premieres pour Acheteurs Europeens | Origin Direct"
  description="Exportations de matieres premieres conformes UE depuis l'Afrique de l'Ouest et l'Inde. Conforme EUDR, cadmium teste, certificats EUR.1. Cacao, karite, sesame, cajou, moringa."
  lang="fr"
  hreflangs={[
    { lang: "en", href: `${siteUrl}/markets/europe` },
    { lang: "fr", href: `${siteUrl}/fr/marches/europe` },
  ]}
>
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-950 via-green-900 to-blue-950"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <p class="text-amber-400 font-semibold text-sm uppercase tracking-wider mb-4">Marche Europeen</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6">Matieres Premieres pour Acheteurs Europeens</h1>
      <p class="text-lg md:text-xl text-green-100/90 max-w-2xl mx-auto leading-relaxed">
        Nous desservons {countries.length} pays a travers le continent avec toute la documentation de conformite UE.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">Pays Desservis en Europe</h2>
        <p class="text-gray-600">Nous livrons a tous les grands marches europeens. Documentation complete pour les destinations UE et hors UE.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-2">
        {countries.map((country) => (
          <span class="inline-flex items-center px-3 py-1.5 bg-white text-gray-700 text-sm font-medium rounded-full border border-gray-200">{country}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Pourquoi les Acheteurs Europeens Nous Choisissent</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-8 rounded-2xl bg-green-50/50 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-green-100 text-green-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3">Expertise Conformite UE</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Nous maitrisons toute la reglementation d'importation UE : EUDR, Novel Food, REACH. Votre expedition arrive prete pour le dedouanement.</p>
        </div>
        <div class="text-center p-8 rounded-2xl bg-green-50/50 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-green-100 text-green-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" /></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3">Conforme EUDR</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Donnees de geolocalisation completes pour le cacao et autres matieres reglementees EUDR. Nous fournissons les donnees de diligence raisonnable pour votre equipe conformite.</p>
        </div>
        <div class="text-center p-8 rounded-2xl bg-green-50/50 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-amber-100 text-amber-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3">Certificats EUR.1</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Nous fournissons les certificats de circulation EUR.1 pour les taux tarifaires preferentiels dans le cadre des accords commerciaux UE.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Produits Cles pour l'Europe</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b-2 border-gray-200">
              <th class="text-left py-4 px-4 font-semibold text-gray-900">Produit</th>
              <th class="text-left py-4 px-4 font-semibold text-gray-900">Code SH</th>
              <th class="text-left py-4 px-4 font-semibold text-gray-900">Reglementations</th>
              <th class="text-left py-4 px-4 font-semibold text-gray-900">Notre Conformite</th>
            </tr>
          </thead>
          <tbody>
            {products.map((row, i) => (
              <tr class={`border-b border-gray-100 ${i % 2 === 0 ? 'bg-gray-50/50' : ''}`}>
                <td class="py-3.5 px-4 font-medium text-gray-900">{row.product}</td>
                <td class="py-3.5 px-4 text-gray-600 font-mono text-xs">{row.hsCode}</td>
                <td class="py-3.5 px-4 text-gray-600">{row.regulations}</td>
                <td class="py-3.5 px-4">
                  <span class="inline-flex items-center gap-1.5 text-green-700 font-medium">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    {row.status}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Principaux Ports Europeens</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {ports.map((port) => (
          <div class="bg-white rounded-xl border border-gray-100 p-6 text-center">
            <h3 class="text-lg font-bold text-gray-900 mb-1">{port.name}</h3>
            <p class="text-sm text-gray-500 mb-4">{port.country}</p>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-gray-500">Depuis Tema :</span><span class="font-medium text-gray-900">{port.transitTema}</span></div>
              <div class="flex justify-between"><span class="text-gray-500">Depuis Lagos :</span><span class="font-medium text-gray-900">{port.transitLagos}</span></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-green-950">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Obtenir un Devis pour l'Europe</h2>
        <p class="text-lg text-green-200/80 max-w-xl mx-auto">Matieres premieres conformes UE, prix competitifs, livrees a votre port.</p>
      </div>
      <QuoteForm />
    </div>
  </section>
</Layout>
