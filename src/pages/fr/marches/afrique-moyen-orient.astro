---
import Layout from '../../../layouts/Layout.astro';
import QuoteForm from '../../../components/QuoteForm.astro';

const siteUrl = "https://origindirectgroup.com";

const products = [
  { name: "Charbon Chicha", description: "Briquettes de charbon de bois dur et coque de noix de coco premium. Cubes, plats, doigts et formes sur mesure. Faible teneur en cendres, longue combustion, sans additifs.", highlight: "Plus grande opportunite" },
  { name: "Graines de Sesame", description: "Graines de sesame blanc decortique grade tahini. Purete 99,95%+, faible AGL, ideales pour la production de tahini et halva.", highlight: "Grade tahini" },
  { name: "Hibiscus Seche", description: "Fleurs d'hibiscus sechees premium pour le karkade, la boisson traditionnelle du Moyen-Orient. Couleur rouge profond, acidite elevee, excellent gout.", highlight: "Qualite karkade" },
  { name: "Beurre de Karite", description: "Beurre de karite raffine et non raffine pour la fabrication de cosmetiques. Haute teneur oleique, texture lisse, ideal pour les formulations de soins.", highlight: "Grade cosmetique" },
];

const countries = [
  "EAU", "Arabie Saoudite", "Qatar", "Koweit", "Bahrein", "Oman", "Jordanie", "Liban", "Turquie",
  "Israel", "Egypte", "Afrique du Sud", "Kenya", "Tanzanie", "Maroc", "Tunisie", "Senegal", "Cote d'Ivoire",
];

const ports = [
  { name: "Jebel Ali", country: "EAU", transit: "18-22 jours" },
  { name: "Koweit City", country: "Koweit", transit: "20-24 jours" },
  { name: "Port Hamad", country: "Qatar", transit: "20-24 jours" },
  { name: "Djeddah", country: "Arabie Saoudite", transit: "16-20 jours" },
];
---

<Layout
  title="Matieres Premieres pour l'Afrique et le Moyen-Orient | Origin Direct"
  description="Charbon chicha premium, sesame grade tahini, karkade hibiscus et beurre de karite cosmetique pour les acheteurs du Moyen-Orient et d'Afrique. Certifie halal."
  lang="fr"
  hreflangs={[
    { lang: "en", href: `${siteUrl}/markets/middle-east` },
    { lang: "fr", href: `${siteUrl}/fr/marches/afrique-moyen-orient` },
  ]}
>
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-950 via-green-900 to-amber-900"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <p class="text-amber-400 font-semibold text-sm uppercase tracking-wider mb-4">Marche Afrique et Moyen-Orient</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6">Matieres Premieres pour l'Afrique et le Moyen-Orient</h1>
      <p class="text-lg md:text-xl text-green-100/90 max-w-2xl mx-auto leading-relaxed">
        Nous desservons {countries.length} pays avec du charbon chicha premium, du sesame grade tahini et des cosmetiques naturels.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">Pays Desservis</h2>
        <p class="text-gray-600">Documentation conforme halal et aux exigences reglementaires locales pour chaque destination.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-2">
        {countries.map((country) => (
          <span class="inline-flex items-center px-3 py-1.5 bg-white text-gray-700 text-sm font-medium rounded-full border border-gray-200">{country}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Produits Cles pour cette Region</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>
      <div class="space-y-6">
        {products.map((product) => (
          <div class="bg-white rounded-2xl border border-gray-100 p-8 hover:shadow-lg transition-shadow">
            <div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-8">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-3">
                  <h3 class="text-xl font-bold text-gray-900">{product.name}</h3>
                  <span class="inline-flex items-center px-2.5 py-0.5 bg-green-100 text-green-800 text-xs font-semibold rounded-full">{product.highlight}</span>
                </div>
                <p class="text-gray-600 leading-relaxed">{product.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Temps de Transit</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {ports.map((port) => (
          <div class="bg-gray-50 rounded-xl border border-gray-100 p-6 text-center">
            <h3 class="text-lg font-bold text-gray-900 mb-1">{port.name}</h3>
            <p class="text-sm text-gray-500 mb-3">{port.country}</p>
            <p class="text-2xl font-bold text-green-700">{port.transit}</p>
            <p class="text-xs text-gray-400 mt-1">depuis l'Afrique de l'Ouest</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-green-950">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Obtenir un Devis</h2>
        <p class="text-lg text-green-200/80 max-w-xl mx-auto">Matieres premieres certifiees halal, prix competitifs, livrees a votre port.</p>
      </div>
      <QuoteForm />
    </div>
  </section>
</Layout>
