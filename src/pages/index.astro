---
import Layout from '../layouts/Layout.astro';
import TrustBar from '../components/TrustBar.astro';
import ProductCard from '../components/ProductCard.astro';
import QuoteForm from '../components/QuoteForm.astro';

const products = [
  {
    name: "Shea Butter",
    slug: "shea-butter",
    origin: "Ghana \u{1F1EC}\u{1F1ED}",
    description: "Unrefined, refined, and organic grades for cosmetics and food industries",
    grades: "Grade A Unrefined | Refined | Organic Certified",
  },
  {
    name: "Cocoa Products",
    slug: "cocoa",
    origin: "Ghana \u{1F1EC}\u{1F1ED} / Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Cocoa beans, butter, powder, and nibs \u2014 direct from the world's top producing region",
    grades: "Fermented Beans | Natural Butter | Alkalized Powder",
  },
  {
    name: "Cashew Nuts",
    slug: "cashew-nuts",
    origin: "Ghana \u{1F1EC}\u{1F1ED} / Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Raw cashew nuts and processed kernels in all standard grades",
    grades: "RCN | W180 | W240 | W320 | W450",
  },
  {
    name: "Hookah Charcoal",
    slug: "hookah-charcoal",
    origin: "Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Premium hardwood and coconut shell charcoal briquettes for the shisha market",
    grades: "Cube 25mm | Flat | Finger | Custom Shapes",
  },
  {
    name: "Dried Hibiscus",
    slug: "hibiscus",
    origin: "Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Sun-dried hibiscus flowers (Roselle) for beverages, tea blends, and food coloring",
    grades: "Whole Flowers | Cut & Sifted | Powder",
  },
  {
    name: "Sesame Seeds",
    slug: "sesame-seeds",
    origin: "Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Premium white and brown sesame seeds for tahini production and food processing",
    grades: "Hulled White | Natural | Black | Organic",
  },
  {
    name: "Moringa Powder",
    slug: "moringa",
    origin: "Ghana \u{1F1EC}\u{1F1ED} / Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Certified organic moringa leaf powder for the health food and supplement markets",
    grades: "Conventional | Organic | Pharmaceutical Grade",
  },
  {
    name: "Dried Ginger",
    slug: "ginger",
    origin: "Nigeria \u{1F1F3}\u{1F1EC}",
    description: "Split and whole dried ginger with high oleoresin and gingerol content",
    grades: "Split Dried | Whole Dried | Powder | Organic",
  },
];

const steps = [
  {
    number: "01",
    title: "Tell Us What You Need",
    description: "Submit a quote request with your product, quantity, and destination. We start planning from the soil.",
  },
  {
    number: "02",
    title: "We Source at the Farm",
    description: "Our on-ground teams visit producers, inspect quality at origin, negotiate pricing, and secure the best product directly from the source.",
  },
  {
    number: "03",
    title: "We Handle the Paperwork & Freight",
    description: "Lab testing, phytosanitary certificates, export documentation, container loading supervision, and ocean freight booking - all managed by us.",
  },
  {
    number: "04",
    title: "Delivered to Your Door",
    description: "Track your shipment in real time. We coordinate customs documentation and last-mile delivery to your warehouse.",
  },
];

const markets = [
  {
    region: "Europe",
    slug: "europe",
    featured: ["Netherlands", "Germany", "UK", "France", "Belgium", "Italy", "Spain", "Portugal", "Poland", "Czech Republic"],
    moreCount: 17,
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.92 17.92 0 01-8.716-2.247m0 0A8.966 8.966 0 013 12c0-1.528.38-2.968 1.05-4.228" /></svg>`,
  },
  {
    region: "Americas",
    slug: "americas",
    featured: ["USA", "Canada", "Mexico", "Brazil", "Argentina", "Colombia", "Chile", "Jamaica", "Trinidad & Tobago", "Costa Rica"],
    moreCount: 12,
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.92 17.92 0 01-8.716-2.247m0 0A8.966 8.966 0 013 12c0-1.528.38-2.968 1.05-4.228" /></svg>`,
  },
  {
    region: "Middle East & Africa",
    slug: "middle-east",
    featured: ["UAE", "Saudi Arabia", "Qatar", "Kuwait", "Turkey", "South Africa", "Kenya", "Egypt", "Morocco", "Bahrain"],
    moreCount: 8,
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>`,
  },
  {
    region: "Asia & Pacific",
    slug: "asia",
    featured: ["China", "Japan", "South Korea", "India", "Vietnam", "Indonesia", "Thailand", "Singapore", "Australia", "Malaysia"],
    moreCount: 9,
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.115 5.19l.319 1.913A6 6 0 008.11 10.36L9.75 12l-.387.775c-.217.433-.132.956.21 1.298l1.348 1.348c.21.21.329.497.329.795v1.089c0 .426.24.815.622 1.006l.153.076c.433.217.956.132 1.298-.21l.723-.723a8.7 8.7 0 002.288-4.042 1.087 1.087 0 00-.358-1.099l-1.33-1.108c-.251-.21-.582-.299-.905-.245l-1.17.195a1.125 1.125 0 01-.98-.314l-.295-.295a1.125 1.125 0 010-1.591l.13-.132a1.125 1.125 0 011.3-.21l.603.302a.809.809 0 001.086-1.086L14.25 7.5l1.256-.837a4.5 4.5 0 001.528-1.732l.146-.292M6.115 5.19A9 9 0 1017.18 4.64M6.115 5.19A8.965 8.965 0 0112 3c1.929 0 3.716.607 5.18 1.64" /></svg>`,
  },
];
---

<Layout title="Origin Direct Group | Commodities Direct From Source" description="B2B commodity broker connecting global buyers with verified suppliers across West Africa and India. Shea butter, cocoa, cashew nuts, and more - direct from source.">

  <!-- Hero Section -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-950 via-green-900 to-amber-950"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(180,130,50,0.15),transparent_60%)]"></div>
    <div class="absolute inset-0 bg-black/30"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white tracking-tight leading-tight mb-6 animate-fade-in">
        Commodities Direct<br />From Source
      </h1>
      <p class="text-lg md:text-xl text-gray-200 max-w-2xl mx-auto mb-10 leading-relaxed">
        We connect global buyers with verified suppliers across West Africa and India.
        No middlemen. No markup. Full traceability.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <a
          href="#quote"
          class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-green-950 font-semibold rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-amber-500/25 text-lg"
        >
          Request a Quote
        </a>
        <a
          href="#products"
          class="inline-flex items-center px-8 py-4 border-2 border-white/80 hover:border-white text-white font-semibold rounded-lg transition-all duration-200 hover:bg-white/10 text-lg"
        >
          View Products
        </a>
      </div>

      <div class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full mb-4">
        <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" />
        </svg>
        <span class="text-sm font-semibold text-amber-200 tracking-wide">From Soil to Door &mdash; We Handle Everything</span>
      </div>

      <p class="text-sm text-gray-300/80 tracking-wide uppercase">
        Trusted by buyers in 150+ countries worldwide
      </p>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Trust Bar -->
  <TrustBar />

  <!-- Why Origin Direct -->
  <section class="py-24 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Why Buyers Choose Us</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Direct From Source -->
        <div class="text-center p-8 rounded-2xl hover:bg-green-50/50 transition-colors duration-300">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 text-green-700 rounded-2xl mb-6">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Direct From Source</h3>
          <p class="text-gray-600 leading-relaxed">
            Our teams in Ghana, Nigeria, and India work directly with producers.
            No European or Asian middlemen inflating your costs.
          </p>
        </div>

        <!-- Full Quality Control -->
        <div class="text-center p-8 rounded-2xl hover:bg-green-50/50 transition-colors duration-300">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 text-green-700 rounded-2xl mb-6">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Full Quality Control</h3>
          <p class="text-gray-600 leading-relaxed">
            Every shipment is inspected, tested, and documented. Lab reports,
            certificates of analysis, and phytosanitary certificates included.
          </p>
        </div>

        <!-- End-to-End Support -->
        <div class="text-center p-8 rounded-2xl hover:bg-green-50/50 transition-colors duration-300">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 text-green-700 rounded-2xl mb-6">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.92 17.92 0 01-8.716-2.247m0 0A8.966 8.966 0 013 12c0-1.528.38-2.968 1.05-4.228" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Soil to Door Service</h3>
          <p class="text-gray-600 leading-relaxed">
            We manage every link in the chain: sourcing at the farm, quality control at origin,
            export documentation, ocean freight, and delivery to your warehouse. FOB, CIF, or DDP.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Products Grid -->
  <section id="products" class="py-24 md:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Products</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Sourced directly from verified producers across West Africa and India
        </p>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full mt-4"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map((product) => (
          <ProductCard
            name={product.name}
            slug={product.slug}
            origin={product.origin}
            description={product.description}
            grades={product.grades}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-24 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">How It Works</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-2">From soil to your door in four simple steps</p>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="relative">
        <!-- Dotted connector line (desktop) -->
        <div class="hidden md:block absolute top-12 left-[12.5%] right-[12.5%] h-0.5 border-t-2 border-dashed border-green-200"></div>

        <div class="grid md:grid-cols-4 gap-8 md:gap-6">
          {steps.map((step) => (
            <div class="relative text-center">
              <div class="inline-flex items-center justify-center w-24 h-24 bg-green-50 border-2 border-green-200 rounded-full mb-6 relative z-10 bg-white">
                <span class="text-2xl font-bold text-green-700">{step.number}</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{step.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>

        <!-- Vertical dotted connector (mobile) -->
        <div class="md:hidden absolute top-0 bottom-0 left-1/2 -translate-x-1/2 w-0.5 border-l-2 border-dashed border-green-200 -z-10"></div>
      </div>
    </div>
  </section>

  <!-- Markets We Serve -->
  <section class="py-24 md:py-28 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Markets We Serve</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>
      <p class="text-center text-lg text-gray-600 mb-12 max-w-2xl mx-auto">
        We ship to <span class="font-semibold text-green-700">150+ countries</span> worldwide. Wherever your business is, we deliver.
      </p>

      <div class="grid sm:grid-cols-2 gap-6">
        {markets.map((market) => (
          <a
            href={`/markets/${market.slug}`}
            class="group bg-white rounded-2xl p-8 border border-gray-100 hover:border-green-200 hover:shadow-lg transition-all duration-300"
          >
            <div class="flex items-center gap-3 mb-4">
              <div class="text-green-700" set:html={market.icon} />
              <h3 class="text-xl font-bold text-gray-900 group-hover:text-green-700 transition-colors">
                {market.region}
              </h3>
            </div>
            <div class="flex flex-wrap gap-2 mb-3">
              {market.featured.map((country: string) => (
                <span class="inline-flex items-center px-2.5 py-1 bg-gray-50 text-gray-700 text-xs font-medium rounded-full border border-gray-200">
                  {country}
                </span>
              ))}
            </div>
            <p class="text-sm text-green-700 font-medium">
              + {market.moreCount} more countries &rarr;
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA / Quote Section -->
  <section id="quote" class="py-24 md:py-28 bg-green-950">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Ready to Source Directly?</h2>
        <p class="text-lg text-green-200/80 max-w-xl mx-auto">
          Get a competitive quote within 2 hours. Our team is ready to help.
        </p>
      </div>

      <QuoteForm />
    </div>
  </section>

</Layout>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.8s ease-out both;
  }
</style>
