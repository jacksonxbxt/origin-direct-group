                <th class="px-6 py-4 font-semibold">Ghana</th>
                <th class="px-6 py-4 font-semibold">Ivory Coast</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr class="bg-white">
