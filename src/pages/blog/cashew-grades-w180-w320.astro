                <td class="px-6 py-3 font-medium text-gray-900">Moisture content</td>
                <td class="px-6 py-3 text-gray-700">Maximum 5%</td>
              </tr>
              <tr class="bg-gray-50">
                <td class="px-6 py-3 font-medium text-gray-900">Broken kernels</td>
                <td class="px-6 py-3 text-gray-700">Maximum 5% (for whole grades)</td>
              </tr>
              <tr class="bg-white">
                <td class="px-6 py-3 font-medium text-gray-900">Spotted/stained kernels</td>
                <td class="px-6 py-3 text-gray-700">Maximum 5% (for white grades)</td>
              </tr>
              <tr class="bg-gray-50">
