---
import Layout from '../../../../layouts/Layout.astro';
import QuoteForm from '../../../../components/QuoteForm.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import { tradeRoutes } from '../../../../data/routes';
import type { TradeRoute } from '../../../../data/routes';

export function getStaticPaths() {
  return tradeRoutes.map((route) => ({
    params: {
      product: route.productSlug,
      country: route.destinationSlug,
    },
    props: { route },
  }));
}

interface Props {
  route: TradeRoute;
}

const { route } = Astro.props;

const siteUrl = "https://origindirectgroup.com";
const pageUrl = `${siteUrl}/products/${route.productSlug}/to/${route.destinationSlug}`;

const title = `${route.productName} Supplier for ${route.destinationName} | Origin Direct Group`;
const description = `Import ${route.productName.toLowerCase()} to ${route.destinationName} direct from ${route.originCountries}. ${route.transitTimeDays} days transit. HS code ${route.hsCode}. ${route.euDuty} duty. Quality certified. Get a quote.`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl + "/" },
    { "@type": "ListItem", position: 2, name: "Products", item: siteUrl + "/products" },
    { "@type": "ListItem", position: 3, name: route.productName, item: siteUrl + "/products/" + route.productSlug },
    { "@type": "ListItem", position: 4, name: route.destinationName, item: pageUrl },
  ],
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: `${route.productName} - Export to ${route.destinationName}`,
  description: description,
  brand: { "@type": "Brand", name: "Origin Direct Group" },
  category: "Commodity Trading",
  countryOfOrigin: { "@type": "Country", name: route.originCountries.split(",")[0].trim() },
  offers: {
    "@type": "Offer",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    eligibleRegion: { "@type": "Country", name: route.destinationName },
    url: pageUrl,
  },
  additionalProperty: [
    { "@type": "PropertyValue", name: "HS Code", value: route.hsCode },
    { "@type": "PropertyValue", name: "Origin Port", value: route.originPort },
    { "@type": "PropertyValue", name: "Destination Port", value: route.destinationPort },
    { "@type": "PropertyValue", name: "Transit Time", value: route.transitTimeDays + " days" },
  ],
};

const docs = [
  { name: "Certificate of Analysis (CoA)", desc: "Full quality testing results for every shipment" },
  { name: "Phytosanitary Certificate", desc: "Plant health certification from origin country" },
  { name: "Certificate of Origin", desc: "Proof of origin for customs clearance and duty preferences" },
  { name: "Bill of Lading", desc: "Shipping document for cargo ownership and delivery" },
  { name: "Commercial Invoice", desc: "Detailed invoice for customs valuation" },
  { name: "Packing List", desc: "Complete breakdown of shipment contents and weights" },
];

// Determine if this is an EU destination (for EUR.1 mention)
const euCountries = ["Germany", "France", "Netherlands", "Italy", "Spain", "Poland", "Belgium", "Greece", "Sweden"];
const isEu = euCountries.includes(route.destinationName);
if (isEu) {
  docs.push({ name: "EUR.1 Movement Certificate", desc: "For preferential duty rates under ACP/EPA agreement" });
}
---

<Layout
  title={title}
  description={description}
  structuredData={[breadcrumbSchema, productSchema]}
>
  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[
      { label: "Products", href: "/products" },
      { label: route.productName, href: `/products/${route.productSlug}` },
      { label: route.destinationName },
    ]} />
  </div>

  <!-- Hero -->
  <section class="relative py-20 sm:py-28 bg-gradient-to-br from-brand-900 via-brand-800 to-earth-800 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(196,154,42,0.3),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Direct from {route.originCountries}</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        Import {route.productName} to {route.destinationName}
      </h1>
      <p class="text-lg text-brand-200 max-w-2xl mx-auto mb-8">
        {route.productName} supplier for {route.destinationName}. {route.transitTimeDays} days transit via {route.destinationPort}. Quality certified, documentation handled.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Get a Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- Route Summary Card -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gray-50 rounded-2xl border border-gray-200 p-6 sm:p-8">
        <h2 class="text-xl font-bold text-brand-900 mb-6">Route Summary</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Origin -->
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Origin Port</p>
            <p class="text-sm font-medium text-gray-900">{route.originPort}</p>
          </div>
          <!-- Destination -->
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Destination Port</p>
            <p class="text-sm font-medium text-gray-900">{route.destinationPort}</p>
          </div>
          <!-- Transit Time -->
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Transit Time</p>
            <p class="text-sm font-medium text-gray-900">{route.transitTimeDays} days</p>
          </div>
          <!-- HS Code -->
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">HS Code</p>
            <p class="text-sm font-mono font-medium text-gray-900">{route.hsCode}</p>
          </div>
        </div>

        <!-- Duty rates -->
        <div class="mt-6 pt-6 border-t border-gray-200 grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">EU Duty Rate</p>
            <p class="text-sm font-medium text-gray-900">{route.euDuty}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">US Duty Rate</p>
            <p class="text-sm font-medium text-gray-900">{route.usDuty}</p>
          </div>
        </div>

        <!-- Route visualization -->
        <div class="mt-6 pt-6 border-t border-gray-200">
          <div class="flex items-center justify-center gap-3 text-sm">
            <span class="bg-brand-100 text-brand-800 font-semibold px-3 py-1.5 rounded-lg">{route.originPort.split(",")[0]}</span>
            <div class="flex items-center gap-1 text-gray-400">
              <div class="w-8 h-px bg-gray-300"></div>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
            <span class="text-xs text-gray-500 font-medium">{route.transitTimeDays} days</span>
            <div class="flex items-center gap-1 text-gray-400">
              <div class="w-8 h-px bg-gray-300"></div>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
            <span class="bg-gold/10 text-gold-dark font-semibold px-3 py-1.5 rounded-lg">{route.destinationPort.split("/")[0].split(",")[0]}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Import Requirements -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-brand-900 mb-6">
        What You Need to Know About Importing {route.productName} to {route.destinationName}
      </h2>
      <div class="prose prose-lg text-gray-700 space-y-4">
        <p>{route.importRequirements}</p>
        <p>
          Origin Direct handles all export-side documentation and works with your freight forwarder or customs broker to ensure smooth clearance at {route.destinationPort}. We have established trade lanes on this route and ship regularly to {route.destinationName}.
        </p>
      </div>

      <!-- Certifications -->
      {route.certifications.length > 0 && (
        <div class="mt-8">
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Required Certifications &amp; Standards</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {route.certifications.map((cert) => (
              <div class="flex items-start gap-3 bg-green-50 rounded-lg p-3 border border-green-100">
                <svg class="w-5 h-5 text-brand-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-sm font-medium text-gray-800">{cert}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Shipping Details -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-brand-900 mb-8">Shipping &amp; Packaging</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Logistics</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1 font-bold">&#8226;</span>
              <span><strong>Container:</strong> {route.containerType}</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1 font-bold">&#8226;</span>
              <span><strong>Loading Port:</strong> {route.originPort}</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1 font-bold">&#8226;</span>
              <span><strong>Discharge Port:</strong> {route.destinationPort}</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1 font-bold">&#8226;</span>
              <span><strong>Transit Time:</strong> {route.transitTimeDays} days</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Packaging Options</h3>
          <p class="text-gray-700 mb-3">{route.packaging}</p>
          <p class="text-sm text-gray-500">
            Custom packaging and private labeling available on request. Incoterms: FOB, CIF, CFR, and DDP available.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Documentation -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-brand-900 mb-4">Documentation We Provide</h2>
      <p class="text-gray-600 mb-8">
        Every shipment to {route.destinationName} comes with comprehensive documentation to ensure smooth customs clearance and regulatory compliance.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {docs.map((doc) => (
          <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
              <div>
                <p class="text-sm font-semibold text-gray-900">{doc.name}</p>
                <p class="text-xs text-gray-500 mt-0.5">{doc.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <section id="quote-form" class="py-16 bg-gray-50">
    <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8">
      <QuoteForm productName={route.productName} />
    </div>
  </section>

  <!-- Back to product -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <a
        href={`/products/${route.productSlug}`}
        class="inline-flex items-center gap-2 text-brand-700 hover:text-brand-900 font-medium transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        Back to {route.productName} product page
      </a>
    </div>
  </section>

</Layout>
