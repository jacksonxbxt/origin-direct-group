---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
---

<Layout
  title="Sesame Seeds - Premium Nigerian White & Brown | Origin Direct"
  description="Premium Nigerian sesame seeds with 48-55% oil content. Hulled white, natural, brown and black varieties. EU ethylene oxide compliant. B2B supply for tahini, bakery, and oil."
>
  <!-- Hero -->
  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-earth-800 via-brand-900 to-earth-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(196,154,42,0.4),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Nigeria &mdash; Top 3 Global Exporter</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Sesame Seeds</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        High oil content Nigerian sesame for tahini production, bakery, confectionery, and oil extraction. EU ethylene oxide compliant.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Request Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- Product Image -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-100">
        <img
          src="/images/products/sesame-seeds.jpg"
          alt="Premium sesame seeds from Nigeria"
          class="w-full h-64 sm:h-80 object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Overview</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          Nigeria consistently ranks among the world's top three sesame seed exporters, producing seeds with oil content between 48&ndash;55% &mdash; some of the highest in the global market. This makes Nigerian sesame particularly prized for oil extraction and tahini production, where oil content directly determines yield and profitability.
        </p>
        <p>
          Origin Direct supplies the full range of sesame varieties: hulled white seeds for tahini and hummus manufacturers, natural white and brown seeds for bakery toppings and confectionery, and black sesame for specialty applications. Every lot undergoes rigorous testing for Salmonella, E. coli, and critically, ethylene oxide levels below the EU threshold of 0.05 mg/kg &mdash; a parameter that has caused border rejections for many exporters.
        </p>
        <p>
          Our cleaning and sorting facilities in Nigeria use optical sorting technology to achieve purity above 99%, meeting the exacting standards of Turkish tahini producers, Japanese oil manufacturers, and European food processors alike.
        </p>
      </div>
    </div>
  </section>

  <!-- Specifications -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Technical Specifications</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-earth-800 text-white">
              <th class="px-6 py-4 font-semibold">Parameter</th>
              <th class="px-6 py-4 font-semibold">Specification</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Oil Content</td>
              <td class="px-6 py-4 text-gray-700">48 &ndash; 55%</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Free Fatty Acids (FFA)</td>
              <td class="px-6 py-4 text-gray-700">&lt; 2%</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Moisture</td>
              <td class="px-6 py-4 text-gray-700">&lt; 5%</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Purity</td>
              <td class="px-6 py-4 text-gray-700">&gt; 99%</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Salmonella</td>
              <td class="px-6 py-4 text-gray-700">Absent per 25g</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">E. coli</td>
              <td class="px-6 py-4 text-gray-700">&lt; 10 CFU/g</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Ethylene Oxide</td>
              <td class="px-6 py-4 text-gray-700">&lt; 0.05 mg/kg (EU requirement)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Available Grades -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Available Grades</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-earth-800 text-white">
              <th class="px-6 py-4 font-semibold">Grade</th>
              <th class="px-6 py-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Hulled White</td>
              <td class="px-6 py-4 text-gray-700">Outer husk removed. Premium appearance. Primary grade for tahini and hummus production.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Natural (Unhulled) White</td>
              <td class="px-6 py-4 text-gray-700">With husk intact. Used for bakery toppings, oil extraction, and confectionery.</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Natural Brown</td>
              <td class="px-6 py-4 text-gray-700">Darker variety with nutty flavor. Popular in Asian cuisine and specialty bakeries.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Black Sesame</td>
              <td class="px-6 py-4 text-gray-700">Growing demand in health food, Asian confectionery, and premium oil production.</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Organic Certified</td>
              <td class="px-6 py-4 text-gray-700">Available in white and brown varieties. For organic food manufacturers.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Certifications &amp; Documentation</h2>
      <p class="text-gray-700 mb-8">Full analytical and regulatory documentation for seamless import clearance.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          "Certificate of Analysis (CoA)",
          "Phytosanitary Certificate",
          "Certificate of Origin",
          "SGS Inspection (available)",
          "Organic Certification (available)",
          "Ethylene Oxide Test Report",
        ].map((cert) => (
          <div class="flex items-start gap-3 bg-white rounded-lg p-4 border border-gray-200">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm font-medium text-gray-800">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Packaging & Shipping -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Packaging &amp; Shipping</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Packaging Options</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>25 kg or 50 kg PP (polypropylene) bags</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>Bulk in container liners (20&ndash;25 MT per container)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>Custom packaging on request</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Key Markets &amp; Transit</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>Turkey</strong> &mdash; Tahini production hub</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>Japan &amp; China</strong> &mdash; Oil and confectionery</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>EU &amp; Middle East</strong> &mdash; Food processing</span>
            </li>
          </ul>
          <p class="text-sm text-gray-500 mt-4">FOB Lagos. Season: Oct&ndash;Feb. Year-round supply from warehoused stock.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <QuoteForm productName="Sesame Seeds" />
</Layout>
