---

<Layout
  title="Our Products | Origin Direct Group"
  description="Browse our full range of 33+ commodities sourced directly from West Africa and India. Shea butter, cocoa, cashews, spices, industrial minerals, and more."
>
  <!-- Hero -->
  <section class="relative py-24 bg-gradient-to-br from-green-950 via-green-900 to-earth-900">
    <div class="absolute inset-0 bg-black/30"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight">
        Our Products
      </h1>
      <div class="w-16 h-1 bg-amber-500 mx-auto mt-6 mb-6"></div>
      <p class="text-lg md:text-xl text-gray-200/90 max-w-3xl mx-auto">
        33+ commodities sourced directly from verified producers across West Africa and India.
        Full quality control, documentation, and soil-to-door delivery.
      </p>
    </div>
  </section>

  <!-- Core Products Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-brand-900">Core Commodities</h2>
        <p class="mt-3 text-gray-500 max-w-2xl mx-auto">
          Our most requested products with established supply chains and full compliance documentation.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {products.map((product) => (
          <ProductCard {...product} />
        ))}
      </div>
    </div>
  </section>

  <!-- Extended Range: West Africa -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-brand-900">Extended Range &mdash; West Africa</h2>
        <p class="mt-3 text-gray-500 max-w-2xl mx-auto">
          Specialty commodities from Ghana and Nigeria. Health food ingredients, industrial minerals, natural skincare, and more.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {extendedWestAfrica.map((product) => (
          <ProductCard {...product} />
        ))}
      </div>
    </div>
  </section>

  <!-- Extended Range: India -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-brand-900">Extended Range &mdash; India</h2>
        <p class="mt-3 text-gray-500 max-w-2xl mx-auto">
          High-volume Indian commodities where India holds near-monopoly supply positions. Spices, industrial oils, and agricultural ingredients.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {extendedIndia.map((product) => (
          <ProductCard {...product} />
        ))}
      </div>
    </div>
  </section>

  <!-- Can't Find What You're Looking For -->
  <section class="py-20 bg-brand-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center mb-12">
        <h2 class="text-3xl font-bold text-brand-900">
          Don't See What You Need?
        </h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          Our product range goes far beyond what's listed here. With teams on the ground across Ghana, Nigeria, and India,
          we can source virtually any commodity from the region. Just tell us what you're looking for.
        </p>
        <a
          href="/products/custom-sourcing"
          class="inline-flex items-center gap-2 mt-6 px-6 py-3 bg-amber-500 text-white font-semibold rounded-lg hover:bg-amber-600 transition-colors shadow-sm"
        >
          Explore Custom Sourcing
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="max-w-4xl mx-auto">
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider text-center mb-6">
          Other products we can source
        </h3>
        <div class="flex flex-wrap justify-center gap-2">
          {otherProducts.map((product) => (
            <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-full text-sm text-gray-600 hover:border-brand-400 hover:text-brand-700 transition-colors cursor-default">
              {product}
            </span>
          ))}
          <a
            href="/products/custom-sourcing"
            class="px-3 py-1.5 bg-brand-700 text-white rounded-full text-sm font-medium hover:bg-brand-600 transition-colors"
          >
            + Anything else &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote CTA -->
  <section class="py-20 bg-green-950">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-white">Request a Quote</h2>
        <p class="mt-3 text-gray-300">
          Tell us what you need - we'll get back to you within 2 hours.
        </p>
      </div>
      <QuoteForm />
    </div>
  </section>
</Layout>
