---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Cassava Starch",
  description: "Premium cassava starch from Nigeria, the world's largest cassava producer (59M MT/year). Food processing, pharmaceuticals, textiles, and bioplastics.",
  image: "https://origindirectgroup.com/images/products/cassava-starch.jpg",
  brand: { "@type": "Brand", name: "Origin Direct Group" },
  category: "Food & Industrial Starch",
  countryOfOrigin: { "@type": "Country", name: "Nigeria" },
  offers: { "@type": "AggregateOffer", priceCurrency: "USD", availability: "https://schema.org/InStock" },
  additionalProperty: [
    { "@type": "PropertyValue", name: "HS Code", value: "1108.14" },
    { "@type": "PropertyValue", name: "MOQ", value: "1 FCL (20 MT)" },
    { "@type": "PropertyValue", name: "Origin", value: "Nigeria" },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Products", item: "https://origindirectgroup.com/products" },
    { "@type": "ListItem", position: 3, name: "Cassava Starch", item: "https://origindirectgroup.com/products/cassava-starch" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Why is Nigeria a strategic source for cassava starch?",
      acceptedAnswer: { "@type": "Answer", text: "Nigeria is the world's largest cassava producer at approximately 59 million metric tons annually, more than double the output of the second-largest producer (Thailand at 28M MT). However, Nigeria currently processes only about 10% of its cassava into starch, meaning there is massive untapped supply. This production scale, combined with lower labor costs, makes Nigerian cassava starch price-competitive with Thai starch for many applications." },
    },
    {
      "@type": "Question",
      name: "What industries use cassava starch?",
      acceptedAnswer: { "@type": "Answer", text: "Cassava starch serves multiple industries: food processing (thickener, binder, modified starch for sauces and processed foods), pharmaceuticals (tablet binder and disintegrant), textiles (fabric sizing and finishing), paper manufacturing (surface sizing and coating), adhesives (corrugated board and packaging), and increasingly bioplastics (biodegradable packaging material). The global cassava starch market exceeds $50 billion annually." },
    },
    {
      "@type": "Question",
      name: "What quality standards does your cassava starch meet?",
      acceptedAnswer: { "@type": "Answer", text: "Our cassava starch meets international food-grade specifications: moisture below 13%, starch content above 85%, pH 5.0-7.0, ash below 0.2%, fiber below 0.3%, and SO2 below 30 ppm. For pharmaceutical applications, we supply BP/USP-compliant grades with additional microbiological testing. Every shipment includes Certificate of Analysis, Certificate of Origin, and phytosanitary certificate." },
    },
  ],
};
---

<Layout
  title="Cassava Starch Supplier - Direct from Nigeria | Origin Direct"
  description="Premium cassava starch from Nigeria, world's largest producer (59M MT/year). Food-grade, pharma-grade. For food processing, textiles, bioplastics. Bulk supply."
  structuredData={[productSchema, breadcrumbSchema, faqSchema]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Products", href: "/products" }, { label: "Cassava Starch" }]} />
  </div>

  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-brand-900 via-brand-800 to-earth-800 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(196,154,42,0.3),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Direct from Nigeria</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Cassava Starch</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        From the world's largest cassava producer. Food-grade and pharmaceutical-grade starch for processing, textiles, and bioplastics.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Request Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Overview</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          Nigeria is the world's largest cassava producer at 59 million metric tons annually, dwarfing Thailand (28M MT) and Indonesia (18M MT). Cassava starch extracted from this massive production base is a versatile industrial commodity used in food processing, pharmaceuticals, textiles, paper, adhesives, and the rapidly growing bioplastics sector.
        </p>
        <p>
          While Thailand has historically dominated global cassava starch exports, Nigeria's cost advantages in raw material and labor are making it increasingly competitive. The Nigerian government's cassava industrialization policies are driving investment in modern starch extraction facilities, improving quality consistency to meet international standards.
        </p>
        <p>
          Origin Direct partners with established cassava processing facilities across Nigeria's cassava belt to supply food-grade and pharmaceutical-grade starch in bulk. Our direct sourcing model ensures competitive pricing, consistent quality, and reliable supply for industrial buyers seeking alternatives to traditional Thai and Vietnamese sources.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Key Specifications</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-brand-800 text-white">
              <th class="px-6 py-4 font-semibold">Parameter</th>
              <th class="px-6 py-4 font-semibold">Specification</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Starch Content</td><td class="px-6 py-4 text-gray-700">&gt; 85%</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Moisture</td><td class="px-6 py-4 text-gray-700">&lt; 13%</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">pH</td><td class="px-6 py-4 text-gray-700">5.0 &ndash; 7.0</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Ash</td><td class="px-6 py-4 text-gray-700">&lt; 0.2%</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Whiteness</td><td class="px-6 py-4 text-gray-700">&gt; 90% (ISO brightness)</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Viscosity</td><td class="px-6 py-4 text-gray-700">700 &ndash; 1,100 BU (Brabender)</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">MOQ</td><td class="px-6 py-4 text-gray-700">1 FCL (~20 MT)</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">HS Code</td><td class="px-6 py-4 text-gray-700">1108.14</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((faq) => (
          <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
            <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">{faq.name}</summary>
            <div class="px-6 pb-4 text-gray-700">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <QuoteForm productName="Other (please specify below)" />
</Layout>
