---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Psyllium Husk",
  description: "Indian psyllium husk (80%+ of global supply). Premium dietary fiber ingredient. $6,600/MT. Health food and pharmaceutical markets.",
  image: "https://origindirectgroup.com/images/products/psyllium-husk.jpg",
  brand: { "@type": "Brand", name: "Origin Direct Group" },
  category: "Health Food & Pharmaceutical Ingredients",
  countryOfOrigin: { "@type": "Country", name: "India" },
  offers: { "@type": "AggregateOffer", priceCurrency: "USD", availability: "https://schema.org/InStock" },
  additionalProperty: [
    { "@type": "PropertyValue", name: "HS Code", value: "1211.90" },
    { "@type": "PropertyValue", name: "MOQ", value: "1 FCL (15 MT)" },
    { "@type": "PropertyValue", name: "Origin", value: "India" },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Products", item: "https://origindirectgroup.com/products" },
    { "@type": "ListItem", position: 3, name: "Psyllium Husk", item: "https://origindirectgroup.com/products/psyllium-husk" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Why have psyllium husk prices increased so dramatically?",
      acceptedAnswer: { "@type": "Answer", text: "Psyllium husk prices have surged approximately 52% in recent years, driven by explosive growth in health food demand, GLP-1 drug alternatives (fiber supplements), and the gut health movement. India supplies over 80% of global psyllium from Rajasthan and Gujarat, where production is limited by arid climate constraints. Current prices around $6,600/MT reflect tight supply against surging demand from supplement brands, food manufacturers adding fiber to products, and pharmaceutical companies." },
    },
    {
      "@type": "Question",
      name: "What are the main commercial uses of psyllium husk?",
      acceptedAnswer: { "@type": "Answer", text: "Psyllium husk is the active ingredient in Metamucil and similar fiber supplements (largest use). It is also used in: gluten-free baking (replaces gluten's binding properties), food processing (fiber enrichment of cereals, bars, and baked goods), pharmaceutical formulations (bulk-forming laxative, cholesterol-lowering), and cosmetics (face masks, skin care). The FDA allows a heart health claim for psyllium: 7g/day can reduce cholesterol." },
    },
    {
      "@type": "Question",
      name: "What psyllium grades are available?",
      acceptedAnswer: { "@type": "Answer", text: "We supply: 85% husk (standard dietary supplement grade), 95% husk (premium pharmaceutical grade), 98% husk (ultra-fine, for capsule filling), psyllium husk powder (fine mesh, for food processing), and whole psyllium seed (for animal feed and industrial use). All grades meet USP/BP specifications. Organic certified (USDA NOP, EU Organic) is available at 20-30% premium. We provide certificates of analysis with purity, swell volume, moisture, and microbiological parameters." },
    },
  ],
};
---

<Layout
  title="Psyllium Husk Supplier - Direct from India | Origin Direct"
  description="Indian psyllium husk (80%+ of global supply). Prices up 52%. $6,600/MT. Dietary fiber for supplements, food processing, pharma. USP/BP compliant."
  structuredData={[productSchema, breadcrumbSchema, faqSchema]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Products", href: "/products" }, { label: "Psyllium Husk" }]} />
  </div>

  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-brand-900 via-brand-800 to-earth-800 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(196,154,42,0.3),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Direct from India</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Psyllium Husk</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        The world's #1 dietary fiber ingredient. From India, which controls 80%+ of global supply. Prices up 52% — secure your supply chain.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Request Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Overview</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          Psyllium husk (Plantago ovata) is the world's most widely used dietary fiber supplement ingredient, best known as the active component in Metamucil. India dominates global production with over 80% market share, grown primarily in the semi-arid regions of Rajasthan and Gujarat. The FDA recognizes psyllium's cholesterol-lowering benefits, allowing a heart health claim for products containing 7g daily.
        </p>
        <p>
          Prices have surged approximately 52% in recent years, reaching around $6,600/MT, driven by the health food boom, growing demand for fiber-enriched processed foods, the gut health movement, and interest in natural GLP-1 alternatives. Supply remains constrained by the limited growing area in western India and the crop's sensitivity to rainfall timing.
        </p>
        <p>
          Origin Direct sources psyllium husk directly from processing facilities in Rajasthan's Mehsana and Sidhpur regions, the heart of India's psyllium belt. We supply pharmaceutical-grade (USP/BP), food-grade, and organic-certified husk and powder with full documentation for regulatory compliance in the EU, US, and global markets.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Key Specifications</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-brand-800 text-white">
              <th class="px-6 py-4 font-semibold">Parameter</th>
              <th class="px-6 py-4 font-semibold">Specification</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Purity</td><td class="px-6 py-4 text-gray-700">85%, 95%, or 98% husk</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Swell Volume</td><td class="px-6 py-4 text-gray-700">&gt; 40 ml/g (USP specification)</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Moisture</td><td class="px-6 py-4 text-gray-700">&lt; 12%</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Ash</td><td class="px-6 py-4 text-gray-700">&lt; 4%</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Price</td><td class="px-6 py-4 text-gray-700">~$6,600/MT (85% husk, FOB)</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Certifications</td><td class="px-6 py-4 text-gray-700">USP/BP, Organic (USDA/EU), Kosher, Halal</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">MOQ</td><td class="px-6 py-4 text-gray-700">1 FCL (~15 MT)</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">HS Code</td><td class="px-6 py-4 text-gray-700">1211.90</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((faq) => (
          <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
            <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">{faq.name}</summary>
            <div class="px-6 pb-4 text-gray-700">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <QuoteForm productName="Other (please specify below)" />
</Layout>
