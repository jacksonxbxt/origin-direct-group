---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Kola Nuts",
  description: "Premium kola nuts sourced directly from Nigeria, the world's largest producer. Natural caffeine source for beverages, supplements, and traditional uses.",
  image: "https://origindirectgroup.com/images/products/kola-nuts.jpg",
  brand: { "@type": "Brand", name: "Origin Direct Group" },
  category: "Functional Ingredients",
  countryOfOrigin: { "@type": "Country", name: "Nigeria" },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
  },
  additionalProperty: [
    { "@type": "PropertyValue", name: "HS Code", value: "0811.90" },
    { "@type": "PropertyValue", name: "MOQ", value: "1 FCL (18-20 MT)" },
    { "@type": "PropertyValue", name: "Origin", value: "Nigeria" },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Products", item: "https://origindirectgroup.com/products" },
    { "@type": "ListItem", position: 3, name: "Kola Nuts", item: "https://origindirectgroup.com/products/kola-nuts" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How much kola nut does Nigeria produce?",
      acceptedAnswer: { "@type": "Answer", text: "Nigeria produces approximately 188,000 tonnes of kola nuts annually, accounting for 52% of global production. The main growing regions are in the southern states, particularly Oyo, Osun, Ondo, and Edo. Nigeria has been the world's dominant kola nut producer for decades, with production concentrated among smallholder farmers." },
    },
    {
      "@type": "Question",
      name: "What are kola nuts used for commercially?",
      acceptedAnswer: { "@type": "Answer", text: "Kola nuts contain 2-3.5% caffeine and 1-2.5% theobromine, making them a natural stimulant. Commercial uses include functional beverages and energy drinks, dietary supplements, pharmaceutical formulations, and flavoring extracts. Historically, kola nut extract was the original flavoring in cola soft drinks. The global functional beverage trend is driving renewed demand for natural caffeine sources." },
    },
    {
      "@type": "Question",
      name: "What is the price range for wholesale kola nuts?",
      acceptedAnswer: { "@type": "Answer", text: "Wholesale kola nut prices typically range from $2,500 to $4,800 per metric ton FOB Lagos, depending on variety (Cola nitida commands higher prices than Cola acuminata), quality grade, moisture content, and order volume. Prices fluctuate seasonally, with peak harvest from August to October offering the most competitive rates." },
    },
  ],
};
---

<Layout
  title="Kola Nuts Supplier - Direct from Nigeria | Origin Direct"
  description="Premium kola nuts from Nigeria, world's #1 producer (52% of global supply). Natural caffeine source for beverages and supplements. $2,500-4,800/MT FOB."
  structuredData={[productSchema, breadcrumbSchema, faqSchema]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Products", href: "/products" }, { label: "Kola Nuts" }]} />
  </div>

  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-brand-900 via-brand-800 to-earth-800 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(196,154,42,0.3),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Direct from Nigeria</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Kola Nuts</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        Natural caffeine source from the world's largest producer. For functional beverages, supplements, and pharmaceutical applications.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Request Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Overview</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          Kola nuts (Cola nitida and Cola acuminata) are one of West Africa's most culturally and commercially significant crops. Nigeria dominates global production with 188,000 tonnes annually, representing 52% of world output. The nut's natural caffeine content (2-3.5%) and theobromine make it a prized ingredient in the functional beverage and supplement industries.
        </p>
        <p>
          Beyond their historical role as the original flavoring in cola beverages, kola nuts are experiencing renewed commercial interest as consumers seek natural alternatives to synthetic caffeine. The global functional beverage market, valued at over $200 billion, increasingly demands plant-based stimulant ingredients with clean-label appeal.
        </p>
        <p>
          Origin Direct sources kola nuts from Nigeria's prime growing regions in the southwest, working directly with farming cooperatives to ensure consistent quality. Our supply chain offers fresh and dried kola nuts in bulk, with prices ranging from $2,500 to $4,800/MT FOB Lagos depending on variety and grade.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Key Specifications</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-brand-800 text-white">
              <th class="px-6 py-4 font-semibold">Parameter</th>
              <th class="px-6 py-4 font-semibold">Specification</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Varieties</td><td class="px-6 py-4 text-gray-700">Cola nitida (preferred) &amp; Cola acuminata</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Caffeine Content</td><td class="px-6 py-4 text-gray-700">2.0 &ndash; 3.5%</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Theobromine</td><td class="px-6 py-4 text-gray-700">1.0 &ndash; 2.5%</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Moisture (dried)</td><td class="px-6 py-4 text-gray-700">&lt; 12%</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Price Range</td><td class="px-6 py-4 text-gray-700">$2,500 &ndash; $4,800/MT FOB Lagos</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">MOQ</td><td class="px-6 py-4 text-gray-700">1 FCL (~18 MT)</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Packaging</td><td class="px-6 py-4 text-gray-700">25 kg or 50 kg jute/PP bags</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">HS Code</td><td class="px-6 py-4 text-gray-700">0811.90</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((faq) => (
          <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
            <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">{faq.name}</summary>
            <div class="px-6 pb-4 text-gray-700">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <QuoteForm productName="Other (please specify below)" />
</Layout>
