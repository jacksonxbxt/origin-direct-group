---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Shea Butter",
  description: "Premium shea butter sourced directly from Ghana. Cosmetic grade, refined, organic certified. FFA < 1%, COSMOS & ECOCERT certified.",
  image: "https://origindirectgroup.com/images/products/shea-butter.jpg",
  brand: { "@type": "Brand", name: "Origin Direct Group" },
  category: "Cosmetic & Food Ingredients",
  countryOfOrigin: { "@type": "Country", name: "Ghana" },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
  },
  additionalProperty: [
    { "@type": "PropertyValue", name: "HS Code", value: "1515.90" },
    { "@type": "PropertyValue", name: "MOQ", value: "1 FCL (18-20 MT)" },
    { "@type": "PropertyValue", name: "Certifications", value: "COSMOS, ECOCERT, USDA Organic, EU Organic" },
    { "@type": "PropertyValue", name: "FFA", value: "< 1%" },
    { "@type": "PropertyValue", name: "Melting Point", value: "33-42°C" },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Products", item: "https://origindirectgroup.com/products" },
    { "@type": "ListItem", position: 3, name: "Shea Butter", item: "https://origindirectgroup.com/products/shea-butter" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What grades of shea butter does Origin Direct supply?",
      acceptedAnswer: { "@type": "Answer", text: "We supply five grades: Grade A Unrefined (raw, yellow), Refined (white, odorless), Organic Certified (COSMOS/ECOCERT), Shea Olein (liquid fraction for serums), and Shea Stearin (solid fraction for cosmetics). All sourced directly from women's cooperatives in northern Ghana." },
    },
    {
      "@type": "Question",
      name: "What is the minimum order quantity for shea butter?",
      acceptedAnswer: { "@type": "Answer", text: "Standard MOQ is 1 full container load (FCL), approximately 18-20 metric tons. We offer 25kg cartons, 50kg drums, and 180kg drums. Smaller trial orders of 1-5 MT available for new customers." },
    },
    {
      "@type": "Question",
      name: "Is your shea butter COSMOS and ECOCERT certified?",
      acceptedAnswer: { "@type": "Answer", text: "Yes. Our organic shea butter is certified by both COSMOS and ECOCERT. We also hold USDA Organic and EU Organic certifications. Certificates are provided with every shipment." },
    },
    {
      "@type": "Question",
      name: "What are the quality specifications for cosmetic grade shea butter?",
      acceptedAnswer: { "@type": "Answer", text: "Our cosmetic grade shea butter meets: Free Fatty Acid (FFA) below 1%, Peroxide Value below 10 meq/kg, Moisture below 0.05%, Unsaponifiable Matter 6-17%, Melting Point 33-42 degrees C, and heavy metals undetectable." },
    },
    {
      "@type": "Question",
      name: "How much does wholesale shea butter cost?",
      acceptedAnswer: { "@type": "Answer", text: "Pricing depends on grade, volume, and Incoterms. Indicative range: unrefined Grade A $2,500-3,600/MT FOB Tema (Ghana), refined $3,000-4,200/MT, organic certified $3,500-5,000/MT. Contact us for a firm quote." },
    },
  ],
};
---

<Layout
  title="Shea Butter Supplier - Direct from Ghana | Origin Direct"
  description="Premium shea butter sourced directly from Ghana. Cosmetic grade, refined, organic certified. FFA < 1%, COSMOS & ECOCERT certified. Competitive B2B pricing."
  structuredData={[productSchema, breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Products", href: "/products" }, { label: "Shea Butter" }]} />
  </div>

  <!-- Hero -->
  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-brand-900 via-brand-800 to-earth-800 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(196,154,42,0.3),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Direct from Ghana</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Shea Butter</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        Premium unrefined and refined shea butter for cosmetics, food, and pharmaceutical applications. Sourced directly from Ghanaian cooperatives.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Request Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- Product Image -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-100">
        <img
          src="/images/products/shea-butter.jpg"
          alt="Premium shea butter sourced directly from Ghana"
          class="w-full h-64 sm:h-80 object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Overview</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          Shea butter is one of West Africa's most versatile commodity exports, prized across the cosmetics industry (57% of demand), food and chocolate manufacturing (35%), and pharmaceutical applications (8%). Ghana's Northern and Upper regions produce some of the highest-quality shea nuts in the world, yielding butter with superior moisturizing properties and a rich nutrient profile.
        </p>
        <p>
          Origin Direct works with established cooperatives and processing facilities across Ghana's shea belt, giving us direct control over quality from nut collection through to final processing. Our supply chain eliminates unnecessary intermediaries, resulting in competitive pricing without compromising on the strict quality parameters that European and American buyers demand.
        </p>
        <p>
          Whether you need raw unrefined butter for artisanal cosmetics, fully refined white butter for industrial formulations, or COSMOS-certified organic butter for premium product lines, we deliver consistent quality with full traceability and documentation.
        </p>
      </div>
    </div>
  </section>

  <!-- Specifications -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Technical Specifications</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-brand-800 text-white">
              <th class="px-6 py-4 font-semibold">Parameter</th>
              <th class="px-6 py-4 font-semibold">Specification</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Free Fatty Acids (FFA)</td>
              <td class="px-6 py-4 text-gray-700">&lt; 1% (cosmetic grade)</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Peroxide Value</td>
              <td class="px-6 py-4 text-gray-700">&lt; 10 meq/kg</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Moisture Content</td>
              <td class="px-6 py-4 text-gray-700">&lt; 0.05%</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Unsaponifiable Matter</td>
              <td class="px-6 py-4 text-gray-700">6 &ndash; 17%</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Melting Point</td>
              <td class="px-6 py-4 text-gray-700">33 &ndash; 42&deg;C</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Heavy Metals</td>
              <td class="px-6 py-4 text-gray-700">Undetectable</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Available Grades -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Available Grades</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-brand-800 text-white">
              <th class="px-6 py-4 font-semibold">Grade</th>
              <th class="px-6 py-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Grade A Unrefined</td>
              <td class="px-6 py-4 text-gray-700">Raw, yellow color with natural nutty aroma. Preferred for artisanal and premium cosmetics.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Refined</td>
              <td class="px-6 py-4 text-gray-700">White, odorless butter. Ideal for industrial cosmetic formulations and food applications.</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Organic Certified</td>
              <td class="px-6 py-4 text-gray-700">COSMOS/ECOCERT certified organic. Meets the strictest standards for natural product lines.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Shea Olein</td>
              <td class="px-6 py-4 text-gray-700">Liquid fraction of shea butter. Used in hair care, massage oils, and liquid formulations.</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Shea Stearin</td>
              <td class="px-6 py-4 text-gray-700">Solid fraction. Used as a cocoa butter equivalent in chocolate and confectionery.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Certifications &amp; Documentation</h2>
      <p class="text-gray-700 mb-8">Every shipment comes with full documentation to meet your regulatory and quality requirements.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          "COSMOS Certified",
          "ECOCERT Certified",
          "USDA Organic",
          "EU Organic",
          "Certificate of Analysis (CoA)",
          "MSDS / Safety Data Sheet",
          "Certificate of Origin",
          "Fair Trade (available)",
        ].map((cert) => (
          <div class="flex items-start gap-3 bg-white rounded-lg p-4 border border-gray-200">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm font-medium text-gray-800">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Packaging & Shipping -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Packaging &amp; Shipping</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Packaging Options</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>25 kg cartons (standard for retail/cosmetic buyers)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>50 kg drums</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>180 kg drums (industrial)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>Flexi-tanks for bulk shipments (20&ndash;24 MT per container)</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Key Markets &amp; Transit</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>EU Cosmetics</strong> &mdash; Rotterdam, Hamburg, Antwerp</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>US Personal Care</strong> &mdash; New York, Savannah</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>Middle East Beauty</strong> &mdash; Dubai, Jeddah</span>
            </li>
          </ul>
          <p class="text-sm text-gray-500 mt-4">FOB Tema Port (Ghana). CIF and DDP terms available on request.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What grades of shea butter does Origin Direct supply?</summary>
          <div class="px-6 pb-4 text-gray-700">We supply five grades: Grade A Unrefined (raw, yellow), Refined (white, odorless), Organic Certified (COSMOS/ECOCERT), Shea Olein (liquid fraction for serums), and Shea Stearin (solid fraction for cosmetics). All sourced directly from women's cooperatives in northern Ghana.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What is the minimum order quantity for shea butter?</summary>
          <div class="px-6 pb-4 text-gray-700">Standard MOQ is 1 full container load (FCL), approximately 18-20 metric tons. We offer 25kg cartons, 50kg drums, and 180kg drums. Smaller trial orders of 1-5 MT available for new customers.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">Is your shea butter COSMOS and ECOCERT certified?</summary>
          <div class="px-6 pb-4 text-gray-700">Yes. Our organic shea butter is certified by both COSMOS and ECOCERT. We also hold USDA Organic and EU Organic certifications. Certificates are provided with every shipment.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What are the quality specifications for cosmetic grade shea butter?</summary>
          <div class="px-6 pb-4 text-gray-700">Our cosmetic grade shea butter meets: Free Fatty Acid (FFA) below 1%, Peroxide Value below 10 meq/kg, Moisture below 0.05%, Unsaponifiable Matter 6-17%, Melting Point 33-42 degrees C, and heavy metals undetectable.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">How much does wholesale shea butter cost?</summary>
          <div class="px-6 pb-4 text-gray-700">Pricing depends on grade, volume, and Incoterms. Indicative range: unrefined Grade A $2,500-3,600/MT FOB Tema (Ghana), refined $3,000-4,200/MT, organic certified $3,500-5,000/MT. Contact us for a firm quote.</div>
        </details>
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <QuoteForm productName="Shea Butter" />
</Layout>
