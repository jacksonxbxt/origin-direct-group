---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Dried Ginger",
  description: "Premium Nigerian dried ginger with the highest oleoresin and gingerol content globally. 4-6% oleoresin, ideal for pharmaceutical and essential oil extraction.",
  image: "https://origindirectgroup.com/images/products/ginger.jpg",
  brand: { "@type": "Brand", name: "Origin Direct Group" },
  category: "Spices & Herbs",
  countryOfOrigin: { "@type": "Country", name: "Nigeria" },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
  },
  additionalProperty: [
    { "@type": "PropertyValue", name: "HS Code", value: "0910.11" },
    { "@type": "PropertyValue", name: "MOQ", value: "1 FCL (18-20 MT)" },
    { "@type": "PropertyValue", name: "Certifications", value: "Phytosanitary, CoA, Organic (available), SGS" },
    { "@type": "PropertyValue", name: "Oleoresin", value: "4-6%" },
    { "@type": "PropertyValue", name: "Volatile Oil", value: "> 1.5%" },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Products", item: "https://origindirectgroup.com/products" },
    { "@type": "ListItem", position: 3, name: "Dried Ginger", item: "https://origindirectgroup.com/products/ginger" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Why is Nigerian ginger considered premium?",
      acceptedAnswer: { "@type": "Answer", text: "Nigerian ginger has the highest oleoresin content (4-6%) and gingerol levels globally, making it preferred for pharmaceutical applications and essential oil extraction. Indian ginger typically has 3-4% oleoresin. This gives Nigerian ginger superior pungency and medicinal value." },
    },
    {
      "@type": "Question",
      name: "What are the specifications for your dried ginger?",
      acceptedAnswer: { "@type": "Answer", text: "Our dried ginger specs: oleoresin 4-6%, volatile oil above 1.5%, moisture below 12%, ash below 8%, crude fiber below 8%, soil content below 1% (EU requirement). Available as split dried, whole dried (unbleached), powder, and organic certified." },
    },
    {
      "@type": "Question",
      name: "Can you supply ginger to the Caribbean market?",
      acceptedAnswer: { "@type": "Answer", text: "Yes. We already supply dried ginger to Jamaica and Trinidad, where demand is strong for beverages and cooking. Nigerian ginger is 60-80% cheaper than what Caribbean buyers currently pay from Canadian and Thai middlemen." },
    },
    {
      "@type": "Question",
      name: "What forms of ginger do you offer?",
      acceptedAnswer: { "@type": "Answer", text: "We supply split dried ginger (most common for export), whole dried unbleached ginger, ginger powder, and organic certified ginger. All forms available in 25kg or 50kg polypropylene woven bags." },
    },
    {
      "@type": "Question",
      name: "What is the minimum order for dried ginger?",
      acceptedAnswer: { "@type": "Answer", text: "Standard MOQ is 1 FCL, approximately 18-20 MT. Packaging in 25kg or 50kg PP woven bags, or cartons for powder. Trial orders from 5 MT considered for new buyers." },
    },
  ],
};
---

<Layout
  title="Dried Ginger - Premium Nigerian Ginger | Origin Direct"
  description="Premium Nigerian dried ginger with the highest oleoresin and gingerol content globally. 4-6% oleoresin, ideal for pharmaceutical and essential oil extraction. B2B supply."
  structuredData={[productSchema, breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Products", href: "/products" }, { label: "Dried Ginger" }]} />
  </div>

  <!-- Hero -->
  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-earth-900 via-earth-800 to-brand-800 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_40%,rgba(196,154,42,0.4),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Nigeria</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Dried Ginger</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        Nigerian ginger &mdash; the world's highest oleoresin and gingerol content. Preferred by pharmaceutical and essential oil producers worldwide.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Request Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- Product Image -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-100">
        <img
          src="/images/products/ginger.jpg"
          alt="Premium dried ginger from Nigeria"
          class="w-full h-64 sm:h-80 object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Overview</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          Nigerian ginger (<em>Zingiber officinale</em>) stands apart in the global market for one critical reason: it contains significantly higher oleoresin (4&ndash;6%) and gingerol content than ginger from India, China, or any other major producing country. These compounds are what give ginger its heat, flavor, and medicinal properties &mdash; making Nigerian ginger the preferred origin for pharmaceutical manufacturers, essential oil producers, and spice blenders who need maximum potency.
        </p>
        <p>
          Origin Direct sources split and whole dried ginger from Nigeria's Kaduna and Nassarawa states, where the volcanic soil and climate conditions produce rhizomes with exceptionally high active compound levels. Our supply chain handles the full process from farm-level aggregation through cleaning, drying, and quality testing before export.
        </p>
        <p>
          For the spice trade, our ginger delivers superior flavor intensity per kilogram. For pharmaceutical and nutraceutical buyers, the high gingerol content means better extraction yields and more potent end products. We also supply ginger powder for food processing and organic-certified ginger for premium markets.
        </p>
      </div>
    </div>
  </section>

  <!-- Specifications -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Technical Specifications</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-earth-800 text-white">
              <th class="px-6 py-4 font-semibold">Parameter</th>
              <th class="px-6 py-4 font-semibold">Specification</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Oleoresin</td>
              <td class="px-6 py-4 text-gray-700">4 &ndash; 6% (higher than Indian ginger)</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Gingerol Content</td>
              <td class="px-6 py-4 text-gray-700">Among highest globally</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Volatile Oil</td>
              <td class="px-6 py-4 text-gray-700">&gt; 1.5%</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Moisture</td>
              <td class="px-6 py-4 text-gray-700">&lt; 12%</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Ash</td>
              <td class="px-6 py-4 text-gray-700">&lt; 8%</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Crude Fiber</td>
              <td class="px-6 py-4 text-gray-700">&lt; 8%</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Soil Content</td>
              <td class="px-6 py-4 text-gray-700">&lt; 1% (EU requirement)</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="mt-6 p-4 bg-gold/10 border border-gold/30 rounded-lg">
        <p class="text-sm text-earth-800"><strong>Nigerian advantage:</strong> Nigerian ginger has significantly higher oleoresin and gingerol content than Indian or Chinese ginger, making it the preferred origin for pharmaceutical and essential oil applications.</p>
      </div>
    </div>
  </section>

  <!-- Available Grades -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Available Grades</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-earth-800 text-white">
              <th class="px-6 py-4 font-semibold">Grade</th>
              <th class="px-6 py-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Split Dried Ginger</td>
              <td class="px-6 py-4 text-gray-700">Most traded form. Rhizomes split and sun-dried. For spice trade and industrial processing.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Whole Dried (Unbleached)</td>
              <td class="px-6 py-4 text-gray-700">Intact rhizomes, naturally dried. Longer shelf life. Preferred for retail and grinding.</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Ginger Powder</td>
              <td class="px-6 py-4 text-gray-700">Finely milled for food processing, beverages, and baking applications.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Organic Certified</td>
              <td class="px-6 py-4 text-gray-700">Available in split, whole, and powder forms. For organic food manufacturers and retailers.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Certifications &amp; Documentation</h2>
      <p class="text-gray-700 mb-8">Complete documentation for import compliance across all major markets.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          "Phytosanitary Certificate",
          "Certificate of Analysis (CoA)",
          "Certificate of Origin",
          "Organic Certification (available)",
          "SGS Inspection (available)",
          "EU Soil Content Test Report",
        ].map((cert) => (
          <div class="flex items-start gap-3 bg-white rounded-lg p-4 border border-gray-200">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm font-medium text-gray-800">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Packaging & Shipping -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Packaging &amp; Shipping</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Packaging Options</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>25 kg or 50 kg PP woven bags (dried ginger)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>Cartons for ginger powder</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>Custom packaging on request</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Key Markets &amp; Transit</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>EU</strong> &mdash; Germany, UK, Netherlands</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>Caribbean</strong> &mdash; Jamaica, Trinidad</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>USA &amp; India</strong> &mdash; Spice trade & pharma</span>
            </li>
          </ul>
          <p class="text-sm text-gray-500 mt-4">FOB Lagos. Season: Nov&ndash;Mar. Climate-controlled storage available for year-round supply.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">Why is Nigerian ginger considered premium?</summary>
          <div class="px-6 pb-4 text-gray-700">Nigerian ginger has the highest oleoresin content (4-6%) and gingerol levels globally, making it preferred for pharmaceutical applications and essential oil extraction. Indian ginger typically has 3-4% oleoresin. This gives Nigerian ginger superior pungency and medicinal value.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What are the specifications for your dried ginger?</summary>
          <div class="px-6 pb-4 text-gray-700">Our dried ginger specs: oleoresin 4-6%, volatile oil above 1.5%, moisture below 12%, ash below 8%, crude fiber below 8%, soil content below 1% (EU requirement). Available as split dried, whole dried (unbleached), powder, and organic certified.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">Can you supply ginger to the Caribbean market?</summary>
          <div class="px-6 pb-4 text-gray-700">Yes. We already supply dried ginger to Jamaica and Trinidad, where demand is strong for beverages and cooking. Nigerian ginger is 60-80% cheaper than what Caribbean buyers currently pay from Canadian and Thai middlemen.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What forms of ginger do you offer?</summary>
          <div class="px-6 pb-4 text-gray-700">We supply split dried ginger (most common for export), whole dried unbleached ginger, ginger powder, and organic certified ginger. All forms available in 25kg or 50kg polypropylene woven bags.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What is the minimum order for dried ginger?</summary>
          <div class="px-6 pb-4 text-gray-700">Standard MOQ is 1 FCL, approximately 18-20 MT. Packaging in 25kg or 50kg PP woven bags, or cartons for powder. Trial orders from 5 MT considered for new buyers.</div>
        </details>
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <QuoteForm productName="Ginger" />
</Layout>
