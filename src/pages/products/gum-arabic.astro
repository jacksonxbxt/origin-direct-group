---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Gum Arabic",
  description: "Food-grade gum arabic (E414) from Nigeria. Natural emulsifier and stabilizer for beverages, confectionery, and pharmaceuticals.",
  image: "https://origindirectgroup.com/images/products/gum-arabic.jpg",
  brand: { "@type": "Brand", name: "Origin Direct Group" },
  category: "Food Additives & Ingredients",
  countryOfOrigin: { "@type": "Country", name: "Nigeria" },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
  },
  additionalProperty: [
    { "@type": "PropertyValue", name: "HS Code", value: "1301.20" },
    { "@type": "PropertyValue", name: "MOQ", value: "1 FCL (18 MT)" },
    { "@type": "PropertyValue", name: "Origin", value: "Nigeria" },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Products", item: "https://origindirectgroup.com/products" },
    { "@type": "ListItem", position: 3, name: "Gum Arabic", item: "https://origindirectgroup.com/products/gum-arabic" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is gum arabic used for in the food industry?",
      acceptedAnswer: { "@type": "Answer", text: "Gum arabic (E414) is used as an emulsifier in soft drinks (Coca-Cola and Pepsi use it to keep flavor oils suspended), as a stabilizer in confectionery and chewing gum, as a coating for candy and pharmaceutical tablets, and as a foam stabilizer in beer. It accounts for roughly 60% of the global hydrocolloid emulsifier market. Major end-users include beverage companies, confectioners, and pharmaceutical manufacturers." },
    },
    {
      "@type": "Question",
      name: "What grades of gum arabic do you supply?",
      acceptedAnswer: { "@type": "Answer", text: "We supply three primary grades: Acacia senegal (Grade 1, premium, for beverage emulsification), Acacia seyal (Grade 2, for confectionery and adhesives), and spray-dried powder (instant-dissolving, for food processing). All grades meet EU E414 and FDA 21 CFR 184.1330 specifications. We provide Certificates of Analysis showing viscosity, optical rotation, moisture, ash content, and microbiological parameters." },
    },
    {
      "@type": "Question",
      name: "How does Nigerian gum arabic compare to Sudanese?",
      acceptedAnswer: { "@type": "Answer", text: "Sudan historically dominated gum arabic production (70-80% of global supply), but political instability has disrupted supply chains. Nigeria is now a significant alternative source, producing primarily Acacia senegal from the northern savanna belt. Nigerian gum arabic meets the same international quality standards (FAO/WHO JECFA specifications) and offers supply chain diversification for buyers seeking to reduce dependence on Sudanese sources." },
    },
  ],
};
---

<Layout
  title="Gum Arabic Supplier (E414) - Direct from Nigeria | Origin Direct"
  description="Food-grade gum arabic (E414) from Nigeria. Natural emulsifier for beverages, confectionery, pharmaceuticals. Acacia senegal and seyal grades. Bulk supply."
  structuredData={[productSchema, breadcrumbSchema, faqSchema]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Products", href: "/products" }, { label: "Gum Arabic" }]} />
  </div>

  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-brand-900 via-brand-800 to-earth-800 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(196,154,42,0.3),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Direct from Nigeria</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Gum Arabic</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        The world's most important natural emulsifier. Food-grade E414 for beverages, confectionery, and pharmaceutical applications.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Request Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Overview</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          Gum arabic is a natural gum exudate from Acacia trees, classified as food additive E414 in the EU and recognized as GRAS by the FDA. It is the most widely used natural emulsifier in the food and beverage industry, with annual global demand exceeding 120,000 metric tons. Major beverage companies including Coca-Cola and PepsiCo rely on gum arabic to keep flavor oils uniformly suspended in their soft drinks.
        </p>
        <p>
          With ongoing supply disruptions from Sudan (historically 70-80% of global supply), Nigeria has emerged as a critical alternative source. Nigerian gum arabic, harvested from Acacia senegal trees across the northern savanna belt, meets the same FAO/WHO JECFA quality specifications demanded by international buyers and offers genuine supply chain diversification.
        </p>
        <p>
          Origin Direct sources gum arabic from established collection networks across Nigeria's Borno, Yobe, and Jigawa states. We supply raw kibbles, cleaned and graded nodules, and spray-dried powder for instant dissolution. All product meets EU E414 and FDA 21 CFR 184.1330 requirements with full analytical documentation.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Key Specifications</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-brand-800 text-white">
              <th class="px-6 py-4 font-semibold">Parameter</th>
              <th class="px-6 py-4 font-semibold">Specification</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Source</td><td class="px-6 py-4 text-gray-700">Acacia senegal (Grade 1) &amp; Acacia seyal (Grade 2)</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">E Number</td><td class="px-6 py-4 text-gray-700">E414</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Moisture</td><td class="px-6 py-4 text-gray-700">&lt; 15%</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Ash Content</td><td class="px-6 py-4 text-gray-700">&lt; 4%</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Optical Rotation</td><td class="px-6 py-4 text-gray-700">-26&deg; to -34&deg; (A. senegal)</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Forms</td><td class="px-6 py-4 text-gray-700">Raw kibbles, cleaned nodules, spray-dried powder</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">MOQ</td><td class="px-6 py-4 text-gray-700">1 FCL (~18 MT)</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">HS Code</td><td class="px-6 py-4 text-gray-700">1301.20</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((faq) => (
          <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
            <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">{faq.name}</summary>
            <div class="px-6 pb-4 text-gray-700">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <QuoteForm productName="Other (please specify below)" />
</Layout>
