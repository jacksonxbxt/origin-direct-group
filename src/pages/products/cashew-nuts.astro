---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Cashew Nuts",
  description: "Raw cashew nuts (RCN) and processed kernels from Ghana and Nigeria. KOR 48-54 lbs, W180 to W450 grades. EU aflatoxin compliant.",
  image: "https://origindirectgroup.com/images/products/cashew-nuts.jpg",
  brand: { "@type": "Brand", name: "Origin Direct Group" },
  category: "Nuts & Dried Fruits",
  countryOfOrigin: { "@type": "Country", name: "Ghana" },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
  },
  additionalProperty: [
    { "@type": "PropertyValue", name: "HS Code", value: "0801.31 / 0801.32" },
    { "@type": "PropertyValue", name: "MOQ", value: "1 FCL (18 MT)" },
    { "@type": "PropertyValue", name: "Certifications", value: "Phytosanitary, CoA, SGS Inspection" },
    { "@type": "PropertyValue", name: "KOR", value: "48-54 lbs per 80kg bag" },
    { "@type": "PropertyValue", name: "Aflatoxin B1", value: "< 5 ug/kg (EU limit)" },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Products", item: "https://origindirectgroup.com/products" },
    { "@type": "ListItem", position: 3, name: "Cashew Nuts", item: "https://origindirectgroup.com/products/cashew-nuts" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What cashew nut grades do you offer?",
      acceptedAnswer: { "@type": "Answer", text: "We supply Raw Cashew Nuts (RCN) and processed kernels in all standard AFI grades: W180 (King size), W210, W240, W320 (most traded globally), W450, Splits, and Pieces. RCN from Ghana, which controls 43.8% of global in-shell exports." },
    },
    {
      "@type": "Question",
      name: "What is KOR and what are your cashew specs?",
      acceptedAnswer: { "@type": "Answer", text: "KOR (Kernel Outturn Ratio) measures usable kernel per 80kg bag. Our RCN delivers 48-54 lbs KOR. Additional specs: moisture below 10%, nut count 170-210/kg, defective below 10%. For kernels: moisture below 5%, aflatoxin B1 below 5 ug/kg (EU limit)." },
    },
    {
      "@type": "Question",
      name: "What payment terms do you accept for cashew orders?",
      acceptedAnswer: { "@type": "Answer", text: "Standard payment for Raw Cashew Nuts is 100% Irrevocable Letter of Credit (LC) at sight, which is industry norm. For processed kernels, we also accept TT (Telegraphic Transfer) and CAD (Cash Against Documents) for established customers." },
    },
    {
      "@type": "Question",
      name: "What is the difference between W180 and W320 cashew grades?",
      acceptedAnswer: { "@type": "Answer", text: "The W-number indicates kernel count per pound. W180 means 180 kernels per pound (largest, most premium). W320 means 320 per pound (medium, most commonly traded). W180 commands 40-60% higher pricing than W320." },
    },
    {
      "@type": "Question",
      name: "Where do your cashew nuts come from?",
      acceptedAnswer: { "@type": "Answer", text: "Our cashews come from Ghana and Nigeria. Ghana is the world's largest exporter of in-shell cashew nuts, controlling 43.8% of global exports. We work directly with farming cooperatives and collection centers." },
    },
  ],
};
---

<Layout
  title="Cashew Nuts - Raw & Processed from Ghana & Nigeria | Origin Direct"
  description="Raw cashew nuts (RCN) and processed kernels from Ghana and Nigeria. KOR 48-54 lbs, W180 to W450 grades. EU aflatoxin compliant. B2B supply with LC payment terms."
  structuredData={[productSchema, breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Products", href: "/products" }, { label: "Cashew Nuts" }]} />
  </div>

  <!-- Hero -->
  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-brand-900 via-earth-700 to-earth-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_70%,rgba(196,154,42,0.3),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Ghana &amp; Nigeria</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Cashew Nuts</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        Raw cashew nuts and processed kernels from West Africa's leading producing regions. Ghana supplies 43.8% of global in-shell exports.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Request Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- Product Image -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-100">
        <img
          src="/images/products/cashew-nuts.jpg"
          alt="Premium cashew nuts from Ghana and Nigeria"
          class="w-full h-64 sm:h-80 object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Overview</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          West Africa has emerged as the world's largest cashew-producing region, with Ghana alone accounting for 43.8% of global raw cashew nut (RCN) exports. Nigerian cashews complement the supply with competitive pricing and growing production volumes. The region's cashew season runs from February through May, with Origin Direct securing supply contracts well in advance.
        </p>
        <p>
          We supply both raw cashew nuts for processing (primarily to India and Vietnam) and finished kernels in all standard grades from premium W180 "King" cashews to W450 and pieces. Our network of trusted processing partners ensures consistent kernel quality that meets the strict aflatoxin limits required by EU and US importers.
        </p>
        <p>
          Cashew trading has unique payment conventions. For RCN, the standard is 100% Irrevocable Letter of Credit, and our team can guide first-time buyers through the LC process. For processed kernels, we offer more flexible terms depending on the relationship and volume.
        </p>
      </div>
    </div>
  </section>

  <!-- Specifications -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Technical Specifications</h2>

      <h3 class="text-lg font-semibold text-brand-800 mb-4">Raw Cashew Nuts (RCN)</h3>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm mb-8">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-brand-800 text-white">
              <th class="px-6 py-4 font-semibold">Parameter</th>
              <th class="px-6 py-4 font-semibold">Specification</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Kernel Output Ratio (KOR)</td>
              <td class="px-6 py-4 text-gray-700">48 &ndash; 54 lbs per 80 kg bag</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Moisture</td>
              <td class="px-6 py-4 text-gray-700">&lt; 10%</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Nut Count</td>
              <td class="px-6 py-4 text-gray-700">170 &ndash; 210 per kg</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Defective Rate</td>
              <td class="px-6 py-4 text-gray-700">&lt; 10%</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-brand-800 mb-4">Processed Kernels</h3>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-brand-800 text-white">
              <th class="px-6 py-4 font-semibold">Parameter</th>
              <th class="px-6 py-4 font-semibold">Specification</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Moisture</td>
              <td class="px-6 py-4 text-gray-700">&lt; 5%</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Broken Kernels</td>
              <td class="px-6 py-4 text-gray-700">&lt; 5% (for whole grades)</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Aflatoxin B1</td>
              <td class="px-6 py-4 text-gray-700">&lt; 5 &mu;g/kg (EU limit)</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Total Aflatoxin</td>
              <td class="px-6 py-4 text-gray-700">&lt; 10 &mu;g/kg</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Available Grades -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Available Grades</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-brand-800 text-white">
              <th class="px-6 py-4 font-semibold">Grade</th>
              <th class="px-6 py-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Raw Cashew Nuts (RCN)</td>
              <td class="px-6 py-4 text-gray-700">In-shell, for processing. Shipped to India and Vietnam processing hubs.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">W180 (King)</td>
              <td class="px-6 py-4 text-gray-700">Premium jumbo whole kernels. 120&ndash;180 kernels per pound.</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">W210</td>
              <td class="px-6 py-4 text-gray-700">Large whole kernels. 200&ndash;210 per pound. Popular in premium snack markets.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">W240</td>
              <td class="px-6 py-4 text-gray-700">Standard whole. 220&ndash;240 per pound. Good balance of size and value.</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">W320</td>
              <td class="px-6 py-4 text-gray-700">Most traded grade globally. 300&ndash;320 per pound. Industry benchmark.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">W450</td>
              <td class="px-6 py-4 text-gray-700">Smaller whole kernels. 400&ndash;450 per pound. Competitive price point.</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Splits &amp; Pieces</td>
              <td class="px-6 py-4 text-gray-700">For bakeries, confectionery, and cashew butter production. Cost-effective.</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="mt-6 p-4 bg-gold/10 border border-gold/30 rounded-lg">
        <p class="text-sm text-earth-800"><strong>Payment terms:</strong> 100% Irrevocable Letter of Credit is standard for RCN transactions. Flexible terms available for processed kernels.</p>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Certifications &amp; Documentation</h2>
      <p class="text-gray-700 mb-8">Complete documentation for smooth customs clearance and regulatory compliance.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          "Phytosanitary Certificate",
          "Certificate of Origin",
          "Fumigation Certificate",
          "SGS Inspection (available)",
          "Bureau Veritas Inspection (available)",
          "Certificate of Analysis (CoA)",
        ].map((cert) => (
          <div class="flex items-start gap-3 bg-white rounded-lg p-4 border border-gray-200">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm font-medium text-gray-800">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Packaging & Shipping -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Packaging &amp; Shipping</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Packaging Options</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>80 kg jute bags (RCN &mdash; industry standard)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>50 lb vacuum-packed cartons (processed kernels)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>Nitrogen-flushed packaging available for extended shelf life</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Key Markets &amp; Transit</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>India &amp; Vietnam</strong> &mdash; RCN processing hubs</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>EU</strong> &mdash; Rotterdam, Hamburg (kernels)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>USA</strong> &mdash; New York, Los Angeles (kernels)</span>
            </li>
          </ul>
          <p class="text-sm text-gray-500 mt-4">FOB Tema/Lagos. Season: Feb&ndash;May (RCN). Processed kernels available year-round.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What cashew nut grades do you offer?</summary>
          <div class="px-6 pb-4 text-gray-700">We supply Raw Cashew Nuts (RCN) and processed kernels in all standard AFI grades: W180 (King size), W210, W240, W320 (most traded globally), W450, Splits, and Pieces. RCN from Ghana, which controls 43.8% of global in-shell exports.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What is KOR and what are your cashew specs?</summary>
          <div class="px-6 pb-4 text-gray-700">KOR (Kernel Outturn Ratio) measures usable kernel per 80kg bag. Our RCN delivers 48-54 lbs KOR. Additional specs: moisture below 10%, nut count 170-210/kg, defective below 10%. For kernels: moisture below 5%, aflatoxin B1 below 5 ug/kg (EU limit).</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What payment terms do you accept for cashew orders?</summary>
          <div class="px-6 pb-4 text-gray-700">Standard payment for Raw Cashew Nuts is 100% Irrevocable Letter of Credit (LC) at sight, which is industry norm. For processed kernels, we also accept TT (Telegraphic Transfer) and CAD (Cash Against Documents) for established customers.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What is the difference between W180 and W320 cashew grades?</summary>
          <div class="px-6 pb-4 text-gray-700">The W-number indicates kernel count per pound. W180 means 180 kernels per pound (largest, most premium). W320 means 320 per pound (medium, most commonly traded). W180 commands 40-60% higher pricing than W320.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">Where do your cashew nuts come from?</summary>
          <div class="px-6 pb-4 text-gray-700">Our cashews come from Ghana and Nigeria. Ghana is the world's largest exporter of in-shell cashew nuts, controlling 43.8% of global exports. We work directly with farming cooperatives and collection centers.</div>
        </details>
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <QuoteForm productName="Cashew Nuts" />
</Layout>
