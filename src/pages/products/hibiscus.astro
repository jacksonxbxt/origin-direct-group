---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Dried Hibiscus Flowers",
  description: "Premium dried hibiscus flowers from Nigeria, the world's largest producer. Grade A dark red, whole flowers and cut & sifted. NAQS-SENASICA compliant for Mexico trade.",
  image: "https://origindirectgroup.com/images/products/hibiscus.jpg",
  brand: { "@type": "Brand", name: "Origin Direct Group" },
  category: "Dried Flowers & Herbal Ingredients",
  countryOfOrigin: { "@type": "Country", name: "Nigeria" },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
  },
  additionalProperty: [
    { "@type": "PropertyValue", name: "HS Code", value: "0902.10 / 1211.90" },
    { "@type": "PropertyValue", name: "MOQ", value: "1 FCL (up to 22 MT)" },
    { "@type": "PropertyValue", name: "Certifications", value: "NAQS-SENASICA Protocol, Phytosanitary, Fumigation Certificate" },
    { "@type": "PropertyValue", name: "Moisture", value: "< 11%" },
    { "@type": "PropertyValue", name: "Foreign Matter", value: "< 1%" },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Products", item: "https://origindirectgroup.com/products" },
    { "@type": "ListItem", position: 3, name: "Dried Hibiscus Flowers", item: "https://origindirectgroup.com/products/hibiscus" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Is Nigeria the world's largest hibiscus producer?",
      acceptedAnswer: { "@type": "Answer", text: "Yes. Nigeria is the world's largest producer and exporter of dried hibiscus flowers (Roselle/Hibiscus sabdariffa). Nigerian hibiscus supplies 85% of Mexico's imports for agua de jamaica, plus significant volumes to Germany, Egypt, and the USA." },
    },
    {
      "@type": "Question",
      name: "What are the quality specs for dried hibiscus?",
      acceptedAnswer: { "@type": "Answer", text: "Our dried hibiscus flowers meet: moisture below 11%, foreign matter below 1%, deep red/burgundy color, pH 2.5-3.5, no artificial coloring, pesticide residues within MRL limits. Available as whole flowers, cut and sifted, or powder." },
    },
    {
      "@type": "Question",
      name: "Can you export hibiscus to Mexico?",
      acceptedAnswer: { "@type": "Answer", text: "Yes. We are fully compliant with the NAQS-SENASICA protocol signed in 2022 that reopened Nigeria-Mexico hibiscus trade (banned 2017-2022 due to khapra beetle). We provide methyl bromide fumigation certificates as required by Mexico." },
    },
    {
      "@type": "Question",
      name: "What is dried hibiscus used for?",
      acceptedAnswer: { "@type": "Answer", text: "Dried hibiscus is used globally for beverages (agua de jamaica in Mexico, karkade in Middle East, sorrel in Caribbean), herbal tea blends, natural food coloring (E163), dietary supplements (high in vitamin C and antioxidants), and cosmetic extracts." },
    },
    {
      "@type": "Question",
      name: "How much does wholesale dried hibiscus cost?",
      acceptedAnswer: { "@type": "Answer", text: "Indicative pricing: $1,800-3,400/MT FOB Lagos depending on grade, season, and volume. Whole Grade A flowers command the highest price. Cut and sifted is 15-20% less. Organic certified adds 20-30% premium." },
    },
  ],
};
---

<Layout
  title="Dried Hibiscus Flowers - Nigeria's #1 Export | Origin Direct"
  description="Premium dried hibiscus flowers from Nigeria, the world's largest producer. Grade A dark red, whole flowers and cut & sifted. NAQS-SENASICA compliant for Mexico trade."
  structuredData={[productSchema, breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Products", href: "/products" }, { label: "Dried Hibiscus Flowers" }]} />
  </div>

  <!-- Hero -->
  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-brand-900 via-[#5a1a2a] to-earth-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_40%_60%,rgba(196,154,42,0.3),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Nigeria &mdash; World's Largest Producer</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Dried Hibiscus Flowers</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        From agua de jamaica in Mexico to karkade in Egypt and sorrel in the Caribbean &mdash; our hibiscus serves the world's top beverage markets.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Request Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- Product Image -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-100">
        <img
          src="/images/products/hibiscus.jpg"
          alt="Dried hibiscus flowers from Nigeria"
          class="w-full h-64 sm:h-80 object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Overview</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          Nigeria is the world's largest producer of dried hibiscus flowers (<em>Hibiscus sabdariffa</em>), and the commodity is deeply woven into global beverage culture. In Mexico, it is brewed as agua de jamaica &mdash; one of the country's most popular drinks. In Egypt and the Middle East, it is served as karkade. In the Caribbean, it becomes sorrel, a festive staple. And across Europe, it is a key ingredient in herbal tea blends and natural food coloring.
        </p>
        <p>
          Origin Direct supplies premium Nigerian hibiscus directly from the northern growing regions where the dry climate produces flowers with deep red color and high acidity &mdash; the two quality markers that matter most to buyers. We work closely with aggregators who sort and grade to our specifications, ensuring clean, consistent product with minimal foreign matter.
        </p>
        <p>
          For the critical Mexico market (the world's largest buyer), we are fully compliant with the NAQS-SENASICA protocol, including required methyl bromide fumigation. Our documentation and quality control processes are built specifically around the regulatory requirements of each destination market.
        </p>
      </div>
    </div>
  </section>

  <!-- Specifications -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Technical Specifications</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-brand-800 text-white">
              <th class="px-6 py-4 font-semibold">Parameter</th>
              <th class="px-6 py-4 font-semibold">Specification</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Moisture</td>
              <td class="px-6 py-4 text-gray-700">&lt; 11%</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Foreign Matter</td>
              <td class="px-6 py-4 text-gray-700">&lt; 1%</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Color</td>
              <td class="px-6 py-4 text-gray-700">Deep red / burgundy</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Acidity (pH)</td>
              <td class="px-6 py-4 text-gray-700">2.5 &ndash; 3.5</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Artificial Coloring</td>
              <td class="px-6 py-4 text-gray-700">None</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Pesticide Residues</td>
              <td class="px-6 py-4 text-gray-700">Within MRL (Maximum Residue Levels)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Available Grades -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Available Grades</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-brand-800 text-white">
              <th class="px-6 py-4 font-semibold">Grade</th>
              <th class="px-6 py-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Whole Dried Flowers &mdash; Grade A</td>
              <td class="px-6 py-4 text-gray-700">Dark red, large calyces. Premium appearance. Preferred for agua de jamaica and karkade.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Cut &amp; Sifted</td>
              <td class="px-6 py-4 text-gray-700">Tea-grade cut. Ideal for tea bags, herbal blends, and infusion products.</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Powder</td>
              <td class="px-6 py-4 text-gray-700">Finely ground. Used in supplements, food coloring, and instant beverage mixes.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Organic Certified</td>
              <td class="px-6 py-4 text-gray-700">Available in whole flower and cut &amp; sifted formats. For organic product lines.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Certifications &amp; Documentation</h2>
      <p class="text-gray-700 mb-8">Comprehensive documentation tailored to the regulatory requirements of each destination market.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          "Phytosanitary Certificate (NAQS)",
          "Fumigation Certificate (methyl bromide)",
          "Certificate of Origin",
          "Organic Certification (available)",
          "NAQS-SENASICA Protocol Compliance",
          "Certificate of Analysis (CoA)",
        ].map((cert) => (
          <div class="flex items-start gap-3 bg-white rounded-lg p-4 border border-gray-200">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm font-medium text-gray-800">{cert}</span>
          </div>
        ))}
      </div>
      <div class="mt-6 p-4 bg-gold/10 border border-gold/30 rounded-lg">
        <p class="text-sm text-earth-800"><strong>Mexico trade:</strong> Methyl bromide fumigation is mandatory for hibiscus imports into Mexico. We include this in all Mexico-bound shipments as standard.</p>
      </div>
    </div>
  </section>

  <!-- Packaging & Shipping -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Packaging &amp; Shipping</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Packaging Options</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>25 kg polypropylene bags</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>50 kg bales</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>Compressed bales for maximum container utilization</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Key Markets &amp; Transit</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>Mexico</strong> &mdash; Largest global buyer (agua de jamaica)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>Germany</strong> &mdash; Herbal tea market</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>Egypt, USA, Caribbean</strong> &mdash; Karkade, sorrel</span>
            </li>
          </ul>
          <p class="text-sm text-gray-500 mt-4">FOB Lagos. Compressed bales optimize shipping costs &mdash; up to 22 MT per 20&rsquo; container.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">Is Nigeria the world's largest hibiscus producer?</summary>
          <div class="px-6 pb-4 text-gray-700">Yes. Nigeria is the world's largest producer and exporter of dried hibiscus flowers (Roselle/Hibiscus sabdariffa). Nigerian hibiscus supplies 85% of Mexico's imports for agua de jamaica, plus significant volumes to Germany, Egypt, and the USA.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What are the quality specs for dried hibiscus?</summary>
          <div class="px-6 pb-4 text-gray-700">Our dried hibiscus flowers meet: moisture below 11%, foreign matter below 1%, deep red/burgundy color, pH 2.5-3.5, no artificial coloring, pesticide residues within MRL limits. Available as whole flowers, cut and sifted, or powder.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">Can you export hibiscus to Mexico?</summary>
          <div class="px-6 pb-4 text-gray-700">Yes. We are fully compliant with the NAQS-SENASICA protocol signed in 2022 that reopened Nigeria-Mexico hibiscus trade (banned 2017-2022 due to khapra beetle). We provide methyl bromide fumigation certificates as required by Mexico.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What is dried hibiscus used for?</summary>
          <div class="px-6 pb-4 text-gray-700">Dried hibiscus is used globally for beverages (agua de jamaica in Mexico, karkade in Middle East, sorrel in Caribbean), herbal tea blends, natural food coloring (E163), dietary supplements (high in vitamin C and antioxidants), and cosmetic extracts.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">How much does wholesale dried hibiscus cost?</summary>
          <div class="px-6 pb-4 text-gray-700">Indicative pricing: $1,800-3,400/MT FOB Lagos depending on grade, season, and volume. Whole Grade A flowers command the highest price. Cut and sifted is 15-20% less. Organic certified adds 20-30% premium.</div>
        </details>
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <QuoteForm productName="Hibiscus" />
</Layout>
