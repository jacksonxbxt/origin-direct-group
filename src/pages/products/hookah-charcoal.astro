---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Hookah Charcoal",
  description: "Premium hookah charcoal from Nigerian acacia hardwood. Fixed carbon > 85%, 90+ minute burn time. Halal certified. OEM/private label available.",
  image: "https://origindirectgroup.com/images/products/hookah-charcoal.jpg",
  brand: { "@type": "Brand", name: "Origin Direct Group" },
  category: "Hookah & Shisha Accessories",
  countryOfOrigin: { "@type": "Country", name: "Nigeria" },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
  },
  additionalProperty: [
    { "@type": "PropertyValue", name: "HS Code", value: "4402.90" },
    { "@type": "PropertyValue", name: "MOQ", value: "1 FCL (18-22 MT)" },
    { "@type": "PropertyValue", name: "Certifications", value: "Halal, SGS, MSDS, UN3088 Self-Heating Test" },
    { "@type": "PropertyValue", name: "Fixed Carbon", value: "> 85%" },
    { "@type": "PropertyValue", name: "Burn Time", value: "90+ minutes" },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Products", item: "https://origindirectgroup.com/products" },
    { "@type": "ListItem", position: 3, name: "Hookah Charcoal", item: "https://origindirectgroup.com/products/hookah-charcoal" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What are the specifications for your hookah charcoal?",
      acceptedAnswer: { "@type": "Answer", text: "Our premium hookah charcoal specs: fixed carbon above 85%, ash content below 2.5%, moisture below 5%, burn time 90+ minutes, volatile matter below 15%. Zero sulfur, zero chemical additives, odorless and tasteless. Made from Nigerian acacia hardwood." },
    },
    {
      "@type": "Question",
      name: "Do you offer OEM/private label hookah charcoal?",
      acceptedAnswer: { "@type": "Answer", text: "Yes. We produce custom-branded hookah charcoal with your logo and packaging design. Available in 25mm cubes (global standard), 22mm cubes, flat/disc, finger, and hexagonal shapes. Custom shapes available for orders above 5 FCL." },
    },
    {
      "@type": "Question",
      name: "Is your charcoal halal certified?",
      acceptedAnswer: { "@type": "Answer", text: "Yes. Our hookah charcoal is halal certified. We also provide SGS lab testing reports, MSDS (Material Safety Data Sheet), and Self-Heating Test documentation required for UN3088 classification shipping." },
    },
    {
      "@type": "Question",
      name: "How does Nigerian charcoal compare to Indonesian coconut charcoal?",
      acceptedAnswer: { "@type": "Answer", text: "Nigerian acacia hardwood charcoal is 60-80% cheaper than Indonesian coconut charcoal at origin. It produces the same premium aroma profile as Somali charcoal (under UN embargo since 2012). FOB Nigeria: $260-500/ton vs Indonesian coconut: $1,250-1,500/ton." },
    },
    {
      "@type": "Question",
      name: "What is the minimum order for hookah charcoal?",
      acceptedAnswer: { "@type": "Answer", text: "Minimum order is 1 FCL (20ft container), approximately 18-22 metric tons. Packaging: 10kg or 20kg master cartons, palletized. We can ship LCL (Less than Container Load) for trial orders starting at 1 ton." },
    },
  ],
};
---

<Layout
  title="Premium Hookah Charcoal - Nigerian Hardwood | Origin Direct"
  description="Premium hookah charcoal from Nigerian acacia hardwood. Fixed carbon > 85%, 90+ minute burn time. Halal certified. OEM/private label available. B2B supply to Middle East, EU, USA."
  structuredData={[productSchema, breadcrumbSchema, faqSchema]}
>
  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Products", href: "/products" }, { label: "Hookah Charcoal" }]} />
  </div>

  <!-- Hero -->
  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-gray-900 via-earth-900 to-brand-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_60%_40%,rgba(196,154,42,0.3),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Nigerian Hardwood</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Hookah Charcoal</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        Premium acacia hardwood charcoal with 90+ minute burn time. The same aroma profile as Somali charcoal at a fraction of the cost.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Request Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- Product Image -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-100">
        <img
          src="/images/products/hookah-charcoal.jpg"
          alt="Premium hookah charcoal from Nigerian hardwood"
          class="w-full h-64 sm:h-80 object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Overview</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          The global hookah charcoal market has grown substantially as shisha culture expands across the Middle East, Europe, and North America. Discerning buyers know that charcoal quality directly affects the smoking experience &mdash; poor charcoal ruins even the best tobacco. Nigerian acacia hardwood produces charcoal with the same premium aroma profile once associated exclusively with Somali charcoal (under UN embargo since 2012).
        </p>
        <p>
          Origin Direct sources from established carbonization facilities in Nigeria that produce consistent, high-carbon charcoal with minimal ash and no chemical additives. Our charcoal is 100% natural hardwood, odorless and tasteless when lit, allowing the full flavor of the tobacco to come through. At 60&ndash;80% cheaper than Indonesian coconut charcoal, it offers an unbeatable value proposition.
        </p>
        <p>
          We offer OEM and private label services, producing charcoal in your branded packaging with custom shapes and sizes. Whether you are a distributor, wholesaler, or hookah lounge chain, we can tailor the product to your exact specifications.
        </p>
      </div>
    </div>
  </section>

  <!-- Specifications -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Technical Specifications</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-gray-800 text-white">
              <th class="px-6 py-4 font-semibold">Parameter</th>
              <th class="px-6 py-4 font-semibold">Specification</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Fixed Carbon</td>
              <td class="px-6 py-4 text-gray-700">&gt; 85%</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Ash Content</td>
              <td class="px-6 py-4 text-gray-700">&lt; 2.5%</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Moisture</td>
              <td class="px-6 py-4 text-gray-700">&lt; 5%</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Burn Time</td>
              <td class="px-6 py-4 text-gray-700">90+ minutes</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Volatile Matter</td>
              <td class="px-6 py-4 text-gray-700">&lt; 15%</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Sulfur / Chemical Additives</td>
              <td class="px-6 py-4 text-gray-700">None &mdash; 100% natural hardwood</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Odor &amp; Taste</td>
              <td class="px-6 py-4 text-gray-700">Odorless and tasteless when lit</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="mt-6 p-4 bg-gold/10 border border-gold/30 rounded-lg">
        <p class="text-sm text-earth-800"><strong>Competitive advantage:</strong> Nigerian acacia hardwood produces the same premium aroma profile as Somali charcoal (under UN embargo since 2012), at 60&ndash;80% less than Indonesian coconut charcoal.</p>
      </div>
    </div>
  </section>

  <!-- Available Grades -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Available Shapes &amp; Sizes</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-gray-800 text-white">
              <th class="px-6 py-4 font-semibold">Shape</th>
              <th class="px-6 py-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Cube 25mm</td>
              <td class="px-6 py-4 text-gray-700">Global standard for hookah. Fits all standard bowls and heat management devices.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Cube 22mm</td>
              <td class="px-6 py-4 text-gray-700">Compact cube for smaller bowls and precise heat control.</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Flat / Disc</td>
              <td class="px-6 py-4 text-gray-700">Traditional shape popular in Middle Eastern markets.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Finger Shape</td>
              <td class="px-6 py-4 text-gray-700">Elongated shape for even heat distribution.</td>
            </tr>
            <tr class="bg-white">
              <td class="px-6 py-4 font-medium text-gray-900">Hexagonal</td>
              <td class="px-6 py-4 text-gray-700">Unique shape with increased surface area for consistent burning.</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Custom Shapes (OEM)</td>
              <td class="px-6 py-4 text-gray-700">Private label with your branding. Custom molds available for unique shapes.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Certifications &amp; Documentation</h2>
      <p class="text-gray-700 mb-8">Full documentation for import compliance and retail distribution.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          "Halal Certification",
          "SGS Lab Testing Report",
          "MSDS / Safety Data Sheet",
          "Self-Heating Test (UN3088)",
          "Certificate of Origin",
          "Customs Classification Documentation",
        ].map((cert) => (
          <div class="flex items-start gap-3 bg-white rounded-lg p-4 border border-gray-200">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm font-medium text-gray-800">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Packaging & Shipping -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Packaging &amp; Shipping</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Packaging Options</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>10 kg master cartons (retail-ready)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>20 kg cartons (wholesale / HoReCa)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>Custom branded packaging (OEM / private label)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 mt-1">&#8226;</span>
              <span>Palletized for efficient container loading</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-brand-800 mb-4">Key Markets &amp; Transit</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>Gulf States</strong> &mdash; Dubai, Kuwait, Qatar, Jeddah</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>Turkey</strong> &mdash; Istanbul, Mersin</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-1">&#9654;</span>
              <span><strong>EU &amp; USA</strong> &mdash; Germany, New York</span>
            </li>
          </ul>
          <p class="text-sm text-gray-500 mt-4">FOB Lagos. UN3088 classified &mdash; shipped as self-heating substance. We handle all export documentation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What are the specifications for your hookah charcoal?</summary>
          <div class="px-6 pb-4 text-gray-700">Our premium hookah charcoal specs: fixed carbon above 85%, ash content below 2.5%, moisture below 5%, burn time 90+ minutes, volatile matter below 15%. Zero sulfur, zero chemical additives, odorless and tasteless. Made from Nigerian acacia hardwood.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">Do you offer OEM/private label hookah charcoal?</summary>
          <div class="px-6 pb-4 text-gray-700">Yes. We produce custom-branded hookah charcoal with your logo and packaging design. Available in 25mm cubes (global standard), 22mm cubes, flat/disc, finger, and hexagonal shapes. Custom shapes available for orders above 5 FCL.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">Is your charcoal halal certified?</summary>
          <div class="px-6 pb-4 text-gray-700">Yes. Our hookah charcoal is halal certified. We also provide SGS lab testing reports, MSDS (Material Safety Data Sheet), and Self-Heating Test documentation required for UN3088 classification shipping.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">How does Nigerian charcoal compare to Indonesian coconut charcoal?</summary>
          <div class="px-6 pb-4 text-gray-700">Nigerian acacia hardwood charcoal is 60-80% cheaper than Indonesian coconut charcoal at origin. It produces the same premium aroma profile as Somali charcoal (under UN embargo since 2012). FOB Nigeria: $260-500/ton vs Indonesian coconut: $1,250-1,500/ton.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">What is the minimum order for hookah charcoal?</summary>
          <div class="px-6 pb-4 text-gray-700">Minimum order is 1 FCL (20ft container), approximately 18-22 metric tons. Packaging: 10kg or 20kg master cartons, palletized. We can ship LCL (Less than Container Load) for trial orders starting at 1 ton.</div>
        </details>
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <QuoteForm productName="Hookah Charcoal" />
</Layout>
