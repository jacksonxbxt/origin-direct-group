---
import Layout from '../layouts/Layout.astro';
import QuoteForm from '../components/QuoteForm.astro';
---

<Layout
  title="About Origin Direct Group - Direct Commodity Sourcing"
  description="Origin Direct Group connects global commodity buyers with verified producers across West Africa and India. We eliminate the middlemen and deliver quality commodities at competitive prices."
>

  <!-- Hero -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-950 via-green-900 to-amber-950"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6">
        Cutting Out The Middlemen
      </h1>
      <p class="text-lg md:text-xl text-green-100/90 max-w-2xl mx-auto leading-relaxed">
        Direct relationships with producers mean better prices, full traceability, and consistent quality for your business.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Our Story -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Story</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed space-y-6">
        <p>
          Origin Direct Group connects global commodity buyers with verified producers across West Africa and India.
          We eliminate the middlemen &mdash; the European processors, Asian intermediaries, and traders who inflate
          costs by 30&ndash;300% &mdash; by maintaining direct relationships with farmers, cooperatives, and producers
          on the ground.
        </p>
        <p>
          Our teams in Ghana, Nigeria, and India handle everything from sourcing and quality control to export
          documentation and logistics. When you work with us, you get the product directly from the people who
          grow and process it &mdash; with full traceability and documentation at every step.
        </p>
      </div>
    </div>
  </section>

  <!-- Our Presence -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Presence</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Ghana -->
        <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
          <div class="text-3xl mb-4">🇬🇭</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Ghana</h3>
          <ul class="space-y-3 text-gray-600">
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
              <span>Accra office &mdash; central coordination</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
              <span>Cocoa belt &mdash; Ashanti &amp; Western regions</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
              <span>Cashew regions &mdash; Brong-Ahafo &amp; Northern</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
              <span>Shea belt &mdash; Upper East &amp; Upper West</span>
            </li>
          </ul>
        </div>

        <!-- Nigeria -->
        <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
          <div class="text-3xl mb-4">🇳🇬</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Nigeria</h3>
          <ul class="space-y-3 text-gray-600">
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
              <span>Lagos operations &mdash; export hub</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
              <span>Northern agri belt &mdash; sesame, hibiscus, ginger</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
              <span>Export ports &mdash; Apapa &amp; Tin Can Island</span>
            </li>
          </ul>
        </div>

        <!-- India -->
        <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
          <div class="text-3xl mb-4">🇮🇳</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">India</h3>
          <ul class="space-y-3 text-gray-600">
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
              <span>Sourcing network for spices</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
              <span>Castor oil &amp; derivatives</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-2 flex-shrink-0"></span>
              <span>Guar gum sourcing</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- From Soil to Your Door -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">From Soil to Your Door</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          We handle every step of the supply chain so you can focus on your business. Here is exactly what we manage.
        </p>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full mt-4"></div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Step 1 -->
        <div class="relative bg-green-50/50 rounded-2xl p-6 border border-green-100">
          <div class="inline-flex items-center justify-center w-10 h-10 bg-green-700 text-white font-bold rounded-full mb-4 text-sm">1</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Farm Sourcing</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-1.5 flex-shrink-0"></span>
              <span>Producer relationship management</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-1.5 flex-shrink-0"></span>
              <span>On-site quality inspection</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-1.5 flex-shrink-0"></span>
              <span>Sample collection and approval</span>
            </li>
          </ul>
        </div>

        <!-- Step 2 -->
        <div class="relative bg-green-50/50 rounded-2xl p-6 border border-green-100">
          <div class="inline-flex items-center justify-center w-10 h-10 bg-green-700 text-white font-bold rounded-full mb-4 text-sm">2</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Quality &amp; Compliance</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-1.5 flex-shrink-0"></span>
              <span>Independent lab testing</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-1.5 flex-shrink-0"></span>
              <span>Certification (organic, fair trade, halal)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-1.5 flex-shrink-0"></span>
              <span>Certificate of Analysis issued</span>
            </li>
          </ul>
        </div>

        <!-- Step 3 -->
        <div class="relative bg-green-50/50 rounded-2xl p-6 border border-green-100">
          <div class="inline-flex items-center justify-center w-10 h-10 bg-green-700 text-white font-bold rounded-full mb-4 text-sm">3</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Export &amp; Freight</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-1.5 flex-shrink-0"></span>
              <span>Phytosanitary &amp; certificate of origin</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-1.5 flex-shrink-0"></span>
              <span>Container loading supervision</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-1.5 flex-shrink-0"></span>
              <span>Bill of lading &amp; freight booking</span>
            </li>
          </ul>
        </div>

        <!-- Step 4 -->
        <div class="relative bg-green-50/50 rounded-2xl p-6 border border-green-100">
          <div class="inline-flex items-center justify-center w-10 h-10 bg-green-700 text-white font-bold rounded-full mb-4 text-sm">4</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Delivery</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-1.5 flex-shrink-0"></span>
              <span>Ocean freight tracking</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-1.5 flex-shrink-0"></span>
              <span>Destination customs documentation</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full mt-1.5 flex-shrink-0"></span>
              <span>Last-mile delivery coordination</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-12 text-center">
        <p class="text-gray-600 max-w-2xl mx-auto">
          Whether you need FOB, CIF, or DDP terms &mdash; we adapt to your requirements and handle every document, inspection, and logistics step between the farm and your warehouse.
        </p>
      </div>
    </div>
  </section>

  <!-- What Makes Us Different -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">What Makes Us Different</h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
        <!-- People on the Ground -->
        <div class="bg-green-50/50 rounded-2xl p-8 lg:p-10 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-green-100 text-green-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">People on the Ground</h3>
          <p class="text-gray-600 leading-relaxed">
            We don't broker from a desk. Our local teams visit farms, inspect warehouses, and supervise loading.
            Every shipment has eyes on it from origin to port.
          </p>
        </div>

        <!-- Full Documentation -->
        <div class="bg-green-50/50 rounded-2xl p-8 lg:p-10 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-green-100 text-green-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Full Documentation</h3>
          <p class="text-gray-600 leading-relaxed">
            Certificate of Analysis, phytosanitary certificates, certificates of origin, lab reports, shipping
            docs &mdash; everything your customs broker needs, included with every shipment.
          </p>
        </div>

        <!-- Flexible Terms -->
        <div class="bg-green-50/50 rounded-2xl p-8 lg:p-10 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-green-100 text-green-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Flexible Terms</h3>
          <p class="text-gray-600 leading-relaxed">
            FOB, CIF, or DDP. Letter of Credit, TT, or CAD. We work with your preferred terms and adapt
            to your business needs.
          </p>
        </div>

        <!-- Quality Guarantee -->
        <div class="bg-green-50/50 rounded-2xl p-8 lg:p-10 border border-green-100">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-green-100 text-green-700 rounded-xl mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Quality Guarantee</h3>
          <p class="text-gray-600 leading-relaxed">
            Every shipment is independently tested. If it doesn't meet specs, we make it right. No excuses,
            no runarounds.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA / Quote Section -->
  <section class="py-20 md:py-28 bg-green-950">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Ready to Source Directly?</h2>
        <p class="text-lg text-green-200/80 max-w-xl mx-auto">
          Get a competitive quote within 2 hours. Our team is ready to help.
        </p>
      </div>
      <QuoteForm />
    </div>
  </section>

</Layout>
