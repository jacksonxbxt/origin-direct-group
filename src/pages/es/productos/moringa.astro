---
import Layout from '../../../layouts/Layout.astro';
import QuoteForm from '../../../components/QuoteForm.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';

const siteUrl = "https://origindirectgroup.com";

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Polvo de Moringa Organico",
  description: "Polvo de moringa certificado USDA y EU Organic de Ghana y Nigeria. 25-30% de proteinas, grado farmaceutico disponible.",
  image: `${siteUrl}/images/products/moringa.jpg`,
  brand: { "@type": "Brand", name: "Origin Direct Group" },
  category: "Superalimentos y Suplementos",
  countryOfOrigin: { "@type": "Country", name: "Ghana" },
  offers: { "@type": "AggregateOffer", priceCurrency: "USD", availability: "https://schema.org/InStock" },
  additionalProperty: [
    { "@type": "PropertyValue", name: "Codigo SA", value: "1211.90" },
    { "@type": "PropertyValue", name: "CMC", value: "1 TM (convencional), 500 kg (organico)" },
    { "@type": "PropertyValue", name: "Proteinas", value: "25-30%" },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: `${siteUrl}/es/` },
    { "@type": "ListItem", position: 2, name: "Productos", item: `${siteUrl}/es/productos` },
    { "@type": "ListItem", position: 3, name: "Moringa", item: `${siteUrl}/es/productos/moringa` },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Su moringa esta certificada como organica?",
      acceptedAnswer: { "@type": "Answer", text: "Si. Ofrecemos polvo de moringa certificado USDA Organic y EU Organic. Nuestras instalaciones cuentan con certificaciones HACCP y GMP. Los documentos de certificacion se entregan con cada embarque." },
    },
    {
      "@type": "Question",
      name: "Cuales son las especificaciones de calidad?",
      acceptedAnswer: { "@type": "Answer", text: "Proteinas 25-30%, hierro 25-30 mg/100g, calcio 2.000+ mg/100g, plomo inferior a 0,3 mg/kg, cadmio inferior a 0,2 mg/kg, recuento total inferior a 10.000 UFC/g, E. coli ausente, Salmonella ausente por 25g. Granulometria 80-100 mesh." },
    },
    {
      "@type": "Question",
      name: "Cual es la cantidad minima de pedido?",
      acceptedAnswer: { "@type": "Answer", text: "A partir de 1 TM para el convencional y 500 kg para el organico. Empaque en bolsas de 5, 10 o 25 kg al vacio. Etiquetado personalizado a partir de 5 TM." },
    },
  ],
};
---

<Layout
  title="Polvo de Moringa Organico - Ghana y Nigeria | Origin Direct"
  description="Polvo de moringa certificado USDA y EU Organic de Ghana y Nigeria. 25-30% de proteinas. Grado farmaceutico disponible. Precios B2B competitivos."
  structuredData={[productSchema, breadcrumbSchema, faqSchema]}
  lang="es"
  hreflangs={[
    { lang: "en", href: `${siteUrl}/products/moringa` },
    { lang: "fr", href: `${siteUrl}/fr/produits/moringa` },
    { lang: "es", href: `${siteUrl}/es/productos/moringa` },
  ]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Productos", href: "/es/productos" }, { label: "Moringa" }]} />
  </div>

  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-green-900 via-brand-800 to-brand-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(196,154,42,0.3),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Ghana y Nigeria</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Polvo de Moringa</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        Polvo de hojas de moringa certificado organico para los mercados de alimentos saludables, suplementos y cosmeticos.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Solicitar Cotizacion
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-100">
        <img src="/images/products/moringa.jpg" alt="Polvo de moringa organico de Ghana y Nigeria" class="w-full h-64 sm:h-80 object-cover" loading="eager" />
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Resumen</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          La moringa (Moringa oleifera) es uno de los superalimentos de mas rapido crecimiento en el mundo, con un mercado global en plena expansion impulsado por la demanda de suplementos alimenticios, alimentos funcionales e ingredientes cosmeticos naturales. Las hojas de moringa contienen 25-30% de proteinas, 7 veces mas vitamina C que las naranjas y 4 veces mas calcio que la leche.
        </p>
        <p>
          Origin Direct se abastece de moringa en plantaciones certificadas de Ghana y Nigeria, donde las condiciones tropicales permiten produccion durante todo el ano. Cada lote se analiza en laboratorio para metales pesados, carga microbiana y salmonela. Ofrecemos polvo convencional, certificado organico (USDA y EU Organic) y de grado farmaceutico, empacado al vacio en bolsas alimentarias de 5, 10 o 25 kg.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Especificaciones Tecnicas</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead><tr class="bg-brand-800 text-white"><th class="px-6 py-4 font-semibold">Parametro</th><th class="px-6 py-4 font-semibold">Especificacion</th></tr></thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Proteinas</td><td class="px-6 py-4 text-gray-700">25-30%</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Hierro</td><td class="px-6 py-4 text-gray-700">25-30 mg/100g</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Calcio</td><td class="px-6 py-4 text-gray-700">2.000+ mg/100g</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Plomo</td><td class="px-6 py-4 text-gray-700">&lt; 0,3 mg/kg</td></tr>
            <tr class="bg-white"><td class="px-6 py-4 font-medium text-gray-900">Granulometria</td><td class="px-6 py-4 text-gray-700">80-100 mesh</td></tr>
            <tr class="bg-gray-50"><td class="px-6 py-4 font-medium text-gray-900">Salmonella</td><td class="px-6 py-4 text-gray-700">Ausente / 25g</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Preguntas Frecuentes</h2>
      <div class="space-y-4">
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">Su moringa esta certificada como organica?</summary>
          <div class="px-6 pb-4 text-gray-700">Si. Certificada USDA Organic y EU Organic. Instalaciones con HACCP y GMP. Documentos de certificacion incluidos con cada embarque.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">Cual es la cantidad minima de pedido?</summary>
          <div class="px-6 pb-4 text-gray-700">A partir de 1 TM para convencional y 500 kg para organico. Empaque en bolsas de 5, 10 o 25 kg al vacio. Etiquetado personalizado a partir de 5 TM.</div>
        </details>
        <details class="bg-white rounded-xl border border-gray-200 shadow-sm">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-900 hover:text-brand-700 transition-colors">Es seguro el polvo de moringa para consumo?</summary>
          <div class="px-6 pb-4 text-gray-700">Si. La Moringa oleifera no esta clasificada como Novel Food en la UE y puede venderse libremente. Nuestro moringa se analiza para metales pesados, microbiologia y pesticidas conforme a estandares internacionales.</div>
        </details>
      </div>
    </div>
  </section>

  <QuoteForm productName="Moringa" />
</Layout>
