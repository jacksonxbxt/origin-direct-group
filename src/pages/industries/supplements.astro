---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Industries", item: "https://origindirectgroup.com/industries" },
    { "@type": "ListItem", position: 3, name: "Supplements", item: "https://origindirectgroup.com/industries/supplements" },
  ],
};

const products = [
  {
    name: "Moringa Powder",
    slug: "/products/moringa",
    description: "Moringa oleifera leaf powder, often called the 'miracle tree'. One of the most nutrient-dense plants on Earth with 25 vitamins and minerals, 9 essential amino acids, and high protein content.",
    specs: ["Organic available", "25+ vitamins/minerals", "Complete amino acid profile"],
    benefits: "Superfood capsules, greens powder blends, energy bars, protein mixes",
  },
  {
    name: "Psyllium Husk",
    slug: "/products/psyllium-husk",
    description: "Indian psyllium husk (Plantago ovata) for fiber supplements, digestive health products, and functional foods. 85%+ dietary fiber, available in whole husk and powder forms.",
    specs: ["85%+ fiber content", "Indian origin", "Husk or powder"],
    benefits: "Fiber supplements, digestive health capsules, keto-friendly products",
  },
  {
    name: "Bitter Kola",
    slug: "/products/bitter-kola",
    description: "Garcinia kola nuts from Nigeria, traditionally used for energy, respiratory health, and immune support. Contains kolaviron, a natural biflavonoid with antioxidant and anti-inflammatory properties.",
    specs: ["Whole or extract", "High kolaviron", "Nigerian origin"],
    benefits: "Energy supplements, immune support formulas, traditional medicine",
  },
  {
    name: "Baobab Powder",
    slug: "/products/baobab-powder",
    description: "Baobab fruit powder with six times the vitamin C of oranges, twice the calcium of milk, and high levels of potassium, magnesium, and iron. A true superfruit.",
    specs: ["6x vitamin C of oranges", "High calcium & iron", "Prebiotic fiber"],
    benefits: "Vitamin C supplements, superfood blends, immune support products",
  },
  {
    name: "Ginger",
    slug: "/products/ginger",
    description: "Dried ginger root and ginger extract for anti-inflammatory supplements, digestive aids, and nausea relief formulations. High gingerol content from Nigerian origin.",
    specs: ["High gingerol", "Powder or extract", "Anti-inflammatory"],
    benefits: "Digestive supplements, anti-nausea capsules, joint support formulas",
  },
  {
    name: "Turmeric",
    slug: "/products/turmeric",
    description: "High-curcumin turmeric powder from India for anti-inflammatory and antioxidant supplement formulations. 3-5% natural curcumin content.",
    specs: ["3-5% curcumin", "Indian origin", "Powder or extract"],
    benefits: "Anti-inflammatory supplements, joint health, antioxidant formulas",
  },
];
---

<Layout
  title="Raw Materials for Supplement Manufacturers | Origin Direct"
  description="Moringa, psyllium husk, bitter kola, baobab, ginger, and turmeric for supplement and nutraceutical manufacturers. Direct from Africa and India, organic available, competitive B2B pricing."
  structuredData={[breadcrumbSchema]}
>
  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Industries", href: "/industries" }, { label: "Supplements" }]} />
  </div>

  <!-- Hero -->
  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-brand-900 via-brand-800 to-earth-800 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_40%_50%,rgba(196,154,42,0.3),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Supplements &amp; Nutraceuticals</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Raw Materials for Supplement Manufacturers</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        Superfoods and botanical ingredients from Africa and India for nutraceutical companies. Moringa, psyllium, bitter kola, baobab, and more.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Request Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Why Supplement Brands Choose Origin Direct</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          The global dietary supplement market exceeds $170 billion, with consumers increasingly seeking plant-based, naturally sourced ingredients. Africa and India produce some of the world's most potent botanicals, from moringa (containing 25+ vitamins and minerals) to psyllium husk (the gold standard in fiber supplementation).
        </p>
        <p>
          Origin Direct sources these ingredients directly from established processors and farming cooperatives, providing supplement manufacturers with consistent quality, competitive pricing, and the documentation needed for regulatory compliance. Whether you need raw powder for capsule filling, standardized extracts for tablets, or bulk ingredients for powder blends, we supply the right form at the right price.
        </p>
        <p>
          Our organic-certified supply chain supports USDA Organic, EU Organic, and other international organic standards. Every shipment includes Certificate of Analysis, heavy metal testing, microbiological testing, and pesticide residue reports.
        </p>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-10">Products for Supplement Manufacturers</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map((product) => (
          <a href={product.slug} class="group block bg-white rounded-2xl border border-gray-100 hover:border-green-200 hover:shadow-xl transition-all duration-300 p-6">
            <h3 class="text-lg font-bold text-gray-900 group-hover:text-green-700 transition-colors mb-3">
              {product.name}
            </h3>
            <p class="text-sm text-gray-600 mb-3 leading-relaxed">{product.description}</p>
            <p class="text-xs text-gray-500 mb-4"><strong>Applications:</strong> {product.benefits}</p>
            <div class="flex flex-wrap gap-1.5 mb-4">
              {product.specs.map((spec: string) => (
                <span class="inline-flex items-center px-2.5 py-1 bg-green-50 text-green-800 text-xs font-medium rounded-full border border-green-100">
                  {spec}
                </span>
              ))}
            </div>
            <div class="flex items-center gap-2 text-green-700 font-semibold text-sm group-hover:gap-3 transition-all">
              View Product
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Quality for Supplements -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Quality Standards for Nutraceuticals</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: "Heavy Metal Testing", detail: "Lead, arsenic, cadmium, and mercury tested to meet USP <2232> and EU supplement limits." },
          { title: "Microbiological Standards", detail: "Total plate count, E. coli, Salmonella, yeast and mold tested per batch. Results on CoA." },
          { title: "Pesticide Residue", detail: "Multi-residue screening for 200+ pesticides. Organic lots meet zero-residue standards." },
          { title: "Identity & Potency", detail: "HPLC/GC testing for active compounds like curcumin, gingerol, and kolaviron content." },
          { title: "Organic Certification", detail: "USDA Organic and EU Organic certified supply available for moringa, ginger, and turmeric." },
          { title: "GMP Documentation", detail: "Certificate of Analysis, MSDS, allergen declarations, and specifications sheets included." },
        ].map((spec) => (
          <div class="bg-gray-50 rounded-xl border border-gray-200 p-6">
            <h3 class="text-sm font-bold text-brand-800 mb-2">{spec.title}</h3>
            <p class="text-sm text-gray-600">{spec.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <section id="quote-form" class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <QuoteForm />
    </div>
  </section>
</Layout>
