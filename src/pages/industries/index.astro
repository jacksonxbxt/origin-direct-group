---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Industries", item: "https://origindirectgroup.com/industries" },
  ],
};

const industries = [
  {
    name: "Cosmetics & Personal Care",
    slug: "cosmetics",
    description: "Shea butter, cocoa butter, moringa oil, and other natural ingredients for cosmetic formulations. COSMOS and ECOCERT certified.",
    products: ["Shea Butter", "Cocoa Butter", "Moringa Oil", "African Black Soap", "Baobab Powder"],
  },
  {
    name: "Chocolate & Confectionery",
    slug: "chocolate",
    description: "Single-origin cocoa beans, natural and deodorized cocoa butter, cocoa powder, and shea stearin as a cocoa butter equivalent.",
    products: ["Cocoa Beans", "Cocoa Butter", "Cocoa Powder", "Shea Stearin", "Cashew Nuts"],
  },
  {
    name: "Food Ingredients & Processing",
    slug: "food-ingredients",
    description: "Bulk sesame seeds, cashew nuts, ginger, hibiscus, moringa, and other ingredients for food manufacturers.",
    products: ["Sesame Seeds", "Cashew Nuts", "Ginger", "Hibiscus", "Moringa"],
  },
  {
    name: "Hookah & Shisha",
    slug: "hookah-shisha",
    description: "Premium Nigerian hardwood charcoal for hookah lounges, distributors, and private label brands. Halal certified.",
    products: ["Hookah Charcoal"],
  },
  {
    name: "Beverages & Tea",
    slug: "beverages",
    description: "Hibiscus for agua de jamaica and karkade, ginger for ginger beer, moringa and baobab for health drinks.",
    products: ["Hibiscus", "Ginger", "Moringa", "Baobab Powder"],
  },
  {
    name: "Supplements & Nutraceuticals",
    slug: "supplements",
    description: "Moringa powder, psyllium husk, bitter kola, baobab, and other superfoods for supplement manufacturers.",
    products: ["Moringa", "Psyllium Husk", "Bitter Kola", "Baobab Powder"],
  },
  {
    name: "Animal Feed",
    slug: "animal-feed",
    description: "Agricultural by-products including cashew shell cake, palm kernel cake, cassava chips, and sesame meal.",
    products: ["Cashew Shell Cake", "Palm Kernel Cake", "Cassava", "Sesame Meal"],
  },
  {
    name: "Industrial Applications",
    slug: "industrial",
    description: "Castor oil, guar gum, natural rubber, kaolin clay, and gum arabic for industrial manufacturing.",
    products: ["Castor Oil", "Guar Gum", "Natural Rubber", "Kaolin Clay", "Gum Arabic"],
  },
  {
    name: "Soap & Candle Making",
    slug: "soap-candles",
    description: "Shea butter, coconut oil, palm kernel oil, cocoa butter, African black soap base, and beeswax for soap and candle manufacturers.",
    products: ["Shea Butter", "Coconut Oil", "Palm Kernel Oil", "Cocoa Butter", "African Black Soap"],
  },
];
---

<Layout
  title="Industries We Serve | Origin Direct Group"
  description="Origin Direct Group supplies raw materials to cosmetics, chocolate, food processing, hookah, beverage, supplement, animal feed, industrial, and soap and candle manufacturers worldwide."
  structuredData={[breadcrumbSchema]}
>
  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Industries" }]} />
  </div>

  <!-- Hero -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green-950 via-green-900 to-amber-950"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6">
        Industries We Serve
      </h1>
      <p class="text-lg md:text-xl text-green-100/90 max-w-2xl mx-auto leading-relaxed">
        From cosmetics labs to chocolate factories, hookah lounges to supplement brands. We supply the raw materials that power your production.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Industry Cards -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {industries.map((industry) => (
          <a
            href={`/industries/${industry.slug}`}
            class="group block bg-white rounded-2xl border border-gray-100 hover:border-green-200 hover:shadow-xl transition-all duration-300 overflow-hidden p-8"
          >
            <h2 class="text-xl font-bold text-gray-900 group-hover:text-green-700 transition-colors mb-3">
              {industry.name}
            </h2>
            <p class="text-gray-600 text-sm leading-relaxed mb-5">
              {industry.description}
            </p>
            <div class="flex flex-wrap gap-1.5 mb-5">
              {industry.products.map((product: string) => (
                <span class="inline-flex items-center px-2.5 py-1 bg-green-50 text-green-800 text-xs font-medium rounded-full border border-green-100">
                  {product}
                </span>
              ))}
            </div>
            <div class="flex items-center gap-2 text-green-700 font-semibold text-sm group-hover:gap-3 transition-all">
              Learn More
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28 bg-green-950">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Not Sure Which Products Fit Your Needs?</h2>
        <p class="text-lg text-green-200/80 max-w-xl mx-auto">
          Tell us about your industry and application. We will recommend the right products and specs.
        </p>
      </div>
      <QuoteForm />
    </div>
  </section>

</Layout>
