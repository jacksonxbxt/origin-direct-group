---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://origindirectgroup.com/" },
    { "@type": "ListItem", position: 2, name: "Industries", item: "https://origindirectgroup.com/industries" },
    { "@type": "ListItem", position: 3, name: "Beverages", item: "https://origindirectgroup.com/industries/beverages" },
  ],
};

const products = [
  {
    name: "Dried Hibiscus",
    slug: "/products/hibiscus",
    description: "Sun-dried hibiscus flowers (Roselle) for agua de jamaica, karkade, sorrel, bissap, and herbal tea blends. Deep red color, tart cranberry-like flavor, naturally caffeine-free.",
    specs: ["Whole or cut & sifted", "High anthocyanin", "Natural colorant"],
    uses: "Agua de jamaica, karkade, sorrel, iced tea, cocktail mixers",
  },
  {
    name: "Ginger",
    slug: "/products/ginger",
    description: "Dried split ginger and ground ginger from Nigeria for ginger beer, ginger ale, ginger shots, and spiced beverages. High gingerol content for strong, authentic ginger flavor.",
    specs: ["Dried split or ground", "High gingerol", "Nigerian origin"],
    uses: "Ginger beer, ginger ale, ginger shots, chai blends",
  },
  {
    name: "Moringa Powder",
    slug: "/products/moringa",
    description: "Fine-ground moringa leaf powder for green smoothies, health drinks, juice blends, and wellness shots. Rich in protein, iron, and vitamins A and C.",
    specs: ["Organic available", "Fine mesh", "Mild green flavor"],
    uses: "Green smoothies, wellness shots, protein drinks",
  },
  {
    name: "Baobab Powder",
    slug: "/products/baobab-powder",
    description: "Baobab fruit powder with six times the vitamin C of oranges. Natural tartness and high fiber content make it ideal for juice blends, smoothies, and vitamin-enriched beverages.",
    specs: ["6x vitamin C of oranges", "Natural tart flavor", "High fiber"],
    uses: "Vitamin drinks, juice blends, smoothie mixes",
  },
];
---

<Layout
  title="Natural Ingredients for Beverage Companies | Origin Direct"
  description="Hibiscus for agua de jamaica and karkade, ginger for ginger beer, moringa and baobab for health drinks. Direct from Africa, competitive bulk pricing for beverage manufacturers."
  structuredData={[breadcrumbSchema]}
>
  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs items={[{ label: "Industries", href: "/industries" }, { label: "Beverages" }]} />
  </div>

  <!-- Hero -->
  <section class="relative py-24 sm:py-32 bg-gradient-to-br from-brand-900 via-brand-800 to-earth-800 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_60%,rgba(196,154,42,0.3),transparent_70%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-light font-medium tracking-wide uppercase text-sm mb-4">Beverages &amp; Tea</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">Natural Ingredients for Beverage Companies</h1>
      <p class="text-xl text-brand-200 max-w-2xl mx-auto mb-10">
        Hibiscus, ginger, moringa, and baobab for tea companies, juice brands, and beverage manufacturers. Naturally sourced, bulk quantities, direct pricing.
      </p>
      <a href="#quote-form" class="inline-flex items-center px-8 py-4 bg-gold hover:bg-gold-dark text-white font-bold rounded-lg transition-colors shadow-lg text-lg">
        Request Quote
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Why Beverage Companies Choose Origin Direct</h2>
      <div class="prose prose-lg text-gray-700 space-y-5">
        <p>
          The global demand for natural, plant-based beverages is surging. From Mexico's agua de jamaica to Egypt's karkade, Caribbean sorrel to craft ginger beer, consumers want authentic flavors from real ingredients. West Africa produces many of the world's best botanical beverage ingredients, and Origin Direct brings them to your production line at competitive direct prices.
        </p>
        <p>
          Our hibiscus flowers produce a deep ruby-red infusion with the tart, cranberry-like flavor that beverage makers need. Our ginger delivers the sharp, warming kick that ginger beer and ginger shot consumers expect. And our moringa and baobab provide the nutritional profile that health-conscious brands look for.
        </p>
        <p>
          We supply in the volumes beverage manufacturers need, from 1 MT trial orders to ongoing container-load supply. Every shipment comes with food-grade documentation, microbiological testing, and consistent quality specifications your production team can rely on.
        </p>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-10">Products for Beverage Manufacturers</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {products.map((product) => (
          <a href={product.slug} class="group block bg-white rounded-2xl border border-gray-100 hover:border-green-200 hover:shadow-xl transition-all duration-300 p-6">
            <h3 class="text-lg font-bold text-gray-900 group-hover:text-green-700 transition-colors mb-3">
              {product.name}
            </h3>
            <p class="text-sm text-gray-600 mb-3 leading-relaxed">{product.description}</p>
            <p class="text-xs text-gray-500 mb-4"><strong>Common uses:</strong> {product.uses}</p>
            <div class="flex flex-wrap gap-1.5 mb-4">
              {product.specs.map((spec: string) => (
                <span class="inline-flex items-center px-2.5 py-1 bg-green-50 text-green-800 text-xs font-medium rounded-full border border-green-100">
                  {spec}
                </span>
              ))}
            </div>
            <div class="flex items-center gap-2 text-green-700 font-semibold text-sm group-hover:gap-3 transition-all">
              View Product
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Beverage Applications -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Beverage Applications by Region</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { region: "Latin America", drinks: "Agua de jamaica (hibiscus iced tea) is one of Mexico's most popular beverages. Also used in horchata blends and tropical fruit punches." },
          { region: "Middle East & North Africa", drinks: "Karkade (hot or cold hibiscus tea) is a staple across Egypt, Sudan, and the Levant. Ginger tea is widely consumed during winter." },
          { region: "Caribbean", drinks: "Sorrel (hibiscus drink) is a holiday tradition across Jamaica, Trinidad, and the wider Caribbean. Ginger beer is a year-round favorite." },
          { region: "West Africa", drinks: "Bissap (hibiscus), ginger juice, and zobo are everyday beverages across the region. Moringa tea is growing in popularity." },
          { region: "Europe & North America", drinks: "Craft ginger beer and ginger ale, functional health shots, superfood smoothies with moringa, and specialty herbal tea blends." },
          { region: "Health & Wellness", drinks: "Moringa lattes, baobab vitamin waters, turmeric and ginger wellness shots, antioxidant-rich hibiscus iced teas." },
        ].map((item) => (
          <div class="bg-gray-50 rounded-xl border border-gray-200 p-6">
            <h3 class="text-sm font-bold text-brand-800 mb-2">{item.region}</h3>
            <p class="text-sm text-gray-600">{item.drinks}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Documentation -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-brand-900 mb-8">Quality &amp; Food Safety</h2>
      <p class="text-gray-700 mb-8">Every ingredient ships with full documentation for your food safety and regulatory teams.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          "Certificate of Analysis (CoA)",
          "Microbiological Testing",
          "Pesticide Residue Report",
          "Heavy Metal Analysis",
          "Phytosanitary Certificate",
          "Certificate of Origin",
          "Aflatoxin Testing",
          "Organic Certification (available)",
          "HACCP Compliance",
        ].map((cert) => (
          <div class="flex items-start gap-3 bg-white rounded-lg p-4 border border-gray-200">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm font-medium text-gray-800">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <section id="quote-form" class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <QuoteForm />
    </div>
  </section>
</Layout>
