---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  structuredData?: Record<string, any>[];
}

const {
  title = "Origin Direct Group | B2B Commodity Exports from West Africa & India",
  description = "Direct commodity sourcing from Ghana, Nigeria & India. Shea butter, cocoa, cashew nuts, hookah charcoal, hibiscus, sesame seeds, moringa & ginger. Competitive pricing, quality guaranteed.",
  ogImage = "/og-image.jpg",
  ogType = "website",
  structuredData = [],
} = Astro.props;

const siteUrl = "https://origindirectgroup.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const whatsappNumber = "31612345678";
const whatsappMessage = encodeURIComponent("Hi, I'm interested in your commodities. Please send me more information.");

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Origin Direct Group",
  legalName: "Origin Direct Group",
  url: siteUrl,
  logo: `${siteUrl}/logo.png`,
  description: "B2B commodity broker exporting shea butter, cocoa, cashew nuts, hookah charcoal, hibiscus, sesame seeds, moringa and ginger from West Africa and India.",
  email: "info@origindirectgroup.com",
  telephone: "+31612345678",
  address: {
    "@type": "PostalAddress",
    addressCountry: "NL",
  },
  sameAs: [],
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "sales",
    email: "info@origindirectgroup.com",
    telephone: "+31612345678",
    availableLanguage: ["English", "French"],
  },
  knowsAbout: [
    "Shea Butter Export",
    "Cocoa Trading",
    "Cashew Nut Processing",
    "Hookah Charcoal Manufacturing",
    "Hibiscus Flower Export",
    "Sesame Seed Trading",
    "Moringa Powder Production",
    "Ginger Export",
    "West African Commodities",
    "B2B Commodity Trading",
  ],
  areaServed: [
    { "@type": "Continent", name: "Europe" },
    { "@type": "Continent", name: "North America" },
    { "@type": "Continent", name: "South America" },
    { "@type": "Continent", name: "Asia" },
    { "@type": "Continent", name: "Africa" },
  ],
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Origin Direct Group",
  url: siteUrl,
  description: "B2B commodity sourcing from West Africa and India. Direct from producers to buyers worldwide.",
  publisher: {
    "@type": "Organization",
    name: "Origin Direct Group",
  },
};

const allSchemas = [organizationSchema, webSiteSchema, ...structuredData];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Origin Direct Group" />
    <meta name="theme-color" content="#1a2e1a" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Origin Direct Group" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Prefetch key pages -->
    <link rel="prefetch" href="/products" />
    <link rel="prefetch" href="/quote" />

    <!-- Structured Data -->
    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col text-gray-900 font-sans bg-white">
    <Header />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />

    <!-- WhatsApp Floating Button -->
    <a
      href={`https://wa.me/${whatsappNumber}?text=${whatsappMessage}`}
      target="_blank"
      rel="noopener noreferrer"
      class="whatsapp-float"
      aria-label="Chat on WhatsApp"
    >
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
        />
      </svg>
    </a>
  </body>
</html>
