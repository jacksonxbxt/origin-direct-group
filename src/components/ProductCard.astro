---
interface Props {
  name: string;
  slug: string;
  origin: string;
  description: string;
  image?: string;
  grades?: string;
}

const { name, slug, origin, description, image, grades } = Astro.props;

// Origin flag emojis
const flagMap: Record<string, string> = {
  Ghana: "\uD83C\uDDEC\uD83C\uDDED",
  Nigeria: "\uD83C\uDDF3\uD83C\uDDEC",
  India: "\uD83C\uDDEE\uD83C\uDDF3",
  "West Africa": "\uD83C\uDF0D",
  "Ghana & Nigeria": "\uD83C\uDDEC\uD83C\uDDED \uD83C\uDDF3\uD83C\uDDEC",
};

const flag = flagMap[origin] || "\uD83C\uDF0D";

// Gradient backgrounds per product as placeholder
const gradientMap: Record<string, string> = {
  "shea-butter": "from-amber-100 to-amber-200",
  cocoa: "from-amber-800 to-amber-900",
  "cashew-nuts": "from-orange-100 to-orange-200",
  "hookah-charcoal": "from-gray-700 to-gray-900",
  hibiscus: "from-rose-300 to-rose-500",
  "sesame-seeds": "from-yellow-50 to-yellow-200",
  moringa: "from-green-200 to-green-400",
  ginger: "from-amber-200 to-amber-400",
};

const gradient = gradientMap[slug] || "from-brand-100 to-brand-200";
---

<article class="group bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
  <!-- Image / Placeholder Gradient -->
  <div class={`relative h-48 bg-gradient-to-br ${gradient} flex items-center justify-center overflow-hidden`}>
    <img
      src={`/images/products/${slug}.jpg`}
      alt={name}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
    />
    <span class="text-4xl opacity-60 hidden items-center justify-center absolute inset-0" style="display:none;">{flag}</span>
    {grades && (
      <div class="absolute top-3 right-3">
        <span class="inline-block px-3 py-1 bg-white/90 backdrop-blur-sm text-xs font-semibold text-brand-800 rounded-full shadow-sm">
          {grades}
        </span>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-6">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="text-lg font-bold text-brand-900 group-hover:text-brand-700 transition-colors">
        {name}
      </h3>
      <span class="text-sm shrink-0" title={origin}>{flag}</span>
    </div>

    <p class="text-sm text-gray-500 mb-1 font-medium">{origin}</p>
    <p class="text-sm text-gray-600 leading-relaxed mb-5 line-clamp-3">
      {description}
    </p>

    <!-- Actions -->
    <div class="flex items-center gap-3">
      <a
        href="/quote"
        class="flex-1 text-center px-4 py-2.5 bg-brand-700 text-white text-sm font-semibold rounded-lg hover:bg-brand-600 transition-colors"
      >
        Get Quote
      </a>
      <a
        href={`/products/${slug}`}
        class="flex-1 text-center px-4 py-2.5 border border-brand-200 text-brand-700 text-sm font-semibold rounded-lg hover:bg-brand-50 transition-colors"
      >
        Learn More
      </a>
    </div>
  </div>
</article>
