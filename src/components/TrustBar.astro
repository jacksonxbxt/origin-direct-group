---
const metrics = [
  {
    value: "5,000+",
    label: "MT Exported",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>`,
  },
  {
    value: "150+",
    label: "Countries Served",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
  {
    value: "Direct",
    label: "from Source",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
  },
  {
    value: "Quality",
    label: "Guaranteed",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
  },
];

const certifications = [
  "ISO 9001",
  "HACCP",
  "Fair Trade",
  "Organic",
];
---

<section class="bg-brand-50 border-y border-brand-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <!-- Metrics -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 mb-10">
      {metrics.map((metric) => (
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-100 text-brand-700 mb-3" set:html={metric.icon} />
          <div class="text-2xl lg:text-3xl font-bold text-brand-900">{metric.value}</div>
          <div class="text-sm text-brand-700 font-medium mt-1">{metric.label}</div>
        </div>
      ))}
    </div>

    <!-- Certifications -->
    <div class="flex flex-wrap items-center justify-center gap-4">
      <span class="text-xs font-semibold uppercase tracking-wider text-brand-600 mr-2">
        Certifications:
      </span>
      {certifications.map((cert) => (
        <span class="inline-flex items-center px-4 py-2 bg-white border border-brand-200 rounded-full text-xs font-semibold text-brand-800 shadow-sm">
          <svg class="w-3.5 h-3.5 text-gold mr-1.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          {cert}
        </span>
      ))}
    </div>
  </div>
</section>
