---
interface Props {
  productName?: string;
}

const { productName } = Astro.props;

const products = [
  "Shea Butter",
  "Cocoa",
  "Cashew Nuts",
  "Hookah Charcoal",
  "Hibiscus",
  "Sesame Seeds",
  "Moringa",
  "Ginger",
  "Other (please specify below)",
];

const whatsappNumber = "31612345678";
const whatsappMessage = encodeURIComponent(
  productName
    ? `Hi, I'd like a quote for ${productName}. Please send me more information.`
    : "Hi, I'm interested in your commodities. Please send me more information."
);
---

<div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 lg:p-10">
  <h3 class="text-2xl font-bold text-brand-900 mb-2">Request a Quote</h3>
  <p class="text-sm text-gray-500 mb-8">
    Fill in your requirements and we'll get back to you with competitive pricing.
  </p>

  <form action="https://formspree.io/f/mjgaqaqj" method="POST" class="space-y-5">
    <!-- Product -->
    <div>
      <label for="product" class="block text-sm font-medium text-gray-700 mb-1.5">
        Product <span class="text-red-500">*</span>
      </label>
      <select
        id="product"
        name="product"
        required
        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow"
      >
        <option value="" disabled selected={!productName}>Select a commodity</option>
        {products.map((p) => (
          <option value={p} selected={p === productName}>
            {p}
          </option>
        ))}
      </select>
    </div>

    <!-- Custom Product (shown when "Other" is selected) -->
    <div id="custom-product-field" class="hidden">
      <label for="custom_product" class="block text-sm font-medium text-gray-700 mb-1.5">
        What product are you looking for? <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="custom_product"
        name="custom_product"
        placeholder="e.g., Tiger Nuts, Kola Nuts, Baobab Powder, Cassava Starch..."
        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow"
      />
      <p class="mt-1 text-xs text-gray-400">We source a wide range of African and Indian commodities - just tell us what you need.</p>
    </div>

    <!-- Quantity -->
    <div>
      <label for="quantity" class="block text-sm font-medium text-gray-700 mb-1.5">
        Quantity <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="quantity"
        name="quantity"
        required
        placeholder="e.g., 20 MT"
        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow"
      />
    </div>

    <!-- Destination Country -->
    <div>
      <label for="destination" class="block text-sm font-medium text-gray-700 mb-1.5">
        Destination Country <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="destination"
        name="destination"
        required
        placeholder="e.g., Netherlands"
        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow"
      />
    </div>

    <!-- Company Name -->
    <div>
      <label for="company" class="block text-sm font-medium text-gray-700 mb-1.5">
        Company Name <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="company"
        name="company"
        required
        placeholder="Your company name"
        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow"
      />
    </div>

    <!-- Email -->
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
        Email <span class="text-red-500">*</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="you@company.com"
        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow"
      />
    </div>

    <!-- Phone (optional) -->
    <div>
      <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">
        Phone <span class="text-gray-400 font-normal">(optional)</span>
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        placeholder="+31 6 1234 5678"
        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow"
      />
    </div>

    <!-- Message (optional) -->
    <div>
      <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">
        Message <span class="text-gray-400 font-normal">(optional)</span>
      </label>
      <textarea
        id="message"
        name="message"
        rows="3"
        placeholder="Any specific requirements, certifications needed, delivery timeline..."
        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow resize-y"
      ></textarea>
    </div>

    <!-- Submit -->
    <button
      type="submit"
      class="w-full px-6 py-3.5 bg-brand-700 text-white font-semibold rounded-lg hover:bg-brand-600 active:bg-brand-800 transition-colors shadow-sm text-sm"
    >
      Request Quote
    </button>
  </form>

  <!-- Response time + WhatsApp alternative -->
  <div class="mt-6 pt-6 border-t border-gray-100 text-center">
    <p class="text-sm text-gray-500 mb-3">
      <svg class="inline w-4 h-4 text-brand-600 mr-1 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      We respond within 2 hours during business days
    </p>
    <p class="text-sm text-gray-500">
      Prefer instant contact?
      <a
        href={`https://wa.me/${whatsappNumber}?text=${whatsappMessage}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-green-600 font-medium hover:text-green-700 transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        Chat on WhatsApp
      </a>
    </p>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('select[name="product"]').forEach((select) => {
      const form = select.closest('form');
      if (!form) return;
      const customField = form.parentElement?.querySelector('#custom-product-field');
      const customInput = form.parentElement?.querySelector('#custom_product');
      if (!customField || !customInput) return;

      select.addEventListener('change', () => {
        if (select.value === 'Other (please specify below)') {
          customField.classList.remove('hidden');
          customInput.setAttribute('required', '');
        } else {
          customField.classList.add('hidden');
          customInput.removeAttribute('required');
        }
      });
    });
  });
</script>
