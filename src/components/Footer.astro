---
const products = [
  { name: "Shea Butter", slug: "shea-butter" },
  { name: "Cocoa", slug: "cocoa" },
  { name: "Cashew Nuts", slug: "cashew-nuts" },
  { name: "Hookah Charcoal", slug: "hookah-charcoal" },
  { name: "Hibiscus", slug: "hibiscus" },
  { name: "Sesame Seeds", slug: "sesame-seeds" },
  { name: "Moringa", slug: "moringa" },
  { name: "Ginger", slug: "ginger" },
];

const markets = [
  { name: "Europe", href: "/markets#europe" },
  { name: "Americas", href: "/markets#americas" },
  { name: "Middle East", href: "/markets#middle-east" },
  { name: "Asia", href: "/markets#asia" },
];

const whatsappNumber = "31612345678";
const whatsappMessage = encodeURIComponent("Hi, I'm interested in your commodities. Please send me more information.");
---

<footer class="bg-brand-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <!-- Company Info -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 mb-4">
          <svg class="w-7 h-7 text-brand-400" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M16 2C16 2 8 8 8 16c0 5.5 3.6 10 8 10s8-4.5 8-10c0-8-8-14-8-14z" fill="currentColor" opacity="0.2"/>
            <path d="M16 4c0 0-6 5-6 12 0 4.4 2.7 8 6 8s6-3.6 6-8c0-7-6-12-6-12z" fill="currentColor" opacity="0.4"/>
            <path d="M16 8c0 0-4 3.5-4 8 0 3 1.8 5.5 4 5.5s4-2.5 4-5.5c0-4.5-4-8-4-8z" fill="currentColor"/>
          </svg>
          <span class="text-lg font-bold tracking-tight">
            ORIGIN <span class="font-medium text-brand-400">DIRECT</span>
          </span>
        </a>
        <p class="text-brand-300 text-sm italic mb-4">
          Direct from source. Direct to you.
        </p>
        <p class="text-brand-400 text-sm leading-relaxed">
          Origin Direct Group<br />
          Unit 2201, 22/F Chung Kiu Comm. Bldg.<br />
          47-51 Shan Tung St. Mongkok<br />
          Hong Kong
        </p>
      </div>

      <!-- Products -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gold mb-5">Products</h3>
        <ul class="space-y-3">
          {products.map((product) => (
            <li>
              <a
                href={`/products/${product.slug}`}
                class="text-sm text-brand-300 hover:text-white transition-colors"
              >
                {product.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Markets -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gold mb-5">Markets</h3>
        <ul class="space-y-3">
          {markets.map((market) => (
            <li>
              <a
                href={market.href}
                class="text-sm text-brand-300 hover:text-white transition-colors"
              >
                {market.name}
              </a>
            </li>
          ))}
        </ul>

        <h3 class="text-sm font-semibold uppercase tracking-wider text-gold mt-8 mb-5">Company</h3>
        <ul class="space-y-3">
          <li><a href="/about" class="text-sm text-brand-300 hover:text-white transition-colors">About Us</a></li>
          <li><a href="/market-intelligence" class="text-sm text-brand-300 hover:text-white transition-colors">Market Intelligence</a></li>
          <li><a href="/blog" class="text-sm text-brand-300 hover:text-white transition-colors">Blog</a></li>
          <li><a href="/quote" class="text-sm text-brand-300 hover:text-white transition-colors">Request Quote</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gold mb-5">Contact</h3>
        <ul class="space-y-4">
          <li>
            <a
              href="/quote"
              class="flex items-start gap-3 text-sm text-brand-300 hover:text-white transition-colors group"
            >
              <svg class="w-5 h-5 shrink-0 mt-0.5 text-brand-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Request a Quote
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-brand-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-brand-500">
        &copy; 2026 Origin Direct Group B.V. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="text-sm text-brand-500 hover:text-brand-300 transition-colors">
          Privacy Policy
        </a>
        <a href="/terms" class="text-sm text-brand-500 hover:text-brand-300 transition-colors">
          Terms & Conditions
        </a>
      </div>
    </div>
  </div>
</footer>
